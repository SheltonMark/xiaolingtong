# =====================================================
# XiaoLingTong server environment example
# Copy the needed keys into your real .env file.
# Do not commit real production secrets.
# =====================================================

# App
NODE_ENV=development
PORT=3000
API_HOST=http://localhost:3000

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=xiaolingtong

# WeChat mini program
WX_APPID=
WX_SECRET=

# WeChat Pay
WX_MCH_ID=
WX_APIV3_KEY=
WX_MCH_KEY_PATH=
WX_MCH_SERIAL=
WX_PAY_PUBLIC_KEY_PATH=
WX_PAY_PUBLIC_KEY_ID=

# Tencent COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-shanghai

# Tencent Cloud OCR + SMS
# Use a Tencent Cloud key that has OCR and SMS API permissions.
# Keep these empty until the account is ready; production cert OCR/SMS
# will not work until the values below are filled.
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=

# OCR region. Keep aligned with the OCR service region used in Tencent Cloud.
TENCENT_OCR_REGION=ap-beijing

# SMS region. Domestic SMS commonly uses ap-guangzhou.
TENCENT_SMS_REGION=ap-guangzhou

# SMS app, sign, and template must be created and approved in Tencent Cloud first.
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=

# Shared certification template. Recommended content shape:
# "Your verification code is {1}".
TENCENT_SMS_CERT_TEMPLATE_ID=

# Optional scene-specific template overrides.
TENCENT_SMS_WORKER_CERT_TEMPLATE_ID=
TENCENT_SMS_ENTERPRISE_CERT_TEMPLATE_ID=

# Local development switches.
# Set to 1 only when Tencent Cloud is not configured yet and you still need
# to test the front-end form flow locally. Do not enable these in production.
TENCENT_SMS_MOCK=0
TENCENT_OCR_MOCK=0

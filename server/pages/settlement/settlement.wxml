<!--pages/settlement/settlement.wxml-->
<view class="settlement-page">
  <nav-bar title="招工管理" />

  <!-- Tab -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === index ? 'tab-active' : ''}}"
          wx:for="{{tabs}}" wx:key="index"
          data-index="{{index}}" bindtap="onTabChange">
      <text>{{item.label}}</text>
    </view>
  </view>

  <!-- Tab 1: 招工管理 -->
  <view class="list-container" wx:if="{{currentTab === 0}}">
    <view class="job-card" wx:for="{{jobs}}" wx:key="id" data-id="{{item.id}}" bindtap="onViewJobDetail">
      <view class="card-top">
        <text class="job-title">{{item.title}}</text>
        <view class="status-tag status-bg-{{item.statusColor}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>

      <view class="job-info-row">
        <text class="job-info-label">工价：</text>
        <text class="job-info-value text-cta font-semibold">{{item.salary}}{{item.salaryUnit}}</text>
      </view>

      <view class="job-info-row">
        <text class="job-info-label">人数：</text>
        <text class="job-info-value">需{{item.needCount}}人 · 已报名{{item.appliedCount}}人</text>
      </view>

      <view class="job-info-row" wx:if="{{item.dateRange}}">
        <text class="job-info-label">日期：</text>
        <text class="job-info-value">{{item.dateRange}}</text>
      </view>
    </view>

    <empty-state wx:if="{{jobs.length === 0}}" text="暂无招工信息" subText="去发布招工吧" />
  </view>

  <!-- Tab 2: 工资结算 -->
  <view class="list-container" wx:if="{{currentTab === 1}}">
    <view class="settlement-card" wx:for="{{settlements}}" wx:key="id" data-id="{{item.id}}" bindtap="onViewSettlementDetail">
      <view class="card-top">
        <text class="settlement-title">{{item.title}}</text>
        <view class="status-tag status-bg-{{item.statusColor}}">
          <text>{{item.statusText}}</text>
        </view>
      </view>

      <view class="settlement-info-row">
        <text class="settlement-info-label">工作日期：</text>
        <text class="settlement-info-value">{{item.dateRange}}</text>
      </view>

      <view class="settlement-summary">
        <view class="summary-item">
          <text class="summary-val">{{item.totalWorkers}}</text>
          <text class="summary-label">实到人数</text>
        </view>
        <view class="summary-item">
          <text class="summary-val">{{item.totalHours}}h</text>
          <text class="summary-label">总工时</text>
        </view>
        <view class="summary-item">
          <text class="summary-val text-warm">¥{{item.factoryTotal}}</text>
          <text class="summary-label">应付金额</text>
        </view>
      </view>
    </view>

    <empty-state wx:if="{{settlements.length === 0}}" text="暂无结算信息" subText="完成招工后可查看结算" />
  </view>
</view>

@import '/iconfont/iconfont.wxss';

.info-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
}

/* 头部 */
.card-header {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 24rpx 0;
}
.avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.card-author { flex: 1; min-width: 0; }
.author-name {
  font-size: 26rpx; font-weight: 600; color: #1E293B;
  display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.author-meta { font-size: 20rpx; color: #94A3B8; }
.header-btns { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.icon-btn {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: #F1F5F9; display: flex; align-items: center; justify-content: center;
}
.icon-btn .iconfont { font-size: 24rpx; color: #94A3B8; }
.share-btn {
  padding: 0;
  line-height: 52rpx;
}
.share-btn::after {
  border: none;
}

/* 文字内容 */
.card-content {
  font-size: 26rpx; color: #1E293B; line-height: 1.7;
  display: block; padding: 20rpx 24rpx;
}
.img-grid {
  margin: 0 24rpx 16rpx;
}

/* 底部三按钮 */
.card-actions {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 16rpx 16rpx;
  border-top: 1rpx solid #F1F5F9;
}
.action-btn {
  flex: 1;
  height: 72rpx;
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 14rpx;
}
.action-btn .iconfont { font-size: 28rpx; }
.action-icon-align { position: relative; top: 2rpx; }
.action-wechat { color: #10B981; background-color: #ECFDF5; }
.action-phone { color: #3B82F6; background-color: #EFF6FF; }
.action-chat { color: #F97316; background-color: #FFF7ED; }

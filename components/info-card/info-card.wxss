@import '/iconfont/iconfont.wxss';

.info-card {
  background-color: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  position: relative;
}
.promoted-badge {
  position: absolute; top: 0; left: 0; z-index: 2;
  display: flex; align-items: center; gap: 4rpx;
  background-color: #F97316; color: #fff;
  font-size: 20rpx; padding: 6rpx 16rpx;
  border-radius: 24rpx 0 16rpx 0;
}

/* 头部 */
.card-header {
  display: flex; align-items: center; gap: 16rpx;
  padding: 24rpx 24rpx 0;
}
.avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.card-author { flex: 1; min-width: 0; }
.author-name-row { display: flex; align-items: center; gap: 8rpx; }
.author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.vip-badge {
  font-size: 18rpx; font-weight: 600; color: #fff;
  background: linear-gradient(135deg, #FBBF24, #F97316);
  padding: 2rpx 10rpx; border-radius: 6rpx;
  flex-shrink: 0; line-height: 1.4;
}
.author-meta { font-size: 20rpx; color: #94A3B8; }
.header-btns { display: flex; align-items: center; gap: 12rpx; flex-shrink: 0; }
.header-pill-btn {
  display: flex; align-items: center; gap: 6rpx;
  height: 48rpx; padding: 0 16rpx;
  width: auto; min-width: 0;
  border-radius: 24rpx;
  font-size: 20rpx; font-weight: 500;
  background: #F1F5F9;
  color: #94A3B8;
  margin: 0; line-height: 48rpx; box-sizing: border-box;
}
.header-pill-btn::after { border: none; }
.header-pill-btn .iconfont { font-size: 22rpx; color: inherit; }
.pill-report { color: #94A3B8; }
.pill-share { color: #94A3B8; position: relative; }
.pill-share-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  opacity: 0; width: 100%; height: 100%;
  margin: 0; padding: 0; min-width: 0;
}

/* 文字内容 */
.card-mode-row {
  padding: 16rpx 24rpx 0;
}

.card-mode-badge {
  display: inline-flex;
  align-items: center;
  height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #EFF6FF;
  color: #2563EB;
  font-size: 20rpx;
  font-weight: 600;
}

.card-content {
  font-size: 28rpx;
  color: #1E293B;
  line-height: 1.7;
  display: block;
  padding: 20rpx 24rpx;
}
.img-grid {
  margin: 0 24rpx 16rpx;
}
.img-grid-item {
  position: relative;
}
.img-extra-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
  border-radius: 12rpx 0 0 0;
}

/* 底部两按钮 */
.card-actions {
  display: flex;
  gap: 16rpx;
  padding: 12rpx 16rpx 16rpx;
  border-top: 1rpx solid #F1F5F9;
}
.action-btn {
  flex: 1;
  height: 72rpx;
  display: flex; align-items: center; justify-content: center; gap: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
  border-radius: 14rpx;
}
.action-btn .iconfont { font-size: 28rpx; }
.action-icon-align { position: relative; top: 2rpx; }
.action-contact { color: #059669; background-color: #ECFDF5; }
.action-chat { color: #F97316; background-color: #FFF7ED; }

<view class="info-card" bindtap="onTapCard">
  <!-- 头部：头像 + 公司名 + 投诉/分享 -->
  <view class="card-header">
    <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="avatar-img" />
    <view wx:else class="text-avatar" style="width:72rpx;height:72rpx;font-size:28rpx;background-color:{{item.avatarColor || '#3B82F6'}};">{{item.avatarText || (displayName && displayName[0]) || '企'}}</view>
    <view class="card-author">
      <text class="author-name">{{displayName || item.companyName || '企业用户'}}</text>
      <text class="author-meta" wx:if="{{item.companyMeta && item.time}}">{{item.companyMeta}} · {{item.time}}</text>
      <text class="author-meta" wx:elif="{{item.companyMeta}}">{{item.companyMeta}}</text>
      <text class="author-meta" wx:elif="{{item.time}}">{{item.time}}</text>
    </view>
    <view class="header-btns">
      <view class="header-pill-btn pill-report" catchtap="onTapReport">
        <text class="iconfont icon-tishixinxi"></text>
        <text>举报</text>
      </view>
      <view class="header-pill-btn pill-share" catchtap="onTapShare">
        <text class="iconfont icon-fenxiang1"></text>
        <text>帮找</text>
        <button class="pill-share-overlay" open-type="share" data-id="{{item.id}}"></button>
      </view>
    </view>
  </view>
  <!-- 文字内容 -->
  <text class="card-content">{{item.content}}</text>
  <!-- 图片网格 -->
  <view class="img-grid img-count-{{item.images.length}}" wx:if="{{item.images && item.images.length > 0}}">
    <view class="img-grid-item" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this">
      <image src="{{img}}" mode="aspectFill" class="img-grid-img" data-urls="{{item.images}}" data-current="{{img}}" catchtap="onPreviewImage" />
    </view>
  </view>
  <!-- 底部三按钮 -->
  <view class="card-actions" wx:if="{{showContact}}">
    <view class="action-btn action-wechat" catchtap="onTapWechat">
      <text class="iconfont icon-xiaoxi action-icon-align"></text>
      <text>微信</text>
    </view>
    <view class="action-btn action-phone" catchtap="onTapPhone">
      <text class="iconfont icon-shouji action-icon-align"></text>
      <text>电话</text>
    </view>
    <view class="action-btn action-chat" catchtap="onTapChat">
      <text class="iconfont icon-pinglun action-icon-align"></text>
      <text>在线聊</text>
    </view>
  </view>
</view>

.st-card {
  margin: 20rpx 24rpx 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background-color: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.card-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.st-summary {
  display: flex;
  gap: 12rpx;
}

.st-sum-item {
  flex: 1;
  background-color: #F8FAFC;
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.st-sum-val {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.st-sum-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #64748B;
}

.st-note-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.st-note {
  font-size: 22rpx;
  color: #64748B;
}

.st-supervisor-row {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background-color: #F8FAFC;
  border: 1rpx solid #E2E8F0;
}

.st-supervisor-label {
  display: block;
  font-size: 20rpx;
  color: #64748B;
}

.st-supervisor-value {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #0F172A;
}

.st-supervisor-pending {
  color: #D97706;
}

.st-supervisor-hint {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #94A3B8;
}

.st-filter-row {
  margin-top: 20rpx;
  white-space: nowrap;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.st-filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: #64748B;
  font-size: 22rpx;
  box-shadow: inset 0 0 0 1rpx #E2E8F0;
}

.st-filter-chip-active {
  background-color: #0F172A;
  color: #FFFFFF;
}

.st-applicant-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEF2F7;
}

.st-applicant-card:last-child {
  border-bottom: none;
}

.st-applicant-main {
  display: flex;
  gap: 18rpx;
}

.st-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background-color: #2563EB;
  color: #FFFFFF;
  font-size: 28rpx;
}

.st-avatar-img {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background-color: #E2E8F0;
}

.st-applicant-info {
  flex: 1;
}

.st-applicant-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.st-applicant-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #0F172A;
}

.st-status-pill,
.st-supervisor-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.st-status-rose { background-color: #FFF1F2; color: #E11D48; }
.st-status-blue { background-color: #EFF6FF; color: #2563EB; }
.st-status-violet { background-color: #F5F3FF; color: #7C3AED; }
.st-status-green { background-color: #ECFDF5; color: #16A34A; }
.st-status-slate { background-color: #F1F5F9; color: #475569; }
.st-status-amber { background-color: #FFFBEB; color: #D97706; }

.st-supervisor-pill {
  background-color: #FEF3C7;
  color: #B45309;
}

.st-applicant-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748B;
}

.st-applicant-actions {
  display: flex;
  align-items: stretch;
  gap: 14rpx;
  margin-top: 20rpx;
}

.st-mini-btn {
  display: block;
  flex: 1 1 0;
  min-width: 0;
  height: 68rpx;
  line-height: 68rpx;
  margin: 0;
  padding: 0 24rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  white-space: nowrap;
  border: none;
  overflow: hidden;
}

.st-mini-btn::after {
  border: none;
}

.st-mini-primary {
  background-color: #2563EB;
  color: #FFFFFF;
}

.st-mini-ghost {
  background-color: #FFF1F2;
  color: #E11D48;
}

.st-mini-warn {
  background-color: #FFFBEB;
  color: #D97706;
}

.st-empty-card {
  text-align: center;
}

.st-empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.st-empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #64748B;
}

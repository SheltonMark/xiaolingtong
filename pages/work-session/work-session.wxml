<view class="ws-page">
  <nav-bar title="工作记录" />

  <block wx:if="{{mode === 'hourly'}}">
    <view class="status-card">
      <view class="sc-top">
        <text class="sc-company">{{status.company}} · {{status.jobType}}</text>
        <text class="sc-badge">进行中</text>
      </view>
      <view class="sc-hours">
        <text class="sc-hours-big">{{status.hoursToday}}</text>
        <text class="sc-hours-unit">小时</text>
      </view>
      <text class="sc-sub">今日工时统计 · {{status.startTime}} 开始</text>
      <text class="sc-sub ws-rule-sub" wx:if="{{status.checkoutRuleHint}}">{{status.checkoutRuleHint}}</text>
      <view class="sc-stats">
        <view class="sc-stat">
          <text class="sc-stat-val">出勤：{{status.todayAttend}}人</text>
        </view>
        <view class="sc-stat">
          <text class="sc-stat-val">异常：{{status.todayAnomaly}}人</text>
        </view>
        <view class="sc-stat">
          <text class="sc-stat-val">已签退：{{status.checkedOutCount}}人</text>
        </view>
      </view>
    </view>

    <view class="ws-card">
      <view class="card-header-row">
        <text class="card-title"><text class="iconfont icon-xiangji"></text> 现场拍照记录（每 2 小时）</text>
      </view>
      <view class="photo-list">
        <view class="photo-item photo-done" wx:for="{{photoRecords}}" wx:key="id" wx:if="{{item.status === 'done'}}">
          <image wx:if="{{item.photoUrl}}" src="{{item.photoUrl}}" class="photo-thumb" mode="aspectFill" />
          <view wx:else class="photo-thumb-placeholder photo-thumb-done">
            <text class="iconfont icon-tupian"></text>
          </view>
          <view class="photo-info">
            <text class="photo-time">{{item.timeRange}}</text>
            <text class="photo-status text-fresh">已上传 · {{item.uploadTime}}</text>
          </view>
          <text class="photo-check iconfont icon-yigouxuan text-fresh"></text>
        </view>
        <view class="photo-item photo-pending" wx:for="{{photoRecords}}" wx:key="id" wx:if="{{item.status === 'pending'}}">
          <view class="photo-thumb-placeholder">
            <text class="iconfont icon-xiangji"></text>
          </view>
          <view class="photo-info">
            <text class="photo-time">{{item.timeRange}}</text>
            <text class="photo-status text-warm">待上传</text>
          </view>
          <button class="photo-btn" data-id="{{item.id}}" disabled="{{!canFinishWork}}" bindtap="onTakePhoto">拍照</button>
        </view>
      </view>
    </view>

    <view class="ws-card">
      <view class="card-header-row">
        <text class="card-title"><text class="iconfont icon-jilu"></text> 工时记录</text>
        <text class="card-tip">点击蓝色按钮自动签退并计算工时</text>
      </view>
      <view class="hour-list">
        <view class="worker-card" wx:for="{{workers}}" wx:key="id">
          <view class="worker-main">
            <view class="piece-worker">
              <view class="text-avatar text-avatar-sm" style="background-color: #3B82F6;">{{item.displayName[0]}}</view>
              <view class="piece-info">
                <text class="piece-name">{{item.displayName}}</text>
                <text class="piece-sub">签到 {{item.checkInTime || '--'}}</text>
                <text class="piece-sub">签退 {{item.checkOutTime || '--'}} · 工时 {{item.hoursText}}</text>
              </view>
            </view>
            <button
              class="checkout-btn {{item.checkedOut ? 'checkout-btn-done' : ''}}"
              loading="{{item.signingOut}}"
              disabled="{{item.checkoutDisabled || item.signingOut || item.checkedOut}}"
              data-id="{{item.id}}"
              bindtap="onQuickCheckout"
            >
              {{item.checkoutButtonText}}
            </button>
          </view>

          <view class="worker-tags">
            <text class="ws-tag ws-tag-{{item.attendanceStatus}}">{{item.attendanceStatusText}}</text>
            <text class="ws-inline-link" data-id="{{item.id}}" bindtap="onToggleRemark">异常/备注</text>
            <text class="ws-inline-link" wx:if="{{item.checkedOut}}" data-id="{{item.id}}" bindtap="onToggleEditCheckoutTime">修改时间</text>
          </view>

          <view class="worker-expand" wx:if="{{item.remarkExpanded}}">
            <view class="expand-row">
              <text class="expand-label">状态</text>
              <picker
                mode="selector"
                range="{{attendanceOptions}}"
                range-key="label"
                data-id="{{item.id}}"
                bindchange="onStatusChange"
              >
                <view class="picker-field">{{item.attendanceStatusText}}</view>
              </picker>
            </view>
            <view class="expand-row">
              <text class="expand-label">备注</text>
              <input
                class="remark-input"
                placeholder="补充原因说明"
                value="{{item.statusNote}}"
                data-id="{{item.id}}"
                bindinput="onRemarkInput"
                bindblur="onRemarkBlur"
              />
            </view>
            <view class="expand-row" wx:if="{{item.editingCheckoutTime}}">
              <text class="expand-label">签退</text>
              <picker mode="time" data-id="{{item.id}}" bindchange="onManualCheckoutChange">
                <view class="picker-field">{{item.manualCheckoutTime || '选择签退时间'}}</view>
              </picker>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{mode === 'piece'}}">
    <view class="status-card status-card-piece">
      <view class="sc-top">
        <text class="sc-company">{{pieceStatus.company}} · {{pieceStatus.jobType}}</text>
        <text class="sc-badge">进行中</text>
      </view>
      <view class="sc-hours">
        <text class="sc-hours-big">{{pieceStatus.piecesToday}}</text>
        <text class="sc-hours-unit">件</text>
      </view>
      <text class="sc-sub">今日完成 · {{pieceStatus.pricePerPiece}}元/件 · 预计收入 {{pieceStatus.earningsToday}}</text>
      <view class="sc-stats">
        <view class="sc-stat">
          <text class="sc-stat-val">出勤：{{pieceStatus.todayAttend}}人</text>
        </view>
        <view class="sc-stat">
          <text class="sc-stat-val">异常：{{pieceStatus.todayAnomaly}}人</text>
        </view>
      </view>
    </view>

    <view class="ws-card">
      <view class="card-header-row">
        <text class="card-title"><text class="iconfont icon-jilu"></text> 今日计件录入</text>
      </view>
      <view class="piece-list">
        <view class="piece-item" wx:for="{{workers}}" wx:key="id">
          <view class="piece-worker">
            <view class="text-avatar text-avatar-sm" style="background-color: #3B82F6;">{{item.displayName[0]}}</view>
            <view class="piece-info">
              <text class="piece-name">{{item.displayName}}</text>
              <text class="piece-sub">今日 {{item.todayPieces}}件 · 累计 {{item.totalPieces}}件</text>
            </view>
          </view>
          <input class="piece-input" type="number" placeholder="录入件数" data-id="{{item.id}}" disabled="{{!canFinishWork}}" bindinput="onPieceInput" value="{{item.inputValue}}" />
        </view>
      </view>
      <button class="piece-submit-btn" loading="{{savingRecords}}" disabled="{{savingRecords || !canFinishWork}}" bindtap="onSubmitPieces">{{hasDraftChanges ? '保存计件' : '暂存计件'}}</button>
      <text class="ws-save-hint" wx:if="{{hasDraftChanges}}">已修改数据，请先保存记录</text>
    </view>
  </block>

  <view class="ws-bottom">
    <button class="btn btn-rose ws-finish-btn {{!canFinishWork ? 'ws-finish-btn-disabled' : ''}}" loading="{{submittingFinish}}" disabled="{{submittingFinish || !canFinishWork}}" bindtap="onFinishWork">{{finishButtonText}}</button>
    <text class="ws-hint">{{canFinishWork ? '确认收工会提交考勤并进入结算，请先检查记录。' : '当前订单已提交收工，后续请在结算页面继续处理。'}}</text>
  </view>
</view>

<view class="ws-page">
  <nav-bar title="工作记录" />

  <block wx:if="{{mode === 'hourly'}}">
    <view class="status-card">
      <view class="sc-top">
        <text class="sc-company">{{status.company}} · {{status.jobType}}</text>
        <text class="sc-badge">进行中</text>
      </view>
      <view class="sc-hours">
        <text class="sc-hours-big">{{status.hoursToday}}</text>
        <text class="sc-hours-unit">小时</text>
      </view>
      <text class="sc-sub">今日工时统计 · {{status.startTime}} 开始</text>
      <text class="sc-sub ws-rule-sub" wx:if="{{status.checkoutRuleHint}}">{{status.checkoutRuleHint}}</text>
      <view class="sc-stats">
        <view class="sc-stat">
          <text class="sc-stat-val">出勤：{{status.todayAttend}}人</text>
        </view>
        <view class="sc-stat">
          <text class="sc-stat-val">异常：{{status.todayAnomaly}}人</text>
        </view>
        <view class="sc-stat">
          <text class="sc-stat-val">已签退：{{status.checkedOutCount}}人</text>
        </view>
      </view>
    </view>

    <view class="ws-card">
      <view class="card-header-row">
        <text class="card-title"><text class="iconfont icon-jilu"></text> 工时记录</text>
        <text class="card-tip">状态、工时事实、异常说明和编辑操作分层展示，方便核对与对账</text>
      </view>
      <view class="hour-list">
        <view class="worker-card" wx:for="{{workers}}" wx:key="id">
          <view class="record-head">
            <view class="piece-worker">
              <view class="text-avatar text-avatar-sm" style="background-color: #3B82F6;">{{item.displayName[0]}}</view>
              <view class="piece-info">
                <text class="piece-name">{{item.displayName}}</text>
                <text class="piece-sub">{{item.recordSummaryText}}</text>
              </view>
            </view>
            <view class="record-badges">
              <text class="record-badge record-badge-{{item.primaryStatusClass}} {{item.isAbnormal ? 'record-badge-' + item.abnormalAccentClass : ''}}">{{item.primaryStatusText}}</text>
              <text class="record-badge record-badge-sub record-badge-{{item.recordStatusClass}}">{{item.recordStatusText}}</text>
            </view>
          </view>

          <view class="record-facts">
            <view class="record-fact">
              <text class="metric-label">签到时间</text>
              <text class="metric-value">{{item.checkInTime || '--'}}</text>
            </view>
            <view class="record-fact">
              <text class="metric-label">签退时间</text>
              <text class="metric-value">{{item.checkOutTime || '--'}}</text>
            </view>
            <view class="record-fact record-fact-strong record-fact-wide">
              <text class="metric-label">结算工时</text>
              <text class="metric-value">{{item.hoursText}}</text>
            </view>
          </view>

          <view class="record-explain" wx:if="{{item.showExplainSection}}">
            <view class="record-explain-item" wx:if="{{item.isAbnormal}}">
              <text class="record-explain-label">异常类型</text>
              <text class="record-explain-value record-explain-value-warning record-explain-value-{{item.abnormalAccentClass}}">{{item.abnormalTypeText}}</text>
            </view>
            <view class="record-explain-item" wx:if="{{item.hasNote}}">
              <text class="record-explain-label">备注说明</text>
              <text class="record-note">{{item.statusNote}}</text>
            </view>
          </view>

          <view class="record-trace">
            <text class="record-trace-text">最后修改：{{item.modifiedAtText || '--'}}</text>
            <text class="record-trace-text">{{item.statusSource === 'manual' ? '当前状态已人工调整' : '当前状态按考勤自动判断'}}</text>
          </view>

          <view class="record-actions">
            <button class="record-action-btn record-action-btn-secondary" data-id="{{item.id}}" bindtap="onToggleRemark">
              {{item.remarkExpanded ? '收起编辑' : '编辑记录'}}
            </button>
            <button
              wx:if="{{item.checkedOut}}"
              class="record-action-btn record-action-btn-plain"
              data-id="{{item.id}}"
              bindtap="onToggleEditCheckoutTime"
            >
              {{item.editingCheckoutTime ? '收起修改签退' : '修改签退'}}
            </button>
            <button
              wx:if="{{!item.checkedOut && item.checkInTime}}"
              class="record-action-btn checkout-btn {{item.checkedOut ? 'checkout-btn-done' : ''}}"
              loading="{{item.signingOut}}"
              disabled="{{item.checkoutDisabled || item.signingOut || item.checkedOut}}"
              data-id="{{item.id}}"
              bindtap="onQuickCheckout"
            >
              {{item.checkoutButtonText}}
            </button>
          </view>

          <view class="record-editor" wx:if="{{item.remarkExpanded}}">
            <view class="editor-field {{item.activeEditorField === 'status' ? 'editor-field-active' : ''}}">
              <view class="editor-field-head">
                <text class="editor-field-label">考勤状态</text>
                <text class="editor-field-helper">用于归类正常或异常</text>
              </view>
              <picker
                mode="selector"
                range="{{attendanceOptions}}"
                range-key="label"
                data-id="{{item.id}}"
                data-field="status"
                bindtap="onEditorFieldFocus"
                bindchange="onStatusChange"
              >
                <view class="picker-field {{item.activeEditorField === 'status' ? 'picker-field-active' : ''}}">{{item.attendanceStatusText}}</view>
              </picker>
            </view>
            <view class="editor-field editor-field-remark {{item.activeEditorField === 'remark' ? 'editor-field-active' : ''}}">
              <view class="editor-field-head">
                <text class="editor-field-label">备注说明</text>
                <text class="editor-field-helper">会同步到考勤汇总与结算说明</text>
              </view>
              <textarea
                class="remark-textarea {{item.activeEditorField === 'remark' ? 'remark-textarea-active' : ''}}"
                placeholder="补充原因说明，可输入多行备注"
                value="{{item.statusNote}}"
                data-id="{{item.id}}"
                data-field="remark"
                auto-height="true"
                maxlength="300"
                bindfocus="onEditorFieldFocus"
                bindinput="onRemarkInput"
                bindblur="onRemarkBlur"
              ></textarea>
              <text class="editor-field-tip">建议填写异常原因、协商结果或需要企业对账关注的信息</text>
            </view>
            <view class="editor-field {{item.activeEditorField === 'checkout' ? 'editor-field-active' : ''}}" wx:if="{{item.editingCheckoutTime}}">
              <view class="editor-field-head">
                <text class="editor-field-label">修改签退</text>
                <text class="editor-field-helper">调整后会重新计算工时</text>
              </view>
              <picker mode="time" data-id="{{item.id}}" data-field="checkout" bindtap="onEditorFieldFocus" bindchange="onManualCheckoutChange">
                <view class="picker-field {{item.activeEditorField === 'checkout' ? 'picker-field-active' : ''}}">{{item.manualCheckoutTime || '选择签退时间'}}</view>
              </picker>
            </view>
          </view>
        </view>
      </view>
    </view>
  </block>

  <block wx:if="{{mode === 'piece'}}">
    <view class="status-card status-card-piece">
      <view class="sc-top">
        <text class="sc-company">{{pieceStatus.company}} · {{pieceStatus.jobType}}</text>
        <text class="sc-badge">进行中</text>
      </view>
      <view class="sc-hours">
        <text class="sc-hours-big">{{pieceStatus.piecesToday}}</text>
        <text class="sc-hours-unit">件</text>
      </view>
      <text class="sc-sub">今日完成 · {{pieceStatus.pricePerPiece}}元/件 · 预计收入 {{pieceStatus.earningsToday}}</text>
      <view class="sc-stats">
        <view class="sc-stat">
          <text class="sc-stat-val">出勤：{{pieceStatus.todayAttend}}人</text>
        </view>
        <view class="sc-stat">
          <text class="sc-stat-val">异常：{{pieceStatus.todayAnomaly}}人</text>
        </view>
      </view>
    </view>

    <view class="ws-card">
      <view class="card-header-row">
        <text class="card-title"><text class="iconfont icon-jilu"></text> 今日计件录入</text>
      </view>
      <view class="piece-list">
        <view class="piece-item" wx:for="{{workers}}" wx:key="id">
          <view class="piece-worker">
            <view class="text-avatar text-avatar-sm" style="background-color: #3B82F6;">{{item.displayName[0]}}</view>
            <view class="piece-info">
              <text class="piece-name">{{item.displayName}}</text>
              <text class="piece-sub">今日 {{item.todayPieces}}件 · 累计 {{item.totalPieces}}件</text>
            </view>
          </view>
          <input class="piece-input" type="number" placeholder="录入件数" data-id="{{item.id}}" disabled="{{!canFinishWork}}" bindinput="onPieceInput" value="{{item.inputValue}}" />
        </view>
      </view>
      <button class="piece-submit-btn" loading="{{savingRecords}}" disabled="{{savingRecords || !canFinishWork}}" bindtap="onSubmitPieces">{{hasDraftChanges ? '保存计件' : '暂存计件'}}</button>
      <text class="ws-save-hint" wx:if="{{hasDraftChanges}}">已修改数据，请先保存记录</text>
    </view>
  </block>

  <view class="ws-bottom">
    <button wx:if="{{canFinishWork}}" class="btn btn-rose ws-finish-btn" loading="{{submittingFinish}}" disabled="{{submittingFinish}}" bindtap="onFinishWork">{{finishButtonText}}</button>
    <button wx:else class="btn btn-primary ws-finish-btn" bindtap="onGoSettlement">{{lockedActionText}}</button>
    <text class="ws-hint">{{canFinishWork ? '确认收工会提交考勤并进入结算，请先检查记录。' : '收工记录已提交，当前页已锁定，请进入结算继续处理。'}}</text>
  </view>
</view>

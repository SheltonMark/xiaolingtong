.ws-page { min-height: 100vh; background-color: #F5F5F5; padding-bottom: 40rpx; }

.status-card {
  margin: 24rpx 32rpx 0;
  border-radius: 24rpx;
  padding: 32rpx;
  background: linear-gradient(to right, #3B82F6, #60A5FA);
  color: #fff;
}

.status-card-piece {
  background: linear-gradient(to right, #F97316, #FB923C);
}

.sc-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16rpx; }
.sc-company { font-size: 24rpx; opacity: 0.82; }
.sc-badge {
  font-size: 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 9999rpx;
}
.sc-hours { display: flex; align-items: baseline; gap: 8rpx; margin-bottom: 8rpx; }
.sc-hours-big { font-size: 60rpx; font-weight: 700; }
.sc-hours-unit { font-size: 28rpx; opacity: 0.8; }
.sc-sub { font-size: 20rpx; opacity: 0.76; display: block; margin-bottom: 24rpx; }
.ws-rule-sub { margin-top: -8rpx; opacity: 0.92; }
.sc-stats {
  display: flex;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  justify-content: space-between;
}
.sc-stat-val { font-size: 20rpx; }

.ws-card {
  background-color: #fff;
  margin: 24rpx 32rpx 0;
  border-radius: 24rpx;
  padding: 32rpx;
}

.card-header-row { margin-bottom: 20rpx; }
.card-title { font-size: 28rpx; font-weight: 600; color: #1E293B; }
.card-title .iconfont { margin-right: 8rpx; }
.card-tip { display: block; margin-top: 8rpx; font-size: 20rpx; color: #94A3B8; }

.piece-list,
.hour-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.piece-item,
.worker-card {
  background-color: #F8FAFC;
  border-radius: 18rpx;
}

.piece-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 20rpx;
}

.worker-card {
  padding: 26rpx 24rpx;
  border: 2rpx solid #E2E8F0;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.04);
}

.record-head {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 16rpx;
}

.piece-worker { display: flex; align-items: center; gap: 16rpx; flex: 1; min-width: 0; }
.piece-info { display: flex; flex-direction: column; gap: 4rpx; min-width: 0; }
.piece-name { font-size: 26rpx; font-weight: 600; color: #1E293B; }
.piece-sub { font-size: 20rpx; color: #64748B; line-height: 1.5; }

.record-badges {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-start;
  gap: 8rpx;
  max-width: none;
}

.record-badge {
  font-size: 20rpx;
  padding: 8rpx 18rpx;
  border-radius: 9999rpx;
  line-height: 1.4;
}

.record-badge-normal {
  background: #DCFCE7;
  color: #15803D;
}

.record-badge-abnormal {
  background: #FFE4E6;
  color: #BE123C;
}

.record-badge-late {
  background: #FEF3C7;
  color: #B45309;
}

.record-badge-early_leave {
  background: #FED7AA;
  color: #C2410C;
}

.record-badge-absent {
  background: #FECDD3;
  color: #BE123C;
}

.record-badge-injury {
  background: #FDE68A;
  color: #92400E;
}

.record-badge-fraud {
  background: #FBCFE8;
  color: #9D174D;
}

.record-badge-sub {
  background: #E2E8F0;
  color: #475569;
}

.record-badge-done {
  background: #DBEAFE;
  color: #1D4ED8;
}

.record-badge-pending {
  background: #FEF3C7;
  color: #B45309;
}

.record-badge-muted {
  background: #E2E8F0;
  color: #64748B;
}

.checkout-btn {
  min-width: 198rpx;
  height: 76rpx;
  border-radius: 18rpx;
  border: none;
  background: linear-gradient(135deg, #2563EB 0%, #3B82F6 100%);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 24rpx;
  line-height: 76rpx;
}
.checkout-btn::after { border: none; }
.checkout-btn-done {
  background: #CBD5E1;
  color: #FFFFFF;
}

.record-facts {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}

.record-fact {
  width: calc((100% - 14rpx) / 2);
  box-sizing: border-box;
  min-height: 116rpx;
  padding: 18rpx 18rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid #E2E8F0;
}

.record-fact-wide {
  width: 100%;
}

.record-fact-strong {
  background: #EFF6FF;
  border-color: #BFDBFE;
}

.metric-label {
  display: block;
  font-size: 18rpx;
  color: #94A3B8;
  margin-bottom: 6rpx;
}

.metric-value {
  display: block;
  font-size: 24rpx;
  color: #1E293B;
  font-weight: 600;
}

.record-explain {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #E2E8F0;
}

.record-explain-item + .record-explain-item {
  margin-top: 16rpx;
}

.record-explain-label {
  display: block;
  font-size: 20rpx;
  color: #94A3B8;
  margin-bottom: 8rpx;
}

.record-explain-value {
  font-size: 24rpx;
  color: #1E293B;
  line-height: 1.6;
}

.record-explain-value-warning {
  color: #B45309;
  font-weight: 600;
}

.record-explain-value-late {
  color: #B45309;
}

.record-explain-value-early_leave {
  color: #C2410C;
}

.record-explain-value-absent {
  color: #BE123C;
}

.record-explain-value-injury {
  color: #92400E;
}

.record-explain-value-fraud {
  color: #9D174D;
}

.record-note {
  display: block;
  padding: 16rpx;
  border-radius: 14rpx;
  background: #F8FAFC;
  color: #334155;
  font-size: 22rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.record-trace {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx 20rpx;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 2rpx dashed #E2E8F0;
}

.record-trace-text {
  font-size: 20rpx;
  color: #94A3B8;
  line-height: 1.6;
}

.record-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.record-action-btn {
  flex: 1;
  min-width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  padding: 0 20rpx;
}

.record-action-btn::after {
  border: none;
}

.record-action-btn-secondary {
  background: #E0F2FE;
  color: #0369A1;
}

.record-action-btn-plain {
  background: #FFFFFF;
  color: #2563EB;
  border: 2rpx solid #BFDBFE;
}

.record-editor {
  margin-top: 18rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F8FBFF 100%);
  border: 2rpx solid #DBEAFE;
}

.editor-field {
  padding: 18rpx 18rpx 20rpx;
  border-radius: 16rpx;
  background: #FFFFFF;
  border: 2rpx solid #E5EEF9;
}

.editor-field-active {
  border-color: #93C5FD;
  box-shadow: 0 0 0 6rpx rgba(191, 219, 254, 0.35);
}

.editor-field-remark {
  background: #F8FBFF;
}

.editor-field + .editor-field {
  margin-top: 20rpx;
}

.editor-field-head {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6rpx;
  margin-bottom: 12rpx;
}

.editor-field-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E293B;
}

.editor-field-helper {
  font-size: 20rpx;
  color: #94A3B8;
  line-height: 1.5;
  text-align: left;
}

.editor-field-tip {
  display: block;
  margin-top: 10rpx;
  font-size: 20rpx;
  color: #94A3B8;
  line-height: 1.6;
}

.picker-field,
.piece-input {
  flex: 1;
  height: 64rpx;
  border-radius: 14rpx;
  border: 2rpx solid #E2E8F0;
  background-color: #fff;
  font-size: 24rpx;
  color: #1E293B;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-field-active {
  border-color: #60A5FA;
  background-color: #EFF6FF;
  box-shadow: 0 8rpx 18rpx rgba(59, 130, 246, 0.10);
}

.remark-textarea {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  border-radius: 14rpx;
  border: 2rpx solid #E2E8F0;
  background-color: #fff;
  font-size: 24rpx;
  color: #1E293B;
  padding: 18rpx 20rpx;
  line-height: 1.7;
  white-space: pre-wrap;
  box-sizing: border-box;
}

.remark-textarea-active {
  border-color: #60A5FA;
  background-color: #FFFFFF;
  box-shadow: 0 10rpx 20rpx rgba(59, 130, 246, 0.10);
}

.piece-input {
  width: 120rpx;
  flex: none;
  text-align: center;
}

.piece-submit-btn {
  width: 100%;
  font-size: 24rpx;
  color: #fff;
  background-color: #F97316;
  padding: 16rpx 0;
  border-radius: 12rpx;
  border: none;
  margin-top: 24rpx;
  font-weight: 500;
}
.piece-submit-btn::after { border: none; }

.ws-save-hint {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #F97316;
  margin-top: 12rpx;
}

.ws-bottom {
  margin: 24rpx 32rpx;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

.ws-finish-btn { width: 100%; }
.ws-finish-btn-disabled {
  background-color: #CBD5E1 !important;
  color: #FFFFFF !important;
  box-shadow: none;
}
.ws-finish-btn-disabled::after { border: none; }
.ws-hint {
  display: block;
  text-align: center;
  font-size: 20rpx;
  color: #94A3B8;
  margin-top: 12rpx;
  line-height: 1.6;
}

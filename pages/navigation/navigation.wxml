<view class="nav-page">
  <!-- 地图区域 - 占大部分屏幕 -->
  <map
    wx:if="{{targetLocation}}"
    class="map-view"
    latitude="{{userLocation ? (targetLocation.latitude + userLocation.latitude) / 2 : targetLocation.latitude}}"
    longitude="{{userLocation ? (targetLocation.longitude + userLocation.longitude) / 2 : targetLocation.longitude}}"
    scale="13"
    markers="{{markers}}"
    polyline="{{polyline}}"
    show-location
  />
  <view wx:else class="map-placeholder">
    <text class="iconfont icon-address" style="font-size:64rpx;color:#94A3B8;"></text>
    <text style="font-size:26rpx;color:#94A3B8;margin-top:16rpx;">正在加载地图...</text>
  </view>

  <!-- 底部信息面板 -->
  <view class="bottom-sheet">
    <view class="sheet-handle"></view>
    <view class="route-info">
      <!-- 起点 -->
      <view class="route-item">
        <view class="route-dot dot-green"></view>
        <view class="route-content">
          <text class="route-label">我的位置</text>
          <text class="route-sub" wx:if="{{userLocation}}">{{userLocation.latitude.toFixed(4)}}, {{userLocation.longitude.toFixed(4)}}</text>
          <text class="route-sub" wx:elif="{{locationUnavailable}}">未获取当前位置，不影响目标导航</text>
          <text class="route-sub" wx:else>定位中...</text>
        </view>
      </view>
      <!-- 连接线 -->
      <view class="route-line"></view>
      <!-- 终点 -->
      <view class="route-item">
        <view class="route-dot dot-orange"></view>
        <view class="route-content">
          <text class="route-name">{{targetName}}</text>
          <text class="route-sub" wx:if="{{targetAddress}}">{{targetAddress}}</text>
        </view>
      </view>
    </view>
    <!-- 导航按钮 -->
    <button class="nav-btn" bindtap="onNavigate">
      <text class="iconfont icon-daohang"></text>
      <text>开始导航</text>
    </button>
  </view>
</view>

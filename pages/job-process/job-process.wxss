.st-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.12), transparent 30%),
    linear-gradient(180deg, #F7F9FC 0%, #F4F7FB 100%);
  padding-bottom: 40rpx;
}

.st-tabs {
  display: flex;
  gap: 12rpx;
  margin: 20rpx 24rpx 0;
  padding: 10rpx;
  border-radius: 28rpx;
  background-color: rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.04);
}

.st-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 20rpx;
  color: #64748B;
  font-size: 24rpx;
}

.st-tab-active {
  background: linear-gradient(135deg, #2563EB 0%, #3B82F6 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.18);
}

.st-hero {
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #FFFFFF 0%, #EEF4FF 100%);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.06);
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.st-hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #0F172A;
}

.st-hero-sub {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748B;
  line-height: 1.6;
}

.st-hero-pill {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background-color: #EFF6FF;
  color: #2563EB;
  font-size: 22rpx;
  font-weight: 600;
}

.st-card {
  margin: 20rpx 24rpx 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background-color: rgba(255, 255, 255, 0.94);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.st-money-card {
  background: linear-gradient(135deg, #FFFFFF 0%, #FFF8ED 100%);
}

.card-title {
  display: block;
  margin-bottom: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.st-summary {
  display: flex;
  gap: 12rpx;
}

.st-sum-item {
  flex: 1;
  background-color: #F8FAFC;
  border-radius: 20rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.st-sum-val {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
}

.st-sum-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #64748B;
}

.st-note-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.st-note {
  font-size: 22rpx;
  color: #64748B;
}

.st-filter-row {
  margin-top: 20rpx;
  white-space: nowrap;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.st-filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  padding: 12rpx 22rpx;
  border-radius: 999rpx;
  background-color: rgba(255, 255, 255, 0.9);
  color: #64748B;
  font-size: 22rpx;
  box-shadow: inset 0 0 0 1rpx #E2E8F0;
}

.st-filter-chip-active {
  background-color: #0F172A;
  color: #FFFFFF;
}

.st-applicant-card {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #EEF2F7;
}

.st-applicant-card:last-child,
.table-row:last-child,
.st-worker-card:last-child {
  border-bottom: none;
}

.st-applicant-main {
  display: flex;
  gap: 18rpx;
}

.st-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background-color: #2563EB;
  color: #FFFFFF;
  font-size: 28rpx;
}

.st-avatar-img {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background-color: #E2E8F0;
}

.st-applicant-info {
  flex: 1;
}

.st-applicant-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.st-applicant-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #0F172A;
}

.st-status-pill,
.st-supervisor-pill {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.st-status-rose { background-color: #FFF1F2; color: #E11D48; }
.st-status-blue { background-color: #EFF6FF; color: #2563EB; }
.st-status-violet { background-color: #F5F3FF; color: #7C3AED; }
.st-status-green { background-color: #ECFDF5; color: #16A34A; }
.st-status-slate { background-color: #F1F5F9; color: #475569; }
.st-status-amber { background-color: #FFFBEB; color: #D97706; }

.st-supervisor-pill {
  background-color: #FEF3C7;
  color: #B45309;
}

.st-applicant-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748B;
}

.st-applicant-actions {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
}

.st-mini-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 140rpx;
  height: 64rpx;
  line-height: 1.2;
  margin: 0;
  padding: 0 26rpx;
  box-sizing: border-box;
  border-radius: 18rpx;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  white-space: nowrap;
  border: none;
}

.st-mini-btn::after,
.btn-outline::after {
  border: none;
}

.st-mini-primary {
  background-color: #2563EB;
  color: #FFFFFF;
}

.st-mini-ghost {
  background-color: #FFF1F2;
  color: #E11D48;
}

.st-mini-warm {
  background-color: #FFFBEB;
  color: #D97706;
}

.table-header {
  display: flex;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.table-row {
  display: flex;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.th {
  font-size: 20rpx;
  color: #94A3B8;
  font-weight: 500;
}

.td {
  font-size: 22rpx;
  color: #1E293B;
}

.att-supervisor {
  font-size: 26rpx;
  color: #0F172A;
}

.att-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #64748B;
}

.att-photo-link {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #2563EB;
}

.st-money-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.st-money-label {
  display: block;
  font-size: 22rpx;
  color: #64748B;
}

.st-money-value {
  display: block;
  margin-top: 10rpx;
  font-size: 56rpx;
  font-weight: 700;
  color: #EA580C;
}

.st-money-pill {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background-color: #FFFBEB;
  color: #D97706;
  font-size: 22rpx;
  font-weight: 600;
}

.st-money-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
}

.st-money-item {
  flex: 1;
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background-color: rgba(255, 255, 255, 0.9);
}

.st-money-item-val {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
}

.st-money-item-label {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #64748B;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  flex-shrink: 0;
}

.dot-done {
  background-color: #ECFDF5;
  color: #16A34A;
}

.dot-pending {
  background-color: #FFFBEB;
  color: #D97706;
}

.step-content {
  display: flex;
  flex-direction: column;
}

.step-label {
  font-size: 24rpx;
  color: #0F172A;
}

.step-time {
  font-size: 20rpx;
  color: #94A3B8;
}

.st-worker-card {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEF2F7;
}

.st-worker-main {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.st-worker-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #0F172A;
}

.st-worker-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748B;
}

.st-worker-side {
  text-align: right;
}

.st-worker-pay {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #EA580C;
}

.st-worker-status {
  display: block;
  margin-top: 8rpx;
  font-size: 20rpx;
}

.fee-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.fee-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.fee-label {
  font-size: 24rpx;
  color: #64748B;
}

.fee-value {
  font-size: 24rpx;
  color: #0F172A;
}

.fee-minus {
  color: #64748B;
}

.fee-divider {
  height: 1rpx;
  background-color: #E2E8F0;
  margin: 8rpx 0;
}

.fee-total .fee-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #0F172A;
}

.fee-total .fee-value {
  font-size: 32rpx;
  font-weight: 700;
}

.st-bottom {
  margin: 24rpx 32rpx;
  padding: 24rpx 0 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.st-hint {
  display: block;
  margin-top: 12rpx;
  text-align: center;
  font-size: 20rpx;
  color: #94A3B8;
}

.att-btn-group {
  display: flex;
  gap: 20rpx;
}

.att-btn-group .btn {
  flex: 1;
}

.btn-outline {
  background-color: #FFFFFF;
  color: #64748B;
  border: 2rpx solid #E2E8F0;
}

.view-all {
  display: block;
  margin-top: 20rpx;
  text-align: center;
  font-size: 24rpx;
  color: #2563EB;
}

.st-empty-card {
  text-align: center;
}

.st-empty-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0F172A;
}

.st-empty-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #64748B;
}

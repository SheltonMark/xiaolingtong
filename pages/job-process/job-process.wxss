.st-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.12), transparent 30%),
    linear-gradient(180deg, #F7F9FC 0%, #F4F7FB 100%);
  padding-bottom: 40rpx;
}

.st-tabs {
  display: flex;
  gap: 12rpx;
  margin: 20rpx 24rpx 0;
  padding: 10rpx;
  border-radius: 28rpx;
  background-color: rgba(255, 255, 255, 0.88);
  box-shadow: 0 12rpx 28rpx rgba(15, 23, 42, 0.04);
}

.st-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 20rpx;
  color: #64748B;
  font-size: 24rpx;
}

.st-tab-active {
  background: linear-gradient(135deg, #2563EB 0%, #3B82F6 100%);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 10rpx 20rpx rgba(37, 99, 235, 0.18);
}

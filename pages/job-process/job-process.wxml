<view class="st-page">
  <nav-bar title="{{pageTitle}}" />

  <view class="st-tabs" wx:if="{{workflowTabs.length > 0}}">
    <view
      wx:for="{{workflowTabs}}"
      wx:key="key"
      class="st-tab {{activeTab === item.key ? 'st-tab-active' : ''}}"
      data-tab="{{item.key}}"
      bindtap="onTabChange"
    >
      <text>{{item.label}}</text>
    </view>
  </view>

  <workflow-header
    title="{{headerTitle}}"
    subtitle="{{headerSubtitle}}"
    roleLabel="{{headerRoleLabel}}"
    statusLabel="{{headerStatusLabel}}"
    statusTone="{{headerStatusTone}}"
    hint="{{headerHint}}"
  />

  <applications-panel
    wx:if="{{activeTab === 'applications' && role === 'enterprise'}}"
    manageJob="{{manageJob}}"
    manageSummary="{{manageSummary}}"
    applicantTabs="{{applicantTabs}}"
    applicantFilter="{{applicantFilter}}"
    filteredApplicants="{{filteredApplicants}}"
    bind:filterchange="onApplicantFilterChange"
    bind:accept="onAcceptApplicant"
    bind:reject="onRejectApplicant"
    bind:setsupervisor="onSetSupervisor"
  />

  <attendance-panel
    wx:if="{{activeTab === 'attendance'}}"
    attendance="{{attendance}}"
    role="{{role}}"
    viewOnly="{{viewOnly}}"
    bind:confirm="onConfirmAttendance"
    bind:dispute="onDisputeAttendance"
    bind:previewphotos="onPreviewAttendancePhotos"
  />

  <settlement-panel
    wx:if="{{activeTab === 'settlement'}}"
    settlementReady="{{settlementReady}}"
    job="{{job}}"
    steps="{{steps}}"
    workers="{{workers}}"
    fees="{{fees}}"
    role="{{role}}"
    viewOnly="{{viewOnly}}"
    currentWorkerSettlement="{{currentWorkerSettlement}}"
    bind:pay="onPay"
    bind:confirmsettlement="onConfirmSettlement"
    bind:rate="onRateEnterprise"
    bind:viewall="onViewAll"
  />
</view>

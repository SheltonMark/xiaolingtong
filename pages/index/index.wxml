<!--pages/index/index.wxml-->
<view class="index-page">
  <!-- 固定顶部区域（整体一块，无缝隙） -->
  <view class="fixed-header" style="padding-top: {{statusBarHeight}}px;">
    <!-- 标题行（与胶囊同行） -->
    <view class="nav-bar-inner" style="height: {{menuHeight}}px;">
      <text class="nav-title">{{userRole === 'enterprise' ? '首页' : '临时工'}}</text>
    </view>
    <!-- 搜索行 -->
    <view class="top-bar-inner">
      <picker mode="selector" range="{{cityNames}}" value="{{cityIndex}}" bindchange="onCityChange">
        <view class="city-selector">
          <text class="city-icon iconfont icon-address {{userRole === 'enterprise' ? 'text-cta' : 'text-primary'}}"></text>
          <text class="city-name">{{currentCity}}</text>
        </view>
      </picker>
      <view class="search-bar">
        <text class="search-icon iconfont icon-sousuo"></text>
        <input class="search-input"
               placeholder="{{userRole === 'enterprise' ? '搜索产品/工艺/工厂' : '搜索工种/地区'}}"
               placeholder-class="search-placeholder"
               value="{{searchKeyword}}"
               bindinput="onSearchInput"
               bindconfirm="onSearchConfirm"
               confirm-type="search" />
      </view>
      <view class="notify-btn" bindtap="onNotification">
        <text class="notify-icon iconfont icon-tongzhi"></text>
        <view class="notify-badge" wx:if="{{unreadCount > 0}}">{{unreadCount > 99 ? '99+' : unreadCount}}</view>
      </view>
    </view>
    <!-- 企业端 Tab -->
    <view class="tab-bar-ent" wx:if="{{userRole === 'enterprise'}}">
      <view class="tab-item {{currentTab === index ? 'tab-active' : ''}}"
            wx:for="{{tabs}}" wx:key="index"
            data-index="{{index}}" bindtap="onTabChange">
        <text class="tab-text">{{item}}</text>
        <view class="tab-line" wx:if="{{currentTab === index}}"></view>
      </view>
    </view>
    <!-- 临工端筛选 -->
    <view class="filter-bar" wx:if="{{userRole === 'worker'}}">
      <picker mode="selector" range="{{jobTypeOptions}}" value="{{jobTypeIndex}}" bindchange="onJobTypeChange">
        <view class="filter-item">
          <text class="filter-text">{{filterJobType || '工种'}}</text>
          <view class="filter-arrow-triangle"></view>
        </view>
      </picker>
      <picker mode="selector" range="{{salaryTypeOptions}}" value="{{salaryTypeIndex}}" bindchange="onSalaryTypeChange">
        <view class="filter-item">
          <text class="filter-text">{{filterSalaryType || '计费方式'}}</text>
          <view class="filter-arrow-triangle"></view>
        </view>
      </picker>
      <picker mode="selector" range="{{distanceOptions}}" value="{{distanceIndex}}" bindchange="onDistanceChange">
        <view class="filter-item">
          <text class="filter-text">{{filterDistance || '距离'}}</text>
          <view class="filter-arrow-triangle"></view>
        </view>
      </picker>
      <picker mode="selector" range="{{salaryOptions}}" value="{{salaryIndex}}" bindchange="onSalaryChange">
        <view class="filter-item">
          <text class="filter-text">{{filterSalaryRange || '工价'}}</text>
          <view class="filter-arrow-triangle"></view>
        </view>
      </picker>
    </view>
  </view>

  <view class="content-spacer" style="height: {{headerHeight ? headerHeight + 'px' : (navBarHeight + (userRole === 'enterprise' ? 140 : 110)) + 'px'}};"></view>

  <!-- ===== 企业端内容 ===== -->
  <view wx:if="{{userRole === 'enterprise'}}">
    <!-- 广告 Banner 轮播 -->
    <view class="banner-wrap">
      <swiper class="banner-swiper" autoplay circular indicator-dots
              indicator-color="rgba(255,255,255,0.4)" indicator-active-color="#ffffff">
        <swiper-item wx:for="{{banners}}" wx:key="id">
          <!-- 广告图片模式 -->
          <view class="banner-slide banner-slide-ad" wx:if="{{item.kind === 'ad'}}" style="position:relative;" bindtap="onAdBannerTap" data-link="{{item.link}}" data-link-type="{{item.linkType}}">
            <image src="{{item.imageUrl}}" class="banner-img banner-img-ad" mode="aspectFill" />
            <text class="ad-tag">广告</text>
          </view>
          <!-- 公告图片模式 -->
          <view class="banner-slide banner-slide-ad" wx:elif="{{item.kind === 'notice-img'}}" style="position:relative;">
            <image src="{{item.imageUrl}}" class="banner-img banner-img-ad" mode="aspectFill" />
            <text class="ad-tag" style="background:rgba(37,99,235,0.7);">公告</text>
          </view>
          <!-- 公告文字模式 -->
          <view class="banner-slide banner-slide-notice" wx:elif="{{item.kind === 'notice'}}">
            <view class="banner-notice-card">
              <view class="banner-notice-top">
                <text class="banner-notice-badge">公告</text>
                <text class="banner-notice-time">{{item.time}}</text>
              </view>
              <text class="banner-notice-title">{{item.title}}</text>
              <text class="banner-notice-sub">{{item.sub}}</text>
            </view>
          </view>
          <view class="banner-slide banner-slide-default" wx:else style="background: {{item.bg}};">
            <view class="banner-content">
              <text class="banner-title">{{item.title}}</text>
              <text class="banner-sub">{{item.sub}}</text>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- Tab 0: 采购需求 -->
    <view wx:if="{{currentTab === 0}}">
      <view class="cate-grid-wrap">
        <view class="cate-grid">
          <view class="cate-item" wx:for="{{catePurchase}}" wx:key="label" data-label="{{item.label}}" bindtap="onCategoryTap">
            <view class="cate-icon {{item.active ? 'cate-icon-active' : ''}}" style="background-color: {{item.active ? '#3B82F6' : item.bg}};">
              <text class="cate-icon-text {{item.active ? 'cate-icon-text-white' : ''}}" style="{{item.active ? '' : 'color:' + (item.iconColor || '#64748B')}}">{{item.icon}}</text>
            </view>
            <text class="cate-label {{item.active ? 'cate-label-active' : ''}}">{{item.label}}</text>
          </view>
        </view>
      </view>
      <view class="list-wrap">
        <view class="section-header">
          <text class="section-title">最新采购需求</text>
        </view>
        <info-card wx:for="{{purchaseList}}" wx:key="id"
                   item="{{item}}"
                   bind:tap="onCardTap"
                   bind:wechat="onWechat"
                   bind:phone="onPhone"
                   bind:chat="onChat"
                   bind:share="onShare"
                   bind:report="onReport" />
        <empty-state wx:if="{{purchaseList.length === 0}}" text="暂无采购需求" />
      </view>
    </view>

    <!-- Tab 1: 工厂库存 -->
    <view wx:if="{{currentTab === 1}}">
      <view class="cate-grid-wrap">
        <view class="cate-grid">
          <view class="cate-item" wx:for="{{cateStock}}" wx:key="label" data-label="{{item.label}}" bindtap="onCategoryTap">
            <view class="cate-icon {{item.active ? 'cate-icon-active' : ''}}" style="background-color: {{item.active ? '#3B82F6' : item.bg}};">
              <text class="cate-icon-text {{item.active ? 'cate-icon-text-white' : ''}}" style="{{item.active ? '' : 'color:' + (item.iconColor || '#64748B')}}">{{item.icon}}</text>
            </view>
            <text class="cate-label {{item.active ? 'cate-label-active' : ''}}">{{item.label}}</text>
          </view>
        </view>
      </view>
      <view class="list-wrap">
        <view class="section-header">
          <text class="section-title">最新工厂库存</text>
        </view>
        <info-card wx:for="{{stockList}}" wx:key="id"
                   item="{{item}}"
                   show-distance="{{true}}"
                   bind:tap="onCardTap"
                   bind:wechat="onWechat"
                   bind:phone="onPhone"
                   bind:chat="onChat"
                   bind:share="onShare"
                   bind:report="onReport" />
        <empty-state wx:if="{{stockList.length === 0}}" text="暂无库存信息" />
      </view>
    </view>

    <!-- Tab 2: 代加工 -->
    <view wx:if="{{currentTab === 2}}">
      <view class="pf-bar">
        <view class="pf-mode-row">
          <picker mode="selector" range="{{processModeFilterOptions}}" bindchange="onProcessModeFilterPicker">
            <view class="pf-pill pf-pill-filter {{processFilterMode ? 'pf-pill-on' : ''}}">
              <text>{{processFilterModeLabel || '类型'}}</text>
              <text class="pf-arrow">▾</text>
            </view>
          </picker>
          <picker mode="selector" range="{{['不限'].concat(processCategoryOptions)}}" bindchange="onProcessCategoryFilter">
            <view class="pf-pill pf-pill-filter {{processFilterCategory ? 'pf-pill-on' : ''}}">
              <text>{{processFilterCategory || '品类'}}</text>
              <text class="pf-arrow">▾</text>
            </view>
          </picker>
          <picker mode="selector" range="{{processDistanceOptions}}" bindchange="onProcessDistanceFilter">
            <view class="pf-pill pf-pill-filter {{processFilterDistance ? 'pf-pill-on' : ''}}">
              <text>{{processFilterDistance || '距离'}}</text>
              <text class="pf-arrow">▾</text>
            </view>
          </picker>
        </view>
      </view>
      <view class="list-wrap">
        <view class="section-header">
          <text class="section-title">最新代加工</text>
        </view>
        <info-card wx:for="{{processList}}" wx:key="id"
                   item="{{item}}"
                   show-distance="{{true}}"
                   bind:tap="onCardTap"
                   bind:wechat="onWechat"
                   bind:phone="onPhone"
                   bind:chat="onChat"
                   bind:share="onShare"
                   bind:report="onReport" />
        <empty-state wx:if="{{!processList || processList.length === 0}}" text="暂无代加工信息" />
      </view>
    </view>

    <!-- Tab 3: 招工 -->
    <view wx:if="{{currentTab === 3}}">
      <!-- 招工管理快捷入口 -->
      <view class="job-quick-actions">
        <view class="job-quick-btn" bindtap="onJobManage">
          <view class="job-quick-icon" style="background-color:#FFF7ED;">
            <text class="job-quick-icon-text" style="color:#D97706;">&#xe61c;</text>
          </view>
          <text class="job-quick-label">招工管理</text>
        </view>
        <view class="job-quick-btn" bindtap="onSettlement">
          <view class="job-quick-icon" style="background-color:#FFFBEB;">
            <text class="job-quick-icon-text" style="color:#F59E0B;">&#xe611;</text>
          </view>
          <text class="job-quick-label">工资结算</text>
        </view>
        <view class="job-quick-btn" bindtap="onPublishJob">
          <view class="job-quick-icon" style="background-color:#FFF1F2;">
            <text class="job-quick-icon-text" style="color:#F43F5E;">&#xe619;</text>
          </view>
          <text class="job-quick-label">发布招工</text>
        </view>
      </view>

      <!-- 切换视图：我的招工 / 所有招工 -->
      <view class="job-view-toggle">
        <view class="job-view-btn {{jobViewMode === 'mine' ? 'job-view-btn-active' : ''}}" bindtap="onToggleJobView" wx:if="{{jobViewMode !== 'mine'}}">
          <text>我的招工</text>
        </view>
        <view class="job-view-btn {{jobViewMode === 'all' ? 'job-view-btn-active' : ''}}" bindtap="onToggleJobView" wx:if="{{jobViewMode !== 'all'}}">
          <text>查看所有招工</text>
        </view>
      </view>

      <view class="cate-grid-wrap">
        <view class="cate-grid">
          <view class="cate-item" wx:for="{{cateJob}}" wx:key="label" data-label="{{item.label}}" bindtap="onCategoryTap">
            <view class="cate-icon {{item.active ? 'cate-icon-active' : ''}}" style="background-color: {{item.active ? '#3B82F6' : item.bg}};">
              <text class="cate-icon-text {{item.active ? 'cate-icon-text-white' : ''}}" style="{{item.active ? '' : 'color:' + (item.iconColor || '#64748B')}}">{{item.icon}}</text>
            </view>
            <text class="cate-label {{item.active ? 'cate-label-active' : ''}}">{{item.label}}</text>
          </view>
        </view>
      </view>
      <view class="list-wrap">
        <view class="section-header">
          <text class="section-title">{{jobViewMode === 'mine' ? '我的招工' : '所有招工信息'}}</text>
        </view>
        <view class="job-card" wx:for="{{jobListEnterprise}}" wx:key="id"
              data-id="{{item.id}}" bindtap="onJobTap">
          <view class="job-header">
            <view class="job-header-left">
              <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="job-avatar-img" mode="aspectFill" />
              <view wx:else class="text-avatar text-avatar-lg" style="background-color:#10B981;">{{item.companyName[0]}}</view>
              <view class="job-company-info">
                <text class="job-company">{{item.companyName}}</text>
                <text class="job-meta">{{item.cityDistrict}} · {{item.publishDate}}</text>
              </view>
            </view>
            <view class="job-pay">
              <text class="job-salary-big">{{item.salary}}</text>
              <text class="job-salary-unit">{{item.salaryUnit}}</text>
            </view>
          </view>
          <view class="job-title-row">
            <text class="job-title-text">{{item.jobCardTitle}}</text>
            <text wx:if="{{item.urgent}}" class="urgent-tag">急招</text>
          </view>
          <view class="job-tags" wx:if="{{item.allTags && item.allTags.length > 0}}">
            <text class="job-tag" wx:for="{{item.allTags}}" wx:for-item="tag" wx:for-index="tagIndex" wx:key="tagIndex" style="background:{{tag.bg}};color:{{tag.color}};">{{tag.label}}</text>
          </view>
          <text class="job-desc">{{item.desc}}</text>
          <view class="job-progress">
            <view class="progress-text-row">
              <text class="progress-text-simple">已报名 <text class="progress-count">{{item.applied}}</text>/{{item.need}}人</text>
              <text class="progress-remain" wx:if="{{item.need - item.applied > 0}}">剩余<text class="progress-remain-num">{{item.need - item.applied}}</text>个名额</text>
            </view>
            <view class="progress-bar">
              <view class="progress-fill" style="width: {{item.applied / item.need * 100}}%;"></view>
            </view>
          </view>
        </view>
        <empty-state wx:if="{{!jobListEnterprise || jobListEnterprise.length === 0}}" text="{{jobViewMode === 'mine' ? '您还没有发布招工信息' : '暂无招工信息'}}" subText="{{jobViewMode === 'mine' ? '点击下方按钮发布第一条招工' : ''}}" />
      </view>
      <!-- 悬浮发布招工按钮 -->
      <view class="fab-publish" bindtap="onPublishJob">
        <text class="fab-publish-icon">+</text>
        <text class="fab-publish-text">发布</text>
      </view>
    </view>

    <!-- Tab 4: 工厂名录 -->
    <view wx:if="{{currentTab === 4}}">
      <view class="cate-grid-wrap">
        <view class="cate-grid">
          <view class="cate-item" wx:for="{{cateFactory}}" wx:key="label" data-label="{{item.label}}" bindtap="onCategoryTap">
            <view class="cate-icon {{item.active ? 'cate-icon-active' : ''}}" style="background-color: {{item.active ? '#3B82F6' : item.bg}};">
              <text class="cate-icon-text {{item.active ? 'cate-icon-text-white' : ''}}" style="{{item.active ? '' : 'color:' + (item.iconColor || '#64748B')}}">{{item.icon}}</text>
            </view>
            <text class="cate-label {{item.active ? 'cate-label-active' : ''}}">{{item.label}}</text>
          </view>
        </view>
      </view>
      <view class="list-wrap">
        <view class="section-header">
          <text class="section-title">工厂名录</text>
        </view>
        <view class="factory-card" wx:for="{{factoryList}}" wx:key="id">
          <view class="factory-top">
            <image wx:if="{{item.image}}" src="{{item.image}}" class="factory-logo-img" mode="aspectFill" />
            <view wx:else class="factory-logo iconfont icon-gongchang"></view>
            <view class="factory-info">
              <text class="factory-name">{{item.name}}</text>
              <text class="factory-sub">{{item.type}} · {{item.location}}</text>
            </view>
          </view>
          <view class="factory-tags">
            <text class="factory-tag tag-blue">已认证</text>
            <text class="factory-tag" style="background-color:{{item.scaleBg}};color:{{item.scaleColor}};">{{item.scale}}</text>
            <text class="factory-years">入驻{{item.years}}年</text>
          </view>
        </view>
        <empty-state wx:if="{{!factoryList || factoryList.length === 0}}" text="暂无工厂" />
      </view>
    </view>
  </view>

  <!-- ===== 临工端内容 ===== -->
  <view wx:if="{{userRole === 'worker'}}" class="worker-list-wrap">
    <view class="job-card" wx:for="{{jobList}}" wx:key="id"
          data-id="{{item.id}}" bindtap="onJobTap">
      <!-- 头部：公司+工资 -->
      <view class="job-header">
        <view class="job-header-left">
          <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="job-avatar-img" mode="aspectFill" />
          <view wx:else class="text-avatar text-avatar-lg" style="background-color:#10B981;">{{item.companyName[0]}}</view>
          <view class="job-company-info">
            <text class="job-company">{{item.companyName}}</text>
            <text class="job-meta">{{item.cityDistrict}} · {{item.publishDate}}<text wx:if="{{item.distanceText}}" class="job-distance"> · 距您{{item.distanceText}}</text></text>
          </view>
        </view>
        <view class="job-pay">
          <text class="job-salary-big">{{item.salary}}</text>
          <text class="job-salary-unit">{{item.salaryUnit}}</text>
        </view>
      </view>
      <!-- 标题 + 急招 -->
      <view class="job-title-row">
        <text class="job-title-text">{{item.jobCardTitle}}</text>
        <text wx:if="{{item.urgent}}" class="urgent-tag">急招</text>
      </view>
      <!-- 福利标签 + 工作时间 -->
      <view class="job-tags" wx:if="{{item.allTags && item.allTags.length > 0}}">
        <text class="job-tag" wx:for="{{item.allTags}}" wx:for-item="tag" wx:for-index="tagIndex" wx:key="tagIndex" style="background:{{tag.bg}};color:{{tag.color}};">{{tag.label}}</text>
      </view>
      <!-- 描述 -->
      <text class="job-desc">{{item.desc}}</text>
      <!-- 报名进度 -->
      <view class="job-progress">
        <view class="progress-text-row">
          <text class="progress-text-simple">已报名 <text class="progress-count">{{item.applied}}</text>/{{item.need}}人</text>
          <text class="progress-remain" wx:if="{{item.need - item.applied > 0}}">剩余<text class="progress-remain-num">{{item.need - item.applied}}</text>个名额</text>
        </view>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{item.applied / item.need * 100}}%;"></view>
        </view>
      </view>
      <!-- 底部：分享 + 报名 -->
      <view class="job-bottom">
        <view class="job-outline-btn job-share-wrap" data-id="{{item.id}}">分享
          <button class="share-overlay" open-type="share" data-id="{{item.id}}" data-type="job"></button>
        </view>
        <view class="job-outline-btn" catchtap="onJobChat" data-id="{{item.id}}">在线聊</view>
        <view class="job-apply-btn" catchtap="onApply" data-id="{{item.id}}">立即报名</view>
      </view>
    </view>
    <empty-state wx:if="{{jobList.length === 0}}" text="暂无招工信息" subText="附近暂时没有招工需求" />
  </view>

  <wechat-contact-card
    visible="{{wechatCardVisible}}"
    wechat-id="{{wechatCard.wechatId}}"
    wechat-qr-image="{{wechatCard.wechatQrImage}}"
    bind:close="onCloseWechatCard"
  />
</view>

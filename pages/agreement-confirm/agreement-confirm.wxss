.ac-page {
  position: relative;
  min-height: 100vh;
  background: #e5e7eb;
  overflow: hidden;
}

.ac-overlay {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(circle at top, rgba(59, 130, 246, 0.14), transparent 36%),
    linear-gradient(180deg, rgba(15, 23, 42, 0.6), rgba(15, 23, 42, 0.36));
}

.ac-shell {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 40rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ac-dialog {
  width: 100%;
  max-width: 702rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 40rpx 28rpx 28rpx;
  box-sizing: border-box;
  box-shadow: 0 24rpx 80rpx rgba(15, 23, 42, 0.2);
}

.ac-header {
  text-align: center;
}

.ac-title {
  display: block;
  color: #111827;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 1.35;
}

.ac-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.6;
}

.ac-summary {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f8fafc;
}

.ac-summary-text {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.7;
}

.ac-scroll {
  height: 360rpx;
  margin-top: 22rpx;
  padding: 0 4rpx;
  box-sizing: border-box;
}

.ac-doc {
  padding-right: 8rpx;
}

.ac-doc-title {
  display: block;
  color: #111827;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  margin-bottom: 14rpx;
}

.ac-doc-paragraph {
  display: block;
  color: #374151;
  font-size: 24rpx;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.ac-actions {
  display: flex;
  gap: 18rpx;
  margin-top: 28rpx;
}

.ac-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
  border: none;
  padding: 0 12rpx;
  box-sizing: border-box;
}

.ac-btn::after {
  border: none;
}

.ac-btn-secondary {
  background: #f3f4f6;
  color: #4b5563;
}

.ac-btn-primary {
  background: #111827;
  color: #ffffff;
  box-shadow: 0 12rpx 28rpx rgba(17, 24, 39, 0.18);
}

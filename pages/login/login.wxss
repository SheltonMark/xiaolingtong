.login-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #ffffff;
  box-sizing: border-box;
}

.login-top {
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.back-btn {
  width: 132rpx;
  height: 64rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #334155;
  background-color: rgba(248, 250, 252, 0.96);
  border: 2rpx solid #E2E8F0;
  box-sizing: border-box;
}

.back-arrow {
  font-size: 34rpx;
  line-height: 1;
  margin-top: -2rpx;
}

.back-text {
  font-size: 24rpx;
  font-weight: 500;
}

.logo-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.logo-box {
  width: 168rpx;
  height: 168rpx;
  border-radius: 42rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
}

.logo-image {
  width: 100%;
  height: 100%;
  display: block;
}

.app-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #1E293B;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 24rpx;
  color: #64748B;
  margin-bottom: 8rpx;
}

.app-desc {
  font-size: 20rpx;
  color: #94A3B8;
}

.login-bottom {
  padding: 0 48rpx 140rpx;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
}

.wx-login-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  width: 100%;
  height: 88rpx;
  background-color: #22C55E;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  padding: 0;
  box-sizing: border-box;
  box-shadow: 0 8rpx 24rpx rgba(34, 197, 94, 0.3);
}

.wx-login-btn::after {
  border: none;
}
.login-tip {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 20rpx;
}

<view class="login-page">
  <view class="login-top" style="padding-top: {{statusBarHeight}}px;">
    <view class="back-btn" bindtap="onBack">
      <text class="back-arrow">‹</text>
      <text class="back-text">返回</text>
    </view>
  </view>

  <view class="logo-area">
    <view class="logo-box">
      <image class="logo-image" src="/logo/logo.jpg" mode="aspectFill" />
    </view>
    <text class="app-slogan">工厂贸易供需对接平台</text>
    <text class="app-desc">打破供需信息壁垒，精准匹配工厂与贸易商</text>
  </view>

  <view class="login-bottom">
    <button class="wx-login-btn" bindtap="onWxLogin">
      <text>微信一键登录</text>
    </button>
    <button class="phone-login-btn" open-type="getPhoneNumber" bindgetphonenumber="onGetPhoneNumber">
      <text>手机号快捷登录</text>
    </button>
    <text class="login-tip">手机号登录后可享受更多服务</text>
  </view>
</view>

.wl-page {
  min-height: 100vh;
  background-color: #F5F5F5;
}

.wl-card {
  margin: 24rpx 32rpx 0;
  border-radius: 32rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #F97316, #EA580C);
  color: #fff;
  position: relative;
  overflow: hidden;
}

.wl-card-bg1 {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.wl-card-bg2 {
  position: absolute;
  bottom: -64rpx;
  left: -64rpx;
  width: 192rpx;
  height: 192rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.wl-label {
  font-size: 22rpx;
  opacity: 0.8;
  display: block;
  margin-bottom: 8rpx;
  position: relative;
}

.wl-amount-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 8rpx;
  position: relative;
}

.wl-yen {
  font-size: 22rpx;
  opacity: 0.8;
}

.wl-amount {
  font-size: 64rpx;
  font-weight: 700;
}

.wl-total {
  font-size: 20rpx;
  opacity: 0.6;
  display: block;
  margin-bottom: 32rpx;
  position: relative;
}

.wl-btn-row {
  display: flex;
  gap: 24rpx;
  position: relative;
}

.wl-btn {
  flex: 1;
  height: 72rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
}

.wl-btn::after {
  border: none;
}

.wl-btn-primary {
  background-color: #fff !important;
  color: #F97316 !important;
}

.wl-btn-primary-disabled {
  background-color: rgba(255, 255, 255, 0.45) !important;
  color: rgba(249, 115, 22, 0.75) !important;
}

.wl-btn-outline {
  background-color: rgba(255, 255, 255, 0.2) !important;
  color: #fff !important;
  border: 2rpx solid rgba(255, 255, 255, 0.3) !important;
}

.wl-disabled-tip {
  display: block;
  margin-top: 18rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.82);
  position: relative;
}

.wl-section {
  margin: 24rpx 32rpx 0;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.section-action {
  font-size: 20rpx;
  color: #3B82F6;
}

.income-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.income-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.income-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.income-icon-green {
  background-color: #ECFDF5;
}

.income-icon-rose {
  background-color: #FFF1F2;
}

.income-icon {
  font-size: 28rpx;
  font-weight: 700;
}

.income-icon-green .income-icon {
  color: #10B981;
}

.income-icon-rose .income-icon {
  color: #F43F5E;
}

.income-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.income-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #1E293B;
}

.income-time {
  font-size: 20rpx;
  color: #94A3B8;
}

.income-amount {
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.wl-tip {
  margin: 24rpx 32rpx 32rpx;
  background-color: #F8FAFC;
  border-radius: 24rpx;
  padding: 24rpx;
}

.wl-tip-text {
  font-size: 20rpx;
  color: #94A3B8;
  text-align: center;
  display: block;
}

.wl-modal-mask {
  position: fixed;
  inset: 0;
  background-color: rgba(15, 23, 42, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 32rpx;
  box-sizing: border-box;
  z-index: 999;
}

.wl-modal {
  width: 100%;
  background-color: #ffffff;
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  box-sizing: border-box;
}

.wl-modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1E293B;
  text-align: center;
}

.wl-modal-balance {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  color: #64748B;
  text-align: center;
}

.wl-input-wrap {
  margin-top: 28rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background-color: #F8FAFC;
  border: 2rpx solid #E2E8F0;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.wl-input-prefix {
  font-size: 34rpx;
  font-weight: 700;
  color: #1E293B;
  margin-right: 16rpx;
}

.wl-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #1E293B;
}

.wl-modal-tip {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  line-height: 1.6;
  color: #F97316;
}

.wl-modal-tip-muted {
  color: #94A3B8;
}

.wl-modal-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 28rpx;
}

.wl-modal-btn {
  flex: 1;
  height: 84rpx;
  border-radius: 22rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
}

.wl-modal-btn::after {
  border: none;
}

.wl-modal-btn-secondary {
  background-color: #F1F5F9;
  color: #64748B;
}

.wl-modal-btn-primary {
  background-color: #F97316;
  color: #ffffff;
}

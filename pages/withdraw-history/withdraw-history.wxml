<view class="wh-page">
  <nav-bar title="{{detailPageTitle}}" />

  <view class="wh-stat-card">
    <view class="wh-stat-item">
      <text class="wh-stat-val text-fresh">¥{{summary.totalIncome}}</text>
      <text class="wh-stat-label">{{totalIncomeLabel}}</text>
    </view>
    <view class="wh-stat-item">
      <text class="wh-stat-val text-cta">¥{{summary.totalWithdraw}}</text>
      <text class="wh-stat-label">累计提现</text>
    </view>
    <view class="wh-stat-item">
      <text class="wh-stat-val text-primary">¥{{summary.balance}}</text>
      <text class="wh-stat-label">当前余额</text>
    </view>
  </view>

  <view class="wh-tab-wrap">
    <view class="wh-tabs">
      <view
        class="wh-tab {{currentTab === item.key ? 'wh-tab-active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onTabChange"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="wh-card">
    <text class="card-title">记录列表</text>
    <view class="wh-list" wx:if="{{displayRecords.length > 0}}">
      <view class="wh-item" wx:for="{{displayRecords}}" wx:key="id">
        <view class="wh-icon-wrap {{item.type === 'income' ? 'wh-icon-income' : 'wh-icon-withdraw'}}">
          <text class="wh-icon">{{item.iconText}}</text>
        </view>
        <view class="wh-info">
          <text class="wh-title">{{item.title}}</text>
          <text class="wh-time {{item.statusType === 'failed' ? 'text-rose' : (item.statusType === 'pending' ? 'text-warm' : '')}}">{{item.desc}}</text>
          <text class="wh-detail" wx:if="{{item.detail}}">{{item.detail}}</text>
        </view>
        <text class="wh-amount {{item.type === 'income' ? 'text-fresh' : 'text-rose'}}">{{item.amount}}</text>
      </view>
    </view>
    <empty-state wx:else text="暂无钱包记录" subText="有收入或提现后会展示在这里" />
  </view>

  <view class="wh-tip">
    <text class="wh-tip-text">提现到微信零钱 · 免手续费 · 一般次日到账，具体以实际到账时间为准</text>
  </view>
</view>

.wh-page {
  min-height: 100vh;
  background-color: #f8fafc;
}

.wh-stat-card {
  background-color: #fff;
  border-radius: 24rpx;
  margin: 24rpx 32rpx 0;
  padding: 32rpx;
  display: flex;
}

.wh-stat-item {
  flex: 1;
  text-align: center;
}

.wh-stat-val {
  font-size: 28rpx;
  font-weight: 700;
  display: block;
}

.wh-stat-label {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 4rpx;
  display: block;
}

.wh-tab-wrap {
  margin: 24rpx 32rpx 0;
  background-color: #fff;
  border-radius: 24rpx 24rpx 0 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.wh-tabs {
  display: flex;
}

.wh-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 24rpx;
  color: #64748b;
  position: relative;
}

.wh-tab-active {
  color: #f97316;
  font-weight: 600;
}

.wh-tab-active::after {
  content: '';
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  border-radius: 4rpx;
  background-color: #f97316;
}

.wh-card {
  background-color: #fff;
  border-radius: 0 0 24rpx 24rpx;
  margin: 0 32rpx;
  padding: 32rpx;
  min-height: 360rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
  margin-bottom: 24rpx;
}

.wh-list {
  display: flex;
  flex-direction: column;
}

.wh-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f8fafc;
}

.wh-item:last-child {
  border-bottom: none;
}

.wh-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.wh-icon-income {
  background-color: #ecfdf5;
}

.wh-icon-withdraw {
  background-color: #fff1f2;
}

.wh-icon {
  font-size: 28rpx;
  font-weight: 700;
}

.wh-icon-income .wh-icon {
  color: #10b981;
}

.wh-icon-withdraw .wh-icon {
  color: #f43f5e;
}

.wh-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.wh-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #1e293b;
}

.wh-time,
.wh-detail {
  font-size: 20rpx;
  color: #94a3b8;
}

.wh-amount {
  font-size: 28rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.wh-tip {
  margin: 24rpx 32rpx 32rpx;
  background-color: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
}

.wh-tip-text {
  font-size: 20rpx;
  color: #94a3b8;
  text-align: center;
  display: block;
}

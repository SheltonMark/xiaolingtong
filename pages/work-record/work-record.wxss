.work-record-page {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
  font-size: 24rpx;
  color: #94a3b8;
}

/* 记录列表 */
.record-list {
  padding: 24rpx 32rpx 0;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-item {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.1);
}

/* 记录头部 */
.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.company-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.company-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 12rpx;
  background-color: #e2e8f0;
}

.company-detail {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
}

.company-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #1e293b;
}

.job-title {
  font-size: 22rpx;
  color: #64748b;
}

/* 状态标签 */
.status-badge {
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 记录详情 */
.record-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.detail-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 22rpx;
}

.detail-label {
  color: #94a3b8;
  min-width: 80rpx;
}

.detail-value {
  color: #1e293b;
  font-weight: 500;
}

.detail-value.anomaly {
  color: #ef4444;
  font-weight: 600;
}

/* 照片 */
.record-photos {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.photo-item {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  background-color: #e2e8f0;
}

/* 操作按钮 */
.record-footer {
  display: flex;
  gap: 12rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f1f5f9;
}

.btn-detail {
  flex: 1;
  padding: 12rpx 16rpx;
  background-color: #3b82f6;
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  font-size: 22rpx;
  font-weight: 500;
}

/* 颜色变量 */
:root {
  --color-amber-100: #fef3c7;
  --color-amber-600: #d97706;
  --color-green-100: #dcfce7;
  --color-green-600: #16a34a;
  --color-gray-100: #f3f4f6;
  --color-gray-600: #4b5563;
  --color-rose-100: #ffe4e6;
  --color-rose-600: #e11d48;
  --color-slate-100: #f1f5f9;
  --color-slate-600: #475569;
}


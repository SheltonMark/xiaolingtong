<!--pages/work-record/work-record.wxml-->
<view class="work-record-page">
  <nav-bar title="我的接单记录" />

  <!-- 加载状态 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 工作记录列表 -->
  <view class="record-list" wx:if="{{!loading && orders.length > 0}}">
    <view class="record-item" wx:for="{{orders}}" wx:key="id"
          data-id="{{item.id}}" data-job-id="{{item.jobId}}"
          bindtap="onOrderTap">

      <!-- 公司信息 -->
      <view class="record-header">
        <view class="company-info">
          <image class="company-avatar" src="{{item.companyAvatar}}" mode="aspectFill" />
          <view class="company-detail">
            <text class="company-name">{{item.companyName}}</text>
            <text class="job-title">{{item.jobTitle}}</text>
          </view>
        </view>
        <view class="record-date">{{item.date}}</view>
      </view>

      <!-- 工作详情 -->
      <view class="record-body">
        <view class="detail-row">
          <text class="detail-label">地点：</text>
          <text class="detail-value">{{item.location}}</text>
        </view>
        <view class="detail-row">
          <text class="detail-label">工时：</text>
          <text class="detail-value">
            {{item.salaryType === 'hourly' ? item.hours + '小时' : item.pieces + '件'}}
          </text>
        </view>
        <view class="detail-row">
          <text class="detail-label">工价：</text>
          <text class="detail-value">{{item.salary}}{{item.salaryUnit}}</text>
        </view>
        <view class="detail-row" wx:if="{{item.anomalyType !== 'normal'}}">
          <text class="detail-label">异常：</text>
          <text class="detail-value anomaly" style="color: #ef4444;">{{item.anomalyText}}</text>
        </view>
      </view>

      <!-- 照片 -->
      <view class="record-photos" wx:if="{{item.photoUrls.length > 0}}">
        <image class="photo-item" wx:for="{{item.photoUrls}}" wx:key="*this"
               src="{{item}}" mode="aspectFill" />
      </view>

      <!-- 操作按钮 -->
      <view class="record-footer">
        <view class="btn-detail">查看详情</view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <empty-state wx:if="{{!loading && empty}}" text="暂无接单记录" subText="完成工作后会显示在这里" />
</view>

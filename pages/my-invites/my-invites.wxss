@import '/iconfont/iconfont.wxss';

.invite-page { background: #F8FAFC; min-height: 100vh; padding-bottom: calc(120rpx + env(safe-area-inset-bottom)); }

/* 渐变卡片 - 和钱包页风格一致 */
.inv-card {
  margin: 24rpx; padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #3B82F6 0%, #60A5FA 100%);
  border-radius: 24rpx; position: relative; overflow: hidden;
}
.inv-card-bg1 {
  position: absolute; top: -40rpx; right: -20rpx;
  width: 200rpx; height: 200rpx; border-radius: 50%;
  background: rgba(255,255,255,0.1);
}
.inv-card-bg2 {
  position: absolute; bottom: -60rpx; left: 40rpx;
  width: 160rpx; height: 160rpx; border-radius: 50%;
  background: rgba(255,255,255,0.06);
}
.inv-card-label { font-size: 24rpx; color: rgba(255,255,255,0.7); display: block; }
.inv-top {
  display: flex; justify-content: center; align-items: center;
  padding-bottom: 32rpx;
}
.inv-stat-item { text-align: center; }
.inv-stat-num { font-size: 72rpx; font-weight: 700; color: #fff; display: block; line-height: 1.1; }
.inv-stat-label { font-size: 22rpx; color: rgba(255,255,255,0.7); }
.inv-bottom {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: 24rpx; border-top: 1rpx solid rgba(255,255,255,0.15);
}
.inv-code-info { display: flex; align-items: center; gap: 12rpx; }
.inv-code-label { font-size: 24rpx; color: rgba(255,255,255,0.7); }
.inv-code { font-size: 28rpx; font-weight: 600; color: #fff; letter-spacing: 2rpx; }
.inv-copy {
  font-size: 24rpx; color: #3B82F6; background: #fff;
  padding: 12rpx 28rpx; border-radius: 24rpx; font-weight: 500;
}

/* 邀请说明 */
.invite-tip {
  margin: 24rpx 24rpx 0;
  padding: 24rpx;
  background: #FFF7ED;
  border-radius: 16rpx;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}
.tip-icon {
  font-size: 32rpx;
  color: #F97316;
  flex-shrink: 0;
}
.tip-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}
.tip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
}
.tip-text {
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.6;
}

/* 列表区域 */
.section-header { padding: 24rpx 24rpx 16rpx; }
.section-title { font-size: 28rpx; font-weight: 600; color: #1E293B; }

.record-list { margin: 0 24rpx; background: #fff; border-radius: 24rpx; overflow: hidden; }
.record-item {
  display: flex; align-items: center; gap: 20rpx;
  padding: 24rpx; border-bottom: 1rpx solid #F1F5F9;
}
.record-item:last-child { border-bottom: none; }
.avatar-img { width: 72rpx; height: 72rpx; border-radius: 50%; }
.record-info { flex: 1; }
.record-name { font-size: 28rpx; color: #1E293B; font-weight: 500; display: block; }
.record-meta { font-size: 22rpx; color: #94A3B8; margin-top: 4rpx; display: block; }

.empty-wrap { text-align: center; padding: 80rpx 0; }
.empty-text { font-size: 28rpx; color: #94A3B8; display: block; }
.empty-sub { font-size: 24rpx; color: #CBD5E1; margin-top: 12rpx; display: block; }

.loading-tip { text-align: center; padding: 32rpx; font-size: 24rpx; color: #94A3B8; }

.bottom-share {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
}
.share-btn {
  width: 100%; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  background: #3B82F6; color: #fff;
  font-size: 30rpx; font-weight: 600;
  border-radius: 16rpx; border: none;
}
.share-btn::after { border: none; }

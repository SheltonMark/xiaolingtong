<view class="invite-page">
  <nav-bar title="我的邀请" />

  <!-- 顶部渐变卡片 -->
  <view class="inv-card">
    <view class="inv-card-bg1"></view>
    <view class="inv-card-bg2"></view>
    <view class="inv-top">
      <view class="inv-stat-item">
        <text class="inv-stat-num">{{totalInvites}}</text>
        <text class="inv-stat-label">累计邀请(人)</text>
      </view>
    </view>
    <view class="inv-bottom">
      <view class="inv-code-info">
        <text class="inv-code-label">邀请码</text>
        <text class="inv-code">{{inviteCode || '------'}}</text>
      </view>
      <text class="inv-copy" bindtap="onCopyCode">复制邀请码</text>
    </view>
  </view>

  <!-- 邀请说明 -->
  <view class="invite-tip">
    <text class="tip-icon iconfont icon-tishixinxi"></text>
    <view class="tip-content">
      <text class="tip-title">邀请奖励</text>
      <text class="tip-text">邀请好友注册即奖励灵豆，好友充值还有持续返佣。点击下方"邀请好友"发送给微信好友即可。</text>
    </view>
  </view>

  <!-- 邀请记录列表 -->
  <view class="section-header">
    <text class="section-title">邀请记录</text>
  </view>

  <view class="record-list" wx:if="{{list.length > 0}}">
    <view class="record-item" wx:for="{{list}}" wx:key="id">
      <view class="record-avatar">
        <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="avatar-img" mode="aspectFill" />
        <view wx:else class="text-avatar" style="width:72rpx;height:72rpx;font-size:26rpx;background-color:#3B82F6;">{{item.initial || '用'}}</view>
      </view>
      <view class="record-info">
        <text class="record-name">{{item.nickname || '新用户'}}</text>
        <text class="record-meta">{{item.role === 'enterprise' ? '企业' : item.role === 'worker' ? '临工' : '未选择'}} · {{item.createdAt}}</text>
      </view>
    </view>
  </view>

  <view class="empty-wrap" wx:if="{{list.length === 0 && !loading}}">
    <text class="empty-text">暂无邀请记录</text>
    <text class="empty-sub">分享给好友，邀请他们加入</text>
  </view>

  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 底部分享按钮 -->
  <view class="bottom-share">
    <button class="share-btn" open-type="share">邀请好友</button>
  </view>
</view>

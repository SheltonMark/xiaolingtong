.my-favorites-page {
  min-height: 100vh;
  background-color: #F8FAFC;
}

/* Tab栏 */
.tab-bar {
  display: flex;
  background-color: #FFFFFF;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #F1F5F9;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-text {
  font-size: 28rpx;
  color: #64748B;
  transition: all 0.3s;
}

.tab-active .tab-text {
  color: #3B82F6;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 48rpx;
  height: 6rpx;
  background-color: #3B82F6;
  border-radius: 3rpx;
}

/* 收藏列表 */
.favorites-list {
  padding: 24rpx 32rpx;
}

/* 收藏卡片 - 与"我的"页面保持一致 */
.fav-card {
  background-color: #F8FAFC;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.fav-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.fav-type-tag {
  font-size: 20rpx;
  padding: 4rpx 0;
  font-weight: 500;
  white-space: nowrap;
}

.fav-type-post {
  color: #3B82F6;
}

.fav-type-job {
  color: #F97316;
}

.fav-type-exposure {
  color: #F43F5E;
}

.fav-date {
  font-size: 20rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.fav-title {
  font-size: 26rpx;
  color: #1E293B;
  font-weight: 500;
  line-height: 1.45;
  margin-bottom: 8rpx;
  display: block;
}

.fav-content {
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.fav-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}

.fav-meta-item {
  font-size: 20rpx;
  color: #64748B;
}

.fav-images {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.fav-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

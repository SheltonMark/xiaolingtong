<view class="my-favorites-page">
  <nav-bar title="我的收藏" />

  <!-- Tab栏 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === index ? 'tab-active' : ''}}"
          wx:for="{{tabs}}" wx:key="*this"
          data-index="{{index}}" bindtap="onTabChange">
      <text>{{item}}</text>
    </view>
  </view>

  <!-- 收藏列表 -->
  <view class="favorites-list">
    <view class="fav-card" wx:for="{{displayList}}" wx:key="id">
      <view class="post-top">
        <text class="type-tag type-{{item.targetType === 'post' ? 'blue' : item.targetType === 'job' ? 'orange' : 'rose'}}">{{item.targetType === 'post' ? '供需' : item.targetType === 'job' ? '招工' : '维权'}}</text>
        <text class="post-date" wx:if="{{item.displayDate}}">{{item.displayDate}}</text>
      </view>
      <text class="post-title">{{item.title}}</text>
      <text class="fav-content" wx:if="{{item.content}}">{{item.content}}</text>

      <!-- 招工信息特殊显示 -->
      <view class="fav-meta" wx:if="{{item.targetType === 'job'}}">
        <text class="fav-meta-item text-cta font-semibold">{{item.salary}}{{item.salaryUnit}}</text>
        <text class="fav-meta-item">需{{item.needCount}}人</text>
        <text class="fav-meta-item">{{item.location}}</text>
      </view>

      <!-- 图片 -->
      <view class="fav-images" wx:if="{{item.images && item.images.length > 0}}">
        <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"
               src="{{img}}" mode="aspectFill" class="fav-img" />
      </view>

      <!-- 操作按钮 -->
      <view class="fav-actions">
        <view class="fav-action action-view" data-id="{{item.id}}" data-type="{{item.targetType}}" catchtap="onViewFavorite">查看</view>
        <view class="fav-action action-delete" data-id="{{item.id}}" data-type="{{item.targetType}}" catchtap="onCancelFavorite">取消收藏</view>
      </view>
    </view>

    <empty-state wx:if="{{displayList.length === 0}}"
                 text="暂无收藏"
                 subText="去浏览信息收藏感兴趣的内容吧~" />
  </view>
</view>

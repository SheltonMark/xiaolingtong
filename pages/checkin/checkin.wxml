<view class="ci-page">
  <nav-bar title="签到管理" />

  <view class="ci-card">
    <view class="ci-job-header">
      <image wx:if="{{jobInfo.avatarUrl}}" src="{{jobInfo.avatarUrl}}" mode="aspectFill" class="ci-avatar-img ci-job-avatar" />
      <view wx:else class="text-avatar" style="width:60rpx;height:60rpx;font-size:24rpx;background-color:#10B981;">{{jobInfo.avatarText}}</view>
      <view class="ci-job-info">
        <text class="ci-company">{{jobInfo.company}} · {{jobInfo.title}}</text>
        <text class="ci-date">{{jobInfo.date}} · {{jobInfo.time}}</text>
      </view>
      <text class="admin-badge">{{isSupervisor ? '临工管理员' : '零工签到'}}</text>
    </view>
    <view class="ci-stats">
      <view class="ci-stat">
        <text class="ci-stat-val text-primary">{{jobInfo.total}}</text>
        <text class="ci-stat-label">应到人数</text>
      </view>
      <view class="ci-stat">
        <text class="ci-stat-val text-fresh">{{jobInfo.checkedIn}}</text>
        <text class="ci-stat-label">已签到</text>
      </view>
      <view class="ci-stat">
        <text class="ci-stat-val text-rose">{{jobInfo.notCheckedIn}}</text>
        <text class="ci-stat-label">未签到</text>
      </view>
    </view>
  </view>

  <view class="ci-card gps-card">
    <view class="gps-map">
      <view class="gps-ring-outer">
        <view class="gps-ring-inner">
          <text class="gps-pin iconfont icon-address"></text>
        </view>
      </view>
      <view class="gps-factory-label">{{jobInfo.company}}</view>
      <view class="gps-my-label">
        <text class="my-loc-icon">●</text>
        <text>我的位置</text>
      </view>
    </view>
    <view class="gps-info">
      <view class="gps-icon-wrap">
        <text class="gps-icon-big iconfont icon-address"></text>
      </view>
      <text class="gps-factory">{{jobInfo.company}}</text>
      <text class="gps-hint">当前位置距离签到点 <text class="text-fresh font-medium">{{distance !== null ? distance + 'm' : '--'}}</text></text>

      <view class="gps-location-block">
        <text class="gps-location-label">当前位置</text>
        <text class="gps-location-value {{currentLocationText ? '' : 'gps-location-placeholder'}}">
          {{currentLocationText || '暂未获取当前位置'}}
        </text>
      </view>

      <view class="gps-location-block">
        <text class="gps-location-label">签到点地址</text>
        <text class="gps-location-value {{jobLocationText ? '' : 'gps-location-placeholder'}}">
          {{jobLocationText || '暂未配置签到点地址'}}
        </text>
      </view>

      <button class="btn btn-fresh checkin-btn {{!canCheckinButton ? 'checkin-btn-disabled' : ''}}"
              disabled="{{!canCheckinButton}}" bindtap="onCheckin">立即签到</button>
      <text class="checkin-tip" wx:if="{{localBlockedReason || checkinBlockedReason}}">{{localBlockedReason || checkinBlockedReason}}</text>
      <text class="checkin-window" wx:if="{{checkinWindowStart && checkinWindowEnd}}">签到时间：{{checkinWindowStart}} - {{checkinWindowEnd}}</text>
      <text class="refresh-link" bindtap="onRefreshLocation"><text class="iconfont icon-shuaxin"></text> 刷新位置</text>
      <text class="gps-range">需在工地 {{maxDistance}} 米范围内签到</text>
    </view>
  </view>

  <view class="ci-section">
    <view class="section-header">
      <text class="section-title">签到名单</text>
      <text class="section-action" wx:if="{{isSupervisor}}" bindtap="onCheckAll">全部签到</text>
    </view>
    <view class="checkin-list">
      <view class="checkin-item" wx:for="{{workers}}" wx:key="id">
        <view class="text-avatar" style="width:64rpx;height:64rpx;font-size:26rpx;background-color:#3B82F6;">{{item.name[0]}}</view>
        <view class="checkin-info">
          <text class="checkin-name">{{item.name}}</text>
          <text class="checkin-time {{item.status === 'absent' ? 'text-rose' : ''}}">
            {{item.status === 'absent' ? '未签到' : item.time + ' 已签到' + (item.status === 'late' ? '（迟到）' : '')}}
          </text>
        </view>
        <view wx:if="{{item.status === 'ontime'}}" class="check-circle check-green">
          <text class="check-mark">✓</text>
        </view>
        <view wx:elif="{{item.status === 'late'}}" class="check-circle check-amber">
          <text class="check-mark">✓</text>
        </view>
        <button wx:elif="{{item.status === 'absent' && isSupervisor}}" class="manual-checkin-btn"
                data-id="{{item.id}}" bindtap="onManualCheckin">手动签到</button>
      </view>
    </view>
  </view>

  <view class="ci-card" wx:if="{{isSupervisor}}">
    <text class="card-title">上传现场照片</text>
    <text class="photo-hint">请拍摄工作现场照片，作为签到与开工记录。</text>
    <view class="start-status" wx:if="{{hasStartedToday}}">
      <text class="start-status-label">今日已确认开工</text>
      <text class="start-status-meta" wx:if="{{startedAt}}">{{startedAt}}{{startedBy ? ' · ' + startedBy : ''}}</text>
    </view>
    <view class="photo-grid">
      <view class="photo-item" wx:for="{{photos}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="photo-img" />
      </view>
      <view class="photo-add" wx:if="{{photos.length < 9}}" bindtap="onTakePhoto">
        <text class="photo-add-icon">📷</text>
        <text class="photo-add-text">拍照</text>
      </view>
    </view>
  </view>

  <view class="ci-bottom" wx:if="{{isSupervisor}}">
    <button wx:if="{{canConfirmStart}}" class="btn btn-fresh" loading="{{submittingStart}}" bindtap="onConfirmStart">确认开工</button>
    <button wx:elif="{{hasStartedToday}}" class="btn btn-started" disabled>今日已确认开工</button>
  </view>
</view>

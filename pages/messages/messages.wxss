.msg-page { min-height: 100vh; background-color: #F8FAFC; padding-bottom: 140rpx; }
.not-logged-in {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}
.nli-text { font-size: 28rpx; color: #94A3B8; margin-top: 24rpx; }
.nli-btn {
  margin-top: 32rpx;
  padding: 16rpx 64rpx;
  border-radius: 40rpx;
  background: #3B82F6;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}
.tab-bar { display: flex; background-color: #fff; border-bottom: 1rpx solid #F1F5F9; }
.tab-item { flex: 1; text-align: center; padding: 20rpx 0; font-size: 24rpx; color: #64748B; position: relative; }
.tab-active { color: #3B82F6; font-weight: 500; }
.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #3B82F6;
  border-radius: 4rpx;
}
.tab-text-wrap { display: inline-block; position: relative; }
.tab-label { display: inline-block; line-height: 1; }
.tab-badge {
  min-width: 24rpx;
  height: 24rpx;
  background-color: #F43F5E;
  color: #fff;
  font-size: 16rpx;
  font-weight: 700;
  border-radius: 9999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
  margin-left: 4rpx;
  margin-top: -4rpx;
}
.tab-badge-float { position: absolute; left: 100%; top: 0; margin-left: 6rpx; margin-top: -10rpx; }
.msg-list { padding: 24rpx 32rpx; display: flex; flex-direction: column; gap: 16rpx; }
.system-panel-head {
  padding: 24rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #EEF4FF 0%, #F8FAFC 100%);
  border: 1rpx solid #DBEAFE;
}
.system-panel-title-row { display: flex; align-items: center; justify-content: space-between; gap: 16rpx; }
.system-panel-title { font-size: 28rpx; font-weight: 700; color: #1E3A8A; }
.system-role-badge,
.msg-role-chip {
  flex-shrink: 0;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: #1D4ED8;
  background-color: rgba(59, 130, 246, 0.12);
}
.system-panel-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #64748B;
  line-height: 1.6;
}
.msg-card { background-color: #fff; border-radius: 20rpx; padding: 24rpx; display: flex; align-items: center; gap: 20rpx; }
.msg-unread { background-color: #FFFEFE; }
.system-card { gap: 16rpx; }
.msg-brace {
  width: 14rpx;
  align-self: stretch;
  border-left-width: 5rpx;
  border-left-style: solid;
  border-top-width: 5rpx;
  border-top-style: solid;
  border-bottom-width: 5rpx;
  border-bottom-style: solid;
  border-top-left-radius: 14rpx;
  border-bottom-left-radius: 14rpx;
  flex-shrink: 0;
}
.msg-icon-wrap { width: 64rpx; height: 64rpx; border-radius: 14rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.msg-icon-text { font-size: 28rpx; }
.msg-body { flex: 1; min-width: 0; }
.msg-top-row { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; margin-bottom: 8rpx; }
.msg-system-title-row { flex: 1; min-width: 0; display: flex; align-items: center; gap: 12rpx; }
.msg-name-row { flex: 1; min-width: 0; display: flex; align-items: center; gap: 12rpx; }
.msg-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1E293B;
  max-width: 260rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.msg-title-read { font-weight: 500; color: #64748B; }
.msg-presence { flex-shrink: 0; font-size: 20rpx; line-height: 1; }
.msg-presence-online { color: #10B981; }
.msg-presence-offline { color: #94A3B8; }
.msg-time-wrap { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; }
.msg-time { font-size: 20rpx; color: #94A3B8; }
.unread-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background-color: #F43F5E; }
.msg-desc {
  font-size: 22rpx;
  color: #64748B;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.msg-desc-read { color: #94A3B8; }
.chat-card { align-items: center; }
.chat-avatar-wrap { width: 88rpx; height: 88rpx; border-radius: 50%; flex-shrink: 0; position: relative; overflow: visible; }
.avatar-img-md { width: 88rpx; height: 88rpx; border-radius: 50%; }
.chat-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 28rpx;
  height: 28rpx;
  background-color: #F43F5E;
  color: #fff;
  font-size: 18rpx;
  font-weight: 600;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 6rpx;
}

<view class="msg-page">
  <nav-bar title="消息中心" showBack="{{true}}" />

  <view wx:if="{{notLoggedIn}}" class="not-logged-in">
    <text class="iconfont icon-xiaoxi" style="font-size:80rpx;color:#CBD5E1;"></text>
    <text class="nli-text">登录后查看消息</text>
    <view class="nli-btn" bindtap="onGoLogin">去登录</view>
  </view>

  <block wx:else>
    <view class="tab-bar">
      <view class="tab-item {{currentTab === 0 ? 'tab-active' : ''}}" data-index="{{0}}" bindtap="onTabChange">
        <view class="tab-text-wrap">
          <text class="tab-label">业务消息</text>
          <view class="tab-badge tab-badge-float" wx:if="{{chatUnreadCount > 0}}">{{chatUnreadDisplay}}</view>
        </view>
      </view>
      <view class="tab-item {{currentTab === 1 ? 'tab-active' : ''}}" data-index="{{1}}" bindtap="onTabChange">
        <view class="tab-text-wrap">
          <text class="tab-label">{{systemTabLabel}}</text>
          <view class="tab-badge tab-badge-float" wx:if="{{systemUnreadCount > 0}}">{{systemUnreadDisplay}}</view>
        </view>
      </view>
    </view>

    <view class="msg-list" wx:if="{{currentTab === 0}}">
      <view class="msg-card chat-card" wx:for="{{chatMessages}}" wx:key="id" bindtap="onTapChat" data-item="{{item}}">
        <view class="chat-avatar-wrap">
          <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="avatar-img avatar-img-md" />
          <view wx:else class="text-avatar" style="width:88rpx;height:88rpx;font-size:32rpx;background-color:{{item.avatarBg}};">{{item.avatarText}}</view>
          <view class="chat-badge" wx:if="{{item.unreadCount > 0}}">{{item.unreadCount}}</view>
        </view>
        <view class="msg-body">
          <view class="msg-top-row">
            <view class="msg-name-row">
              <text class="msg-title">{{item.name}}</text>
              <text wx:if="{{item.activeText}}" class="msg-presence {{item.isOnline ? 'msg-presence-online' : 'msg-presence-offline'}}">{{item.activeText}}</text>
            </view>
            <text class="msg-time">{{item.time}}</text>
          </view>
          <text class="msg-desc">{{item.lastMsg}}</text>
        </view>
      </view>
      <empty-state wx:if="{{chatMessages.length === 0}}" text="暂无业务消息" />
    </view>

    <view class="msg-list" wx:if="{{currentTab === 1}}">
      <view class="system-panel-head">
        <text class="system-panel-title">{{systemPanelTitle}}</text>
        <text class="system-panel-hint">{{systemPanelHint}}</text>
      </view>

      <block wx:if="{{systemSections.length > 0}}">
        <view class="system-section" wx:for="{{systemSections}}" wx:key="key" wx:for-item="section">
          <view class="system-section-head">
            <view class="system-section-title-wrap">
              <text class="system-section-title">{{section.title}}</text>
            </view>
            <text class="system-section-unread" wx:if="{{section.unreadCount > 0}}">{{section.unreadLabel}}</text>
          </view>
          <text class="system-section-hint">{{section.hint}}</text>

          <view
            class="msg-card system-card {{item.unread ? 'msg-unread' : ''}}"
            wx:for="{{section.items}}"
            wx:key="id"
            wx:for-item="item"
            bindtap="onTapMsg"
            data-item="{{item}}"
          >
            <view class="msg-brace" style="border-color: {{item.accentColor}};"></view>
            <view class="msg-icon-wrap" style="background-color: {{item.iconBg}}; color: {{item.iconColor}};">
              <text class="msg-icon-text">{{item.icon}}</text>
            </view>
            <view class="msg-body">
              <view class="msg-top-row">
                <view class="msg-system-title-row">
                  <text class="msg-title {{item.unread ? '' : 'msg-title-read'}}">{{item.title}}</text>
                </view>
                <view class="msg-time-wrap">
                  <view class="unread-dot" wx:if="{{item.unread}}"></view>
                  <text class="msg-time">{{item.time}}</text>
                </view>
              </view>
              <text class="msg-desc {{item.unread ? '' : 'msg-desc-read'}}">{{item.desc}}</text>
            </view>
          </view>
        </view>
      </block>

      <empty-state wx:if="{{systemSections.length === 0}}" text="{{systemEmptyText}}" subText="{{systemEmptySubText}}" />
    </view>
  </block>
</view>


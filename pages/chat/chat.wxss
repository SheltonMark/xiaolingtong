.chat-page { 
  display: flex; 
  flex-direction: column; 
  height: 100vh; 
  background-color: #F8FAFC; 
  overflow: hidden; 
}
.chat-body { 
  flex: 1; 
  padding: 24rpx;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  overflow-y: auto; 
  overflow-x: hidden;
  box-sizing: border-box; 
}
.time-mark { text-align: center; margin-bottom: 24rpx; }
.time-mark text { font-size: 20rpx; color: #94A3B8; }
.sys-tip { display: flex; justify-content: center; margin-bottom: 24rpx; }
.sys-tip-text { font-size: 20rpx; color: #94A3B8; background-color: #F1F5F9; padding: 8rpx 24rpx; border-radius: 9999rpx; }

.msg-row {
  display: flex; 
  align-items: flex-start; 
  gap: 16rpx;
  margin-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
  overflow: hidden;
}
.msg-left { flex-direction: row; }
.msg-right { 
  flex-direction: row; 
  justify-content: flex-end; 
  padding-right: 0;
}
.msg-avatar-wrap { 
  width: 64rpx; 
  height: 64rpx; 
  flex: 0 0 64rpx; 
  box-sizing: border-box;
  overflow: hidden;
  border-radius: 50%;
}
.msg-bubble-wrap {
  display: flex; 
  flex-direction: column; 
  min-width: 0;
  max-width: calc(100% - 80rpx); 
  overflow: hidden;
}
.msg-bubble-right { align-items: flex-end; }
.bubble { 
  padding: 16rpx 24rpx; 
  font-size: 26rpx; 
  line-height: 1.6; 
  word-wrap: break-word; 
  overflow-wrap: break-word;
  max-width: 100%;
}
.bubble-left { background-color: #fff; border-radius: 24rpx 24rpx 24rpx 4rpx; color: #1E293B; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04); }
.bubble-right { background-color: #3B82F6; border-radius: 24rpx 24rpx 4rpx 24rpx; color: #fff; }
.msg-image { width: 300rpx; border-radius: 16rpx; margin-top: 12rpx; max-width: 100%; }
.msg-time-text { font-size: 20rpx; color: #94A3B8; margin-top: 8rpx; }
.msg-time-right { text-align: right; }

.chat-bottom { 
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  background-color: #fff; 
  border-top: 1rpx solid #F1F5F9; 
  padding: 16rpx 24rpx; 
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}
.chat-input-row { display: flex; align-items: center; gap: 12rpx; }
.chat-tool-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.chat-tool-icon {
  font-size: 48rpx;
  color: #64748B;
}
.chat-input { 
  flex: 1; 
  height: 72rpx;
  line-height: 72rpx;
  background-color: #F1F5F9; 
  border-radius: 36rpx; 
  padding: 0 24rpx; 
  font-size: 26rpx;
  box-sizing: border-box;
}
.chat-send-btn {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background-color: #3B82F6;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.send-arrow { color: #fff; font-size: 24rpx; font-weight: 700; line-height: 1; }

.text-avatar {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}
.text-avatar-md {
  width: 64rpx;
  height: 64rpx;
}

<!--pages/post-detail/post-detail.wxml-->
<view class="detail-page">
  <nav-bar title="信息详情" />
  <!-- 视频播放 -->
  <view class="video-wrap" wx:if="{{detail.videos && detail.videos.length > 0}}">
    <video src="{{detail.videos[0]}}" class="detail-video" controls show-fullscreen-btn object-fit="cover" />
  </view>
  <!-- 图片轮播 -->
  <view class="swiper-wrap" wx:if="{{detail.images.length > 0}}">
    <swiper class="image-swiper"
            indicator-dots autoplay circular
            bindchange="onSwiperChange">
      <swiper-item wx:for="{{detail.images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="swiper-img" data-urls="{{detail.images}}" data-current="{{item}}" catchtap="onPreviewImage" />
      </swiper-item>
    </swiper>
    <view class="swiper-counter">{{swiperCurrent + 1}}/{{detail.images.length}}</view>
  </view>

  <!-- 基本信息 -->
  <view class="title-section">
    <view class="tag-row">
      <text class="tag tag-blue">{{detail.typeText}}</text>
      <text class="tag tag-cyan" wx:if="{{detail.processModeLabel}}">{{detail.processModeLabel}}</text>
      <text class="tag tag-amber">{{detail.industry}}</text>
    </view>
    <text class="detail-title">{{detail.title}}</text>
    <view class="location-row" wx:if="{{detail.address || detail.location}}">
      <text class="loc-icon iconfont icon-address"></text>
      <text class="loc-text">{{detail.address || detail.location}}</text>
      <text class="nav-icon iconfont icon-daohang" wx:if="{{detail.lat && detail.lng}}" bindtap="onNavigate"></text>
    </view>
    <view wx:if="{{detail.distanceText}}" class="distance-pill">
      <text class="distance-val">距您 {{detail.distanceText}}</text>
    </view>
    <view class="title-meta">
      <text class="meta-text">发布时间：{{detail.publishTime}}</text>
      <text class="meta-text">有效期至：{{detail.expireTime}}</text>
    </view>
  </view>

  <!-- 详细信息 -->
  <view class="info-section">
    <view class="section-header-row">
      <text class="section-icon iconfont icon-xiangqing"></text>
      <text class="section-label">详细信息</text>
    </view>
    <view class="info-list">
      <view class="info-row" wx:for="{{detail.fields}}" wx:key="label">
        <text class="info-label">{{item.label}}</text>
        <text class="info-value {{item.highlight ? 'text-cta font-semibold' : ''}} {{item.bold ? 'font-medium' : ''}}">{{item.value}}</text>
      </view>
    </view>
    <view class="desc-area" wx:if="{{detail.desc}}">
      <text class="desc-label">补充描述</text>
      <text class="desc-text">{{detail.desc}}</text>
    </view>
  </view>

  <!-- 发布者信息 -->
  <view class="publisher-section">
    <view class="section-header-row">
      <text class="section-icon iconfont icon-gongsi"></text>
      <text class="section-label">发布者</text>
    </view>
    <view class="publisher-info">
      <image wx:if="{{detail.avatarUrl}}" src="{{detail.avatarUrl}}" mode="aspectFill" class="pub-avatar-img" />
      <view wx:else class="text-avatar" style="width:88rpx;height:88rpx;font-size:32rpx;background-color:#3B82F6;">{{detail.avatarText}}</view>
      <view class="pub-detail">
        <view class="pub-name-row">
          <text class="pub-name">{{detail.companyName}}</text>
          <text class="cert-badge {{detail.certText === '未认证' ? 'cert-badge-pending' : ''}}">{{detail.certText}}</text>
        </view>
        <text class="pub-industry">{{detail.industry}} · 发布信息 {{detail.postCount || '--'}} 条</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions-placeholder"></view>
  <view class="bottom-actions">
    <view class="fav-btn" bindtap="onToggleFav">
      <text class="iconfont icon-xingxing {{isFav ? 'fav-active' : 'fav-inactive'}}"></text>
    </view>
    <view class="share-btn-wrap">
      <text class="iconfont icon-fenxiang1 share-icon-gray"></text>
      <button class="share-overlay-btn" open-type="share"></button>
    </view>
    <button class="bottom-btn btn-chat" bindtap="onChat">
      <text class="bottom-btn-icon iconfont icon-xiaoxi"></text>
      <text>在线聊</text>
    </button>
    <!-- 根据 isOwner/isUnlocked 显示不同按钮 -->
    <button class="bottom-btn btn-contact" bindtap="onContactAction">
      <text class="bottom-btn-icon iconfont {{isUnlocked ? 'icon-lianxi' : 'icon-jiesuo'}}"></text>
      <text>{{isUnlocked ? '立即联系' : '解锁联系方式'}}</text>
    </button>
  </view>

  <wechat-contact-card
    visible="{{wechatCardVisible}}"
    wechat-id="{{wechatCard.wechatId}}"
    wechat-qr-image="{{wechatCard.wechatQrImage}}"
    bind:close="onCloseWechatCard"
  />

  <!-- 灵豆不足引导弹窗 -->
  <view class="bean-shortage-mask" wx:if="{{showBeanShortageModal}}" catchtap="onCloseBeanShortage">
    <view class="bean-shortage-dialog" catchtap="">
      <view class="bean-shortage-title">灵豆不足</view>
      <view class="bean-shortage-desc">需要 {{beanShortage.need}} 灵豆解锁，当前余额 {{beanShortage.balance}} 灵豆</view>
      <view class="bean-shortage-actions">
        <view class="bean-action-item" data-action="recharge" bindtap="onBeanShortageAction">
          <text class="bean-action-icon iconfont icon-lingdou"></text>
          <text class="bean-action-text">去充值</text>
        </view>
        <view class="bean-action-item" data-action="invite" bindtap="onBeanShortageAction">
          <text class="bean-action-icon iconfont icon-yaoqing"></text>
          <text class="bean-action-text">邀请好友赚灵豆</text>
        </view>
      </view>
      <view class="bean-shortage-disclaimer">免责声明：联系方式由发布者提供，平台不对其真实性负责，请注意交易安全。</view>
      <view class="bean-shortage-close" bindtap="onCloseBeanShortage">关闭</view>
    </view>
  </view>
</view>

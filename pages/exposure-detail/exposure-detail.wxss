.ed-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eef6ff 0%, #f8fafc 240rpx, #f8fafc 100%);
  padding-bottom: calc(132rpx + env(safe-area-inset-bottom));
}

.ed-card {
  margin: 0 24rpx 24rpx;
  padding: 28rpx 28rpx 32rpx;
  border-radius: 28rpx;
  background-color: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.05);
}

.ed-author {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.ed-avatar-img {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.ed-author-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.ed-author-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.ed-author-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.ed-author-time {
  font-size: 20rpx;
  color: #94a3b8;
}

.ed-type-tag {
  font-size: 20rpx;
  color: #1d4ed8;
  background-color: #dbeafe;
  padding: 4rpx 14rpx;
  border-radius: 9999rpx;
}

.ed-note {
  padding: 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #f0fdf4 100%);
  margin-bottom: 24rpx;
}

.ed-note-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 8rpx;
}

.ed-note-text {
  font-size: 22rpx;
  color: #475569;
  line-height: 1.7;
}

.ed-fields {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ed-field {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.ed-field-label {
  width: 140rpx;
  color: #64748b;
  font-weight: 600;
  flex-shrink: 0;
}

.ed-field-value {
  color: #0f172a;
}

.ed-content {
  font-size: 26rpx;
  color: #1e293b;
  line-height: 1.8;
  display: block;
  margin-bottom: 24rpx;
}

.ed-meta {
  display: flex;
  gap: 32rpx;
  align-items: center;
  margin-top: 24rpx;
}

.ed-meta-item {
  font-size: 22rpx;
  color: #94a3b8;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
}

.ed-meta-item .iconfont {
  font-size: 28rpx;
  line-height: 1;
  vertical-align: middle;
  margin-top: -2rpx;
}

.ed-fav {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-left: auto;
}

.ed-fav .iconfont {
  font-size: 28rpx;
}

.fav-active {
  color: #f59e0b;
}

.fav-inactive {
  color: #cbd5e1;
}

.ed-section-title {
  font-size: 28rpx;
  color: #0f172a;
  font-weight: 600;
  margin-bottom: 20rpx;
  display: block;
}

.comment-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.comment-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
}

.comment-avatar-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
  min-width: 0;
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.comment-name {
  font-size: 24rpx;
  color: #0f172a;
  font-weight: 600;
}

.comment-time {
  font-size: 20rpx;
  color: #94a3b8;
  flex-shrink: 0;
}

.comment-text {
  margin-top: 8rpx;
  display: block;
  font-size: 24rpx;
  line-height: 1.7;
  color: #334155;
  word-break: break-all;
}

.ed-bottom {
  position: fixed;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid #e2e8f0;
  z-index: 100;
}

.ed-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  background-color: #f1f5f9;
  font-size: 24rpx;
}

.ed-send-btn {
  width: 124rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  color: #fff;
  font-size: 24rpx;
  margin: 0;
  padding: 0;
}

.ed-send-btn::after {
  border: none;
}

<!--pages/my-posts/my-posts.wxml-->
<view class="my-posts-page">
  <nav-bar title="我的发布" />
  <view class="tab-bar">
    <view class="tab-item {{currentTab === index ? 'tab-active' : ''}}"
          wx:for="{{tabs}}" wx:key="index"
          data-index="{{index}}" bindtap="onTabChange">
      <text>{{item.label}}</text>
    </view>
  </view>

  <view class="post-list">
    <view class="post-card {{item.status === 'offline' ? 'card-offline' : ''}}"
          wx:for="{{posts}}" wx:key="uniqueKey"
          wx:if="{{currentTab === 0 || item.typeKey === tabs[currentTab].key}}">
      <view class="post-top">
        <view class="post-top-left">
          <text class="type-tag type-{{item.typeColor}}">{{item.type}}</text>
          <text class="promote-tag" wx:if="{{item.isPromoted}}">置顶中</text>
          <text class="urgent-tag" wx:if="{{item.urgent}}">急招中</text>
        </view>
        <view class="post-top-right">
          <view class="status-tag status-bg-{{item.statusColor}}">
            <text>{{item.statusText}}</text>
          </view>
          <text
            wx:if="{{item.showDeleteAction}}"
            class="post-top-delete"
            data-id="{{item.id}}"
            data-type="{{item.typeKey}}"
            bindtap="onDirectDelete"
          >删除</text>
        </view>
      </view>

      <text class="post-title">{{item.title}}</text>

      <view class="job-detail-info" wx:if="{{item.typeKey === 'job'}}">
        <view class="job-info-row">
          <text class="job-info-label">工价：</text>
          <text class="job-info-value text-cta font-semibold">{{item.salary}}{{item.salaryUnit}}</text>
        </view>
        <view class="job-info-row">
          <text class="job-info-label">人数：</text>
          <text class="job-info-value">需{{item.needCount}}人 · 有效报名{{item.activeApplicantCount || item.appliedCount || 0}}人 · 累计记录{{item.applicationRecordCount || 0}}条</text>
        </view>
        <view class="job-info-row" wx:if="{{item.dateRange}}">
          <text class="job-info-label">日期：</text>
          <text class="job-info-value">{{item.dateRange}}</text>
        </view>
        <view class="job-info-row" wx:if="{{item.workHours}}">
          <text class="job-info-label">时间：</text>
          <text class="job-info-value">{{item.workHours}}</text>
        </view>
        <view class="job-info-row" wx:if="{{item.cityDistrict}}">
          <text class="job-info-label">地点：</text>
          <text class="job-info-value">{{item.cityDistrict}}</text>
        </view>
      </view>

      <text class="post-desc" wx:if="{{item.typeKey !== 'job' && item.desc}}">{{item.desc}}</text>

      <view class="reject-box" wx:if="{{item.rejectReason}}">
        <text class="reject-text">驳回原因：{{item.rejectReason}}</text>
      </view>

      <view class="post-meta">
        <text class="meta-item">发布：{{item.publishTime}}</text>
        <text class="meta-item" wx:if="{{item.expireTime && !item.expired}}">有效期至：{{item.expireTime}}</text>
        <text class="meta-item" wx:if="{{item.expired}}">已过期：{{item.expireTime}}</text>
        <text class="meta-item meta-views" wx:if="{{item.views > 0}}">{{item.views}}次浏览</text>
      </view>

      <view class="post-actions">
        <button
          wx:if="{{item.typeKey === 'job'}}"
          class="act-btn act-gold act-btn-main"
          data-id="{{item.id}}"
          data-tab="{{item.primaryActionTab}}"
          bindtap="onManageJob"
        >{{item.primaryActionText || '查看报名'}}</button>
        <button
          wx:else
          class="act-btn act-blue act-btn-main"
          data-id="{{item.id}}"
          data-type="{{item.typeKey}}"
          bindtap="onViewPost"
        >{{item.primaryActionText || '查看详情'}}</button>

        <view class="post-actions-secondary">
          <button
            class="act-btn act-blue"
            wx:if="{{item.showDetailAction}}"
            data-id="{{item.id}}"
            data-type="{{item.typeKey}}"
            bindtap="onViewPost"
          >{{item.detailActionText}}</button>
          <button
            class="act-btn act-orange"
            wx:if="{{item.showPromoteAction}}"
            data-id="{{item.id}}"
            data-type="{{item.typeKey}}"
            bindtap="onDirectPromote"
          >{{item.promoteActionText}}</button>
        </view>
      </view>
    </view>
  </view>

  <empty-state wx:if="{{posts.length === 0}}" text="暂无发布记录" subText="去发布第一条信息吧" />
</view>

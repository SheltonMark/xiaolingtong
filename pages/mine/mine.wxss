.mine-page {
  min-height: 100vh;
  background-color: #F8FAFC;
  padding-bottom: 140rpx;
}

/* ===== 头部 ===== */
.header {
  padding: 0 32rpx 32rpx;
}
.header-enterprise {
  background: linear-gradient(180deg, #EFF6FF 0%, #F8FAFC 100%);
}
.header-worker {
  background: linear-gradient(180deg, #FFF7ED 0%, #F8FAFC 100%);
}
.header-top {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  min-height: 64rpx;
  overflow: visible;
}
.header-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1E293B;
}
.settings-icon {
  font-size: 44rpx;
  color: #1E293B;
  font-weight: bold;
  padding: 8rpx;
  line-height: 1;
  min-width: 48rpx;
  min-height: 48rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  align-self: flex-start;
}

/* ===== 用户信息 ===== */
.user-info {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
}
.avatar-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  flex-shrink: 0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}
.user-detail {
  flex: 1;
  min-width: 0;
  margin-top: 12rpx;
}
.user-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.user-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #1E293B;
  line-height: 1.2;
}
.cert-badge {
  font-size: 20rpx;
  background-color: #10B981;
  color: #ffffff;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.user-sub {
  font-size: 24rpx;
  color: #64748B;
}

/* ===== 数据卡片 ===== */
.data-card {
  margin-top: 32rpx;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.user-avatar-img {
  width: 96rpx; height: 96rpx; border-radius: 50%; flex-shrink: 0;
}
.data-card-3 .data-item {
  flex: 1;
}
.data-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.data-value {
  font-size: 40rpx;
  font-weight: 700;
}
.data-value-sm {
  font-size: 28rpx;
  font-weight: 700;
}
.data-label {
  font-size: 22rpx;
  color: #64748B;
}
.data-divider {
  width: 1rpx;
  height: 60rpx;
  background-color: #F1F5F9;
}

/* ===== 功能入口 ===== */
.func-grid {
  margin: 24rpx 24rpx 0;
  background-color: #ffffff;
  border-radius: 32rpx;
  padding: 32rpx 16rpx;
  display: flex;
  flex-wrap: wrap;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.func-item {
  width: 20%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}
.func-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.func-emoji {
  font-family: "iconfont" !important;
  font-size: 40rpx;
  color: #64748B;
}
.func-label {
  font-size: 20rpx;
  color: #64748B;
}

/* ===== Tab 区域 ===== */
.tab-section {
  margin: 24rpx 24rpx 0;
  background-color: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
}
.tab-bar-mine {
  display: flex;
  border-bottom: 1rpx solid #F1F5F9;
}
.tab-item-mine {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 26rpx;
  color: #64748B;
  position: relative;
}
.tab-active-ent {
  color: #F97316;
  font-weight: 600;
}
.tab-active-ent::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #F97316;
  border-radius: 4rpx;
}
.tab-active-worker {
  color: #3B82F6;
  font-weight: 600;
}
.tab-active-worker::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background-color: #3B82F6;
  border-radius: 4rpx;
}

/* 我的动态卡片 */
.dynamic-list {
  padding: 12rpx 20rpx 20rpx;
}
.dynamic-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 8rpx 16rpx;
}
.dynamic-head-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1E293B;
}
.dynamic-head-more {
  font-size: 22rpx;
  color: #3B82F6;
}
.dynamic-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background-color: #F8FAFC;
  margin-bottom: 16rpx;
}
.dynamic-top {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 8rpx;
}
.dynamic-type {
  font-size: 20rpx;
  padding: 4rpx 0;
  border-radius: 6rpx;
  font-weight: 500;
}
.type-blue { color: #3B82F6; background-color: #EFF6FF; }
.type-orange { color: #F97316; background-color: #FFF7ED; }
.type-green { color: #10B981; background-color: #ECFDF5; }
.type-amber { color: #F59E0B; background-color: #FFFBEB; }
.type-rose { color: #F43F5E; background-color: #FFF1F2; }
.dynamic-date { font-size: 20rpx; color: #94A3B8; }
.dynamic-title { font-size: 26rpx; color: #1E293B; font-weight: 500; display: block; margin-bottom: 8rpx; line-height: 1.45; }
.dynamic-desc {
  display: block;
  font-size: 22rpx;
  color: #64748B;
  line-height: 1.6;
  margin-bottom: 12rpx;
}
.dynamic-meta { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14rpx; }

/* 招工详情信息（我的动态） */
.job-detail-info {
  margin-bottom: 12rpx;
}
.job-info-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 8rpx;
}
.job-info-row:last-child { margin-bottom: 0; }
.job-info-label {
  font-size: 22rpx;
  color: #64748B;
  width: 80rpx;
  flex-shrink: 0;
}
.job-info-value {
  font-size: 22rpx;
  color: #1E293B;
  flex: 1;
}
.dynamic-meta-text { font-size: 20rpx; color: #94A3B8; }
.dynamic-status { font-size: 20rpx; font-weight: 500; }
.dynamic-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F1F5F9;
}
.dynamic-action {
  flex: 1;
  height: 60rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 500;
}
.action-view {
  color: #3B82F6;
  background-color: #EFF6FF;
}
.action-delete {
  color: #F43F5E;
  background-color: #FFF1F2;
}

/* 我的收藏列表 */
.favorites-list {
  padding: 12rpx 20rpx 20rpx;
}
.fav-card {
  padding: 24rpx;
  border-radius: 20rpx;
  background-color: #F8FAFC;
  margin-bottom: 16rpx;
}
.fav-card[data-type="post"] {
}
.fav-card[data-type="job"] {
}
.fav-card[data-type="exposure"] {
}
.fav-card-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 8rpx;
}
.fav-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}
.fav-type-tag {
  font-size: 20rpx;
  padding: 0 6rpx;
  border-radius: 6rpx;
  font-weight: 500;
  display: inline-flex;
  align-items: center;
  height: 28rpx;
  line-height: 1;
}
.fav-type-post { color: #3B82F6; background-color: #EFF6FF; }
.fav-type-job { color: #F97316; background-color: #FFF7ED; }
.fav-type-exposure { color: #F43F5E; background-color: #FFF1F2; }
.fav-date { font-size: 20rpx; color: #94A3B8; flex-shrink: 0; white-space: nowrap; }
.fav-title {
  font-size: 26rpx;
  color: #1E293B;
  font-weight: 500;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.fav-content {
  display: block;
  font-size: 22rpx;
  color: #64748B;
  line-height: 1.6;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}
.fav-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 12rpx;
}
.fav-meta-item {
  font-size: 22rpx;
  color: #64748B;
}
.fav-images {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}
.fav-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

/* ===== 接单记录 ===== */
.applications-list {
  padding: 24rpx 32rpx;
}
.app-card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}
.card-faded {
  opacity: 0.6;
}
.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.app-header-left {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.app-company-avatar-img {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
}
.text-avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 500;
  flex-shrink: 0;
}
.app-company {
  font-size: 24rpx;
  font-weight: 500;
  color: #1E293B;
}
.status-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.status-bg-amber {
  background-color: #FFFBEB;
  color: #F59E0B;
}
.status-bg-green {
  background-color: #ECFDF5;
  color: #10B981;
}
.status-bg-gray {
  background-color: #F1F5F9;
  color: #64748B;
}
.status-bg-rose {
  background-color: #FFF1F2;
  color: #F43F5E;
}
.app-job-line {
  font-size: 26rpx;
  font-weight: 500;
  color: #1E293B;
  display: block;
  margin-bottom: 8rpx;
}
.app-location-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.location-icon {
  font-size: 22rpx;
}
.app-location {
  font-size: 20rpx;
  color: #94A3B8;
}
.app-date-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}
.date-icon {
  font-size: 22rpx;
}
.app-date {
  font-size: 20rpx;
  color: #94A3B8;
}
.app-description {
  font-size: 20rpx;
  color: #64748B;
  display: block;
  margin-bottom: 12rpx;
  line-height: 1.5;
}
.app-alert {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background-color: #FFFBEB;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}
.alert-icon {
  font-size: 24rpx;
}
.alert-text {
  font-size: 20rpx;
  color: #92400E;
  flex: 1;
}


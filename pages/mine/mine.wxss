/* 标题行样式 */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx 16rpx;
}
.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}
.section-more {
  display: flex;
  align-items: center;
  gap: 4rpx;
  font-size: 24rpx;
  color: #64748B;
  padding: 8rpx;
}
.section-more .icon-arrow-right {
  font-size: 20rpx;
}

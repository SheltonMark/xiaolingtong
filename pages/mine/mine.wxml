<!--pages/mine/mine.wxml-->
<view class="mine-page">
  <!-- ===== 企业端 ===== -->
  <view wx:if="{{userRole === 'enterprise'}}">
    <!-- 头部 -->
    <view class="header header-enterprise" style="padding-top: {{statusBarHeight}}px;">
      <!-- 标题行（与胶囊同行） -->
      <view class="header-top" style="min-height: {{menuHeight}}px; padding-left: {{menuRight}}px; padding-right: {{menuRight}}px;">
        <text class="header-label">我的</text>
      </view>
      <view class="user-info">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="user-avatar-img" mode="aspectFill" bindtap="onSettings" />
        <view wx:else class="text-avatar text-avatar-2xl" style="background-color: #3B82F6;" bindtap="onSettings">{{enterpriseInfo.avatarText}}</view>
        <view class="user-detail">
          <view class="user-name-row">
            <text class="user-name">{{certName || '鑫达贸易公司'}}</text>
            <text class="cert-badge">{{certBadge}}</text>
          </view>
          <text class="user-sub">工贸一体 · 日用百货</text>
        </view>
        <text class="settings-icon iconfont icon-shezhi" bindtap="onSettings"></text>
      </view>
      <!-- 数据卡片 -->
      <view class="data-card data-card-3">
        <view class="data-item" bindtap="onBeanRecharge">
          <text class="data-value text-cta">{{beanBalance}}</text>
          <text class="data-label">灵豆</text>
        </view>
        <view class="data-divider"></view>
        <view class="data-item" bindtap="onWallet">
          <text class="data-value text-cta">¥{{walletBalance}}</text>
          <text class="data-label">余额</text>
        </view>
        <view class="data-divider"></view>
        <view class="data-item" bindtap="onMembership">
          <text class="data-value-sm text-warm">未开通</text>
          <text class="data-label">会员中心</text>
        </view>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="func-grid">
      <view class="func-item" wx:for="{{enterpriseFuncs}}" wx:key="label"
            data-url="{{item.url}}" bindtap="onFuncTap">
        <view class="func-icon" style="background-color: {{item.bg}};">
          <text class="func-emoji" style="color: {{item.iconColor}};">{{item.icon}}</text>
        </view>
        <text class="func-label">{{item.label}}</text>
      </view>
    </view>

    <!-- Tab 内容 -->
    <view class="tab-section">
      <view class="tab-bar-mine">
        <view class="tab-item-mine {{currentTab === index ? 'tab-active-ent' : ''}}"
              wx:for="{{enterpriseTabs}}" wx:key="index"
              data-index="{{index}}" bindtap="onTabChange">
          <text>{{item}}</text>
        </view>
      </view>
      <!-- 我的动态 -->
      <view wx:if="{{currentTab === 0}}" class="dynamic-list">
        <view class="dynamic-section-head">
          <text class="dynamic-head-title">最近发布</text>
          <text class="dynamic-head-more" bindtap="onViewAllPosts">查看全部</text>
        </view>
        <view class="dynamic-card" wx:for="{{myPosts}}" wx:key="id">
          <view class="dynamic-top">
            <text class="dynamic-type type-{{item.typeColor}}">{{item.type}}</text>
            <text class="dynamic-date">{{item.date}}</text>
          </view>
          <text class="dynamic-title">{{item.title}}</text>

          <!-- 招工信息详情 -->
          <view class="job-detail-info" wx:if="{{item.typeKey === 'job'}}">
            <view class="job-info-row">
              <text class="job-info-label">工价：</text>
              <text class="job-info-value text-cta font-semibold">{{item.salary}}{{item.salaryUnit}}</text>
            </view>
            <view class="job-info-row">
              <text class="job-info-label">人数：</text>
              <text class="job-info-value">需{{item.needCount}}人 · 已报名{{item.appliedCount}}人</text>
            </view>
            <view class="job-info-row" wx:if="{{item.dateRange}}">
              <text class="job-info-label">日期：</text>
              <text class="job-info-value">{{item.dateRange}}</text>
            </view>
            <view class="job-info-row" wx:if="{{item.workHours}}">
              <text class="job-info-label">时间：</text>
              <text class="job-info-value">{{item.workHours}}</text>
            </view>
            <view class="job-info-row" wx:if="{{item.cityDistrict}}">
              <text class="job-info-label">地点：</text>
              <text class="job-info-value">{{item.cityDistrict}}</text>
            </view>
          </view>

          <!-- 其他类型描述 -->
          <text class="dynamic-desc" wx:if="{{item.typeKey !== 'job' && item.desc}}">{{item.desc}}</text>

          <view class="dynamic-meta">
            <text class="dynamic-meta-text">{{item.views}}次浏览</text>
            <text class="dynamic-status" style="color:{{item.statusColor}};">{{item.statusText}}</text>
          </view>
          <view class="dynamic-actions">
            <view class="dynamic-action action-view" data-id="{{item.id}}" data-type="{{item.typeKey}}" catchtap="onTapPost">查看</view>
            <view class="dynamic-action action-delete" data-id="{{item.id}}" catchtap="onDeletePost">删除</view>
          </view>
        </view>
        <empty-state wx:if="{{myPosts.length === 0}}" text="暂无发布记录" subText="去发布第一条信息吧~" />
      </view>
      <!-- 我的收藏 -->
      <view wx:if="{{currentTab === 1}}" class="favorites-list">
        <view class="fav-card" wx:for="{{favorites}}" wx:key="id"
              data-id="{{item.id}}" data-type="{{item.targetType}}" bindtap="onTapFavorite">
          <view class="dynamic-top">
            <text class="fav-type-tag fav-type-{{item.targetType}}">{{item.targetType === 'post' ? '供需' : item.targetType === 'job' ? '招工' : '曝光'}}</text>
            <text class="fav-date">{{item.createdAt.substring(0, 10)}}</text>
          </view>
          <text class="dynamic-title">{{item.title}}</text>
          <text class="fav-content" wx:if="{{item.content}}">{{item.content}}</text>
          <view class="fav-meta" wx:if="{{item.targetType === 'job'}}">
            <text class="fav-meta-item text-cta font-semibold">{{item.salary}}{{item.salaryUnit}}</text>
            <text class="fav-meta-item">需{{item.needCount}}人</text>
            <text class="fav-meta-item">{{item.location}}</text>
          </view>
          <view class="fav-images" wx:if="{{item.images && item.images.length > 0}}">
            <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"
                   src="{{img}}" mode="aspectFill" class="fav-img" />
          </view>
        </view>
        <empty-state wx:if="{{favorites.length === 0}}" text="暂无收藏" subText="去浏览信息收藏感兴趣的内容吧~" />
      </view>
    </view>
  </view>

  <!-- ===== 临工端 ===== -->
  <view wx:if="{{userRole === 'worker'}}">
    <!-- 头部 -->
    <view class="header header-worker" style="padding-top: {{statusBarHeight}}px;">
      <!-- 标题行（与胶囊同行） -->
      <view class="header-top" style="min-height: {{menuHeight}}px; padding-left: {{menuRight}}px; padding-right: {{menuRight}}px;">
        <text class="header-label">我的</text>
      </view>
      <view class="user-info">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="user-avatar-img" mode="aspectFill" bindtap="onSettings" />
        <view wx:else class="text-avatar text-avatar-2xl" style="background-color: #F97316;" bindtap="onSettings">{{workerInfo.avatarText}}</view>
        <view class="user-detail">
          <view class="user-name-row">
            <text class="user-name">{{certName || '张三'}}</text>
            <text class="cert-badge">{{certBadge}}</text>
          </view>
          <text class="user-sub">信用分 <text class="text-cta font-semibold">{{creditScore}}</text> · 组装工/包装工</text>
        </view>
        <text class="settings-icon iconfont icon-shezhi" bindtap="onSettings"></text>
      </view>
      <!-- 数据卡片 -->
      <view class="data-card data-card-3">
        <view class="data-item" bindtap="onWallet">
          <text class="data-value text-cta">¥{{walletBalance}}</text>
          <text class="data-label">钱包余额</text>
        </view>
        <view class="data-divider"></view>
        <view class="data-item">
          <text class="data-value text-primary">50</text>
          <text class="data-label">累计接单</text>
        </view>
        <view class="data-divider"></view>
        <view class="data-item">
          <text class="data-value text-warm">{{creditScore}}</text>
          <text class="data-label">信用分</text>
        </view>
      </view>
    </view>

    <!-- 功能入口 -->
    <view class="func-grid">
      <view class="func-item" wx:for="{{workerFuncs}}" wx:key="label"
            data-url="{{item.url}}" bindtap="onFuncTap">
        <view class="func-icon" style="background-color: {{item.bg}};">
          <text class="func-emoji" style="color: {{item.iconColor}};">{{item.icon}}</text>
        </view>
        <text class="func-label">{{item.label}}</text>
      </view>
    </view>

    <!-- Tab 内容 -->
    <view class="tab-section">
      <view class="tab-bar-mine">
        <view class="tab-item-mine {{currentTab === index ? 'tab-active-worker' : ''}}"
              wx:for="{{workerTabs}}" wx:key="index"
              data-index="{{index}}" bindtap="onTabChange">
          <text>{{item}}</text>
        </view>
      </view>
      <!-- 接单记录 -->
      <view wx:if="{{currentTab === 0}}" class="applications-list">
        <view class="app-card {{item.status === 'rejected' ? 'card-faded' : ''}}" wx:for="{{myApplications}}" wx:key="id"
              data-id="{{item.jobId}}" bindtap="onViewJobDetail">
          <!-- 头部 -->
          <view class="app-header">
            <view class="app-header-left">
              <view class="text-avatar" style="width:48rpx;height:48rpx;font-size:20rpx;background-color:#10B981;">{{item.company[0]}}</view>
              <text class="app-company">{{item.company}}</text>
            </view>
            <view class="status-tag status-bg-{{item.statusBg}}">
              <text>{{item.statusText}}</text>
            </view>
          </view>
          <!-- 岗位+薪资 -->
          <text class="app-job-line">{{item.title}} · <text class="text-cta">{{item.salary}}</text></text>
          <!-- 地点 -->
          <view class="app-location-row">
            <text class="location-icon">📍</text>
            <text class="app-location">{{item.location}}</text>
          </view>
          <!-- 日期 -->
          <view class="app-date-row">
            <text class="date-icon">📅</text>
            <text class="app-date">{{item.date}}</text>
            <text class="app-date" wx:if="{{item.hours}}"> · {{item.hours}}</text>
          </view>
          <!-- 工作描述 -->
          <text class="app-description" wx:if="{{item.description}}">{{item.description}}</text>
          <!-- 提醒 -->
          <view class="app-alert" wx:if="{{item.alert}}">
            <text class="alert-icon">⏱</text>
            <text class="alert-text">{{item.alert}}</text>
          </view>
        </view>
        <empty-state wx:if="{{myApplications.length === 0}}" text="暂无记录" subText="快去报名接单吧~" />
      </view>
      <!-- 我的收藏 -->
      <view wx:if="{{currentTab === 1}}" class="favorites-list">
        <view class="fav-card" wx:for="{{favorites}}" wx:key="id"
              data-id="{{item.id}}" data-type="{{item.targetType}}" bindtap="onTapFavorite">
          <view class="dynamic-top">
            <text class="fav-type-tag fav-type-{{item.targetType}}">{{item.targetType === 'post' ? '供需' : item.targetType === 'job' ? '招工' : '曝光'}}</text>
            <text class="fav-date">{{item.createdAt.substring(0, 10)}}</text>
          </view>
          <text class="dynamic-title">{{item.title}}</text>
          <text class="fav-content" wx:if="{{item.content}}">{{item.content}}</text>
          <view class="fav-meta" wx:if="{{item.targetType === 'job'}}">
            <text class="fav-meta-item text-cta font-semibold">{{item.salary}}{{item.salaryUnit}}</text>
            <text class="fav-meta-item">需{{item.needCount}}人</text>
            <text class="fav-meta-item">{{item.location}}</text>
          </view>
          <view class="fav-images" wx:if="{{item.images && item.images.length > 0}}">
            <image wx:for="{{item.images}}" wx:for-item="img" wx:key="*this"
                   src="{{img}}" mode="aspectFill" class="fav-img" />
          </view>
        </view>
        <empty-state wx:if="{{favorites.length === 0}}" text="暂无收藏" subText="去浏览信息收藏感兴趣的内容吧~" />
      </view>
    </view>
  </view>
</view>

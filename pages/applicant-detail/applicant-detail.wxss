/* pages/applicant-detail/applicant-detail.wxss */

.applicant-detail-page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

.detail-container {
  padding: 0 20rpx;
}

/* 分组样式 */
.section {
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 16rpx 0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e5e7eb;
}

/* 基本信息卡片 */
.info-card {
  display: flex;
  align-items: center;
}

.avatar-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #e5e7eb;
  flex-shrink: 0;
}

.info-text {
  flex: 1;
}

.name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.phone,
.location {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 4rpx;
}

/* 资质信息网格 */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.stat-item {
  background-color: #f9fafb;
  padding: 12rpx;
  border-radius: 8rpx;
  text-align: center;
}

.stat-label {
  font-size: 22rpx;
  color: #9ca3af;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
}

/* 工作记录 */
.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.record-item:last-child {
  border-bottom: none;
}

.record-label {
  font-size: 24rpx;
  color: #6b7280;
}

.record-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
}

/* 认证信息 */
.cert-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.cert-item:last-child {
  border-bottom: none;
}

.cert-label {
  font-size: 24rpx;
  color: #6b7280;
}

.cert-value {
  font-size: 24rpx;
  color: #1f2937;
}

.status-approved {
  color: #10b981;
  font-weight: 600;
}

.status-pending {
  color: #f59e0b;
  font-weight: 600;
}

/* 信息项 */
.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #e5e7eb;
}

.info-item:last-child {
  border-bottom: none;
}

.label {
  font-size: 24rpx;
  color: #6b7280;
}

.value {
  font-size: 24rpx;
  color: #1f2937;
  font-weight: 500;
}

/* 主管资格 */
.supervisor-info {
  text-align: center;
  padding: 16rpx;
  background-color: #fef3c7;
  border-radius: 8rpx;
}

.badge {
  display: inline-block;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.desc {
  display: block;
  font-size: 22rpx;
  color: #92400e;
}

/* 操作按钮 */
.action-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 0;
}

.action-btn {
  padding: 16rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.2s ease;
}

.btn-supervisor {
  background-color: #10b981;
  color: white;
}

.btn-supervisor:active {
  background-color: #059669;
  opacity: 0.9;
}

.btn-back {
  background-color: #e5e7eb;
  color: #1f2937;
}

.btn-back:active {
  background-color: #d1d5db;
  opacity: 0.9;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #e5e7eb;
  border-top-color: #3b82f6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 错误状态 */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 400rpx;
  padding: 20rpx;
}

.error-text {
  font-size: 24rpx;
  color: #ef4444;
  text-align: center;
  margin-bottom: 20rpx;
}

.error-btn {
  padding: 12rpx 24rpx;
  background-color: #3b82f6;
  color: white;
  border-radius: 8rpx;
  font-size: 24rpx;
  text-align: center;
}

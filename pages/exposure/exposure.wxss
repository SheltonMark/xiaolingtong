.exp-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #eff6ff 0%, #f8fafc 240rpx, #f8fafc 100%);
  padding-bottom: 40rpx;
}

.notice-card {
  margin: 24rpx 32rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ffffff 0%, #eff6ff 100%);
  border: 2rpx solid #dbeafe;
}

.notice-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
  margin-bottom: 10rpx;
}

.notice-text {
  font-size: 22rpx;
  color: #475569;
  line-height: 1.7;
}

.form-card {
  margin: 24rpx 32rpx 0;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.04);
}

.form-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
  display: block;
}

.required::before {
  content: '*';
  color: #2563eb;
  margin-right: 4rpx;
}

.label-hint {
  font-weight: 400;
  color: #94a3b8;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background-color: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #1e293b;
  box-sizing: border-box;
}

.form-input-plain {
  flex: 1;
  border: none;
  background: transparent;
}

.form-textarea {
  width: 100%;
  height: 260rpx;
  background-color: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  font-size: 24rpx;
  color: #1e293b;
  box-sizing: border-box;
}

.form-tip {
  display: block;
  margin-top: 12rpx;
  font-size: 20rpx;
  line-height: 1.6;
  color: #64748b;
}

.category-grid {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.category-item {
  width: calc((100% - 32rpx) / 3);
  min-height: 148rpx;
  border-radius: 20rpx;
  border: 2rpx solid #e2e8f0;
  background-color: #f8fafc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-sizing: border-box;
}

.category-item-active {
  border-color: #60a5fa;
  background: linear-gradient(135deg, #dbeafe 0%, #eff6ff 100%);
}

.category-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #bfdbfe;
  color: #1d4ed8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.category-text {
  font-size: 22rpx;
  color: #334155;
  text-align: center;
}

.input-with-prefix {
  display: flex;
  align-items: center;
  background-color: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  overflow: hidden;
}

.input-prefix {
  font-size: 24rpx;
  color: #64748b;
  padding: 0 24rpx;
  background-color: #f1f5f9;
  height: 72rpx;
  line-height: 72rpx;
  border-right: 2rpx solid #e2e8f0;
  flex-shrink: 0;
}

.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.image-item {
  width: 128rpx;
  height: 128rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.upload-img {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  background-color: rgba(15, 23, 42, 0.6);
  color: #fff;
  font-size: 20rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.image-add {
  width: 128rpx;
  height: 128rpx;
  border: 4rpx dashed #bfdbfe;
  border-radius: 16rpx;
  background-color: #f8fbff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.add-icon {
  font-size: 40rpx;
  color: #60a5fa;
}

.add-text {
  font-size: 18rpx;
  color: #64748b;
}

.agree-row {
  margin: 24rpx 32rpx 0;
  display: flex;
  gap: 16rpx;
  align-items: flex-start;
}

.agree-check {
  width: 32rpx;
  height: 32rpx;
  border: 4rpx solid #cbd5e1;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.agree-checked {
  background-color: #2563eb;
  border-color: #2563eb;
}

.agree-tick {
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
}

.agree-text {
  font-size: 20rpx;
  color: #475569;
  line-height: 1.7;
}

.submit-area {
  margin: 24rpx 32rpx 0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 9999rpx;
  border: none;
}

.submit-btn::after {
  border: none;
}

<view class="exp-page">
  <nav-bar title="分享维权经历" />

  <view class="notice-card">
    <text class="notice-title">分享前请确认</text>
    <text class="notice-text">仅可分享本人真实维权经历、协商过程和结果反馈，禁止指名道姓描述第三方，内容提交后需人工审核并通过内容安全校验。</text>
  </view>

  <view class="form-card">
    <text class="form-label required">经历类型</text>
    <view class="category-grid">
      <view
        class="category-item {{form.category === item.key ? 'category-item-active' : ''}}"
        wx:for="{{categories}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="onSelectCategory"
      >
        <text class="category-avatar">{{item.avatarText}}</text>
        <text class="category-text">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="form-card">
    <text class="form-label">涉及金额 <text class="label-hint">(选填)</text></text>
    <view class="input-with-prefix">
      <text class="input-prefix">¥</text>
      <input
        class="form-input form-input-plain"
        type="digit"
        placeholder="如有金额损失可填写"
        data-field="amount"
        bindinput="onInput"
      />
    </view>
  </view>

  <view class="form-card">
    <text class="form-label required">经历描述</text>
    <textarea
      class="form-textarea"
      maxlength="1000"
      show-confirm-bar="{{false}}"
      placeholder="请用第一人称描述你的维权经过、沟通方式和结果反馈。禁止填写第三方姓名、公司、电话、微信等可识别信息。"
      data-field="description"
      bindinput="onInput"
    />
    <text class="form-tip">建议写清时间线、你采取的措施以及最终结果，方便其他用户参考。</text>
  </view>

  <view class="form-card">
    <text class="form-label">辅助材料 <text class="label-hint">(选填，最多9张)</text></text>
    <view class="image-grid">
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="upload-img" />
        <view class="image-delete" data-index="{{index}}" catchtap="onDeleteImage">×</view>
      </view>
      <view class="image-add" bindtap="onChooseImage" wx:if="{{images.length < 9}}">
        <text class="add-icon">+</text>
        <text class="add-text">添加图片</text>
      </view>
    </view>
  </view>

  <view class="agree-row" bindtap="onToggleAgree">
    <view class="agree-check {{agreed ? 'agree-checked' : ''}}">
      <text wx:if="{{agreed}}" class="agree-tick">✓</text>
    </view>
    <text class="agree-text">我确认分享的是本人真实维权经历，不包含第三方可识别信息，内容将经人工审核和内容安全校验后展示。</text>
  </view>

  <view class="submit-area">
    <button class="submit-btn" bindtap="onSubmit" loading="{{submitting}}" disabled="{{submitting || isUploading}}">提交分享</button>
  </view>
</view>

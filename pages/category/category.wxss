.category-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #FAFBFC 0%, #F5F7FA 100%);
  padding-bottom: 140rpx;
}

.search-wrap {
  padding: 24rpx 24rpx 20rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: linear-gradient(135deg, #F8F9FA 0%, #F3F5F8 100%);
  border-radius: 12rpx;
  padding: 14rpx 20rpx;
  border: 1rpx solid #E8EAEF;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.search-input-wrap:focus-within {
  border-color: #667eea;
  box-shadow: 0 0 0 3rpx rgba(102, 126, 234, 0.1);
}

.search-icon {
  font-size: 28rpx;
  color: #94A3B8;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #1E293B;
  background: transparent;
}

.search-input::placeholder {
  color: #CBD5E1;
}

/* 搜索结果样式 */
.search-results {
  padding: 24rpx 0;
}

.results-header {
  padding: 0 24rpx 20rpx;
  border-bottom: 1rpx solid #E2E8F0;
  margin-bottom: 16rpx;
}

.results-header-content {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.results-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #0F172A;
  letter-spacing: -0.5rpx;
}

.results-count {
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 500;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 0 16rpx;
}

.result-item {
  animation: slideUp 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  opacity: 0;
}

.result-item:nth-child(1) { animation-delay: 0.05s; }
.result-item:nth-child(2) { animation-delay: 0.1s; }
.result-item:nth-child(3) { animation-delay: 0.15s; }
.result-item:nth-child(4) { animation-delay: 0.2s; }
.result-item:nth-child(5) { animation-delay: 0.25s; }
.result-item:nth-child(n+6) { animation-delay: 0.3s; }

@keyframes slideUp {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.result-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  border: 1rpx solid #E8EAEF;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.02);
}

.result-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.result-card:hover {
  border-color: #D1D5DB;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transform: translateY(-2rpx);
}

.card-avatar-section {
  flex-shrink: 0;
}

.card-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.2);
}

.card-content-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.card-header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.card-title {
  font-size: 26rpx;
  color: #0F172A;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.card-time {
  font-size: 22rpx;
  color: #94A3B8;
  flex-shrink: 0;
  white-space: nowrap;
}

.card-content {
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  word-break: break-word;
}

.card-arrow {
  flex-shrink: 0;
  font-size: 20rpx;
  color: #CBD5E1;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.result-card:hover .card-arrow {
  color: #667eea;
  transform: translateX(4rpx);
}

/* 筛选条件样式 */
.filter-section {
  padding: 24rpx 32rpx;
}

.filter-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 20rpx;
}

.filter-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.filter-tag {
  padding: 12rpx 28rpx;
  background-color: #F1F5F9;
  border-radius: 9999rpx;
  font-size: 24rpx;
  color: #64748B;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1rpx solid transparent;
}

.filter-tag:active {
  transform: scale(0.95);
}

.filter-tag-active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

/* 底部按钮 */
.bottom-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 48rpx;
  background: linear-gradient(180deg, #FFFFFF 0%, #F8F9FA 100%);
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.06);
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  backdrop-filter: blur(10rpx);
}

.btn {
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 600;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  border: none;
  padding: 16rpx 0;
}

.btn-outline {
  background-color: #F1F5F9;
  color: #64748B;
  border: 1rpx solid #E2E8F0;
}

.btn-outline:active {
  background-color: #E2E8F0;
  transform: scale(0.98);
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(102, 126, 234, 0.2);
}


<!--pages/category/category.wxml-->
<view class="category-page">
  <nav-bar title="筛选" />
  <!-- 搜索框 -->
  <view class="search-wrap">
    <view class="search-input-wrap">
      <text class="search-icon iconfont icon-sousuo"></text>
      <input class="search-input" placeholder="搜索关键词" value="{{keyword}}" bindinput="onInput" bindconfirm="onSearch" />
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{searchResults.length > 0}}" class="search-results">
    <view class="results-header">
      <view class="results-header-content">
        <text class="results-title">搜索结果</text>
        <text class="results-count">{{searchResults.length}} 条</text>
      </view>
    </view>
    <view class="results-list">
      <view class="result-item" wx:for="{{searchResults}}" wx:key="id" bindtap="onCardTap" data-id="{{item.id}}">
        <view class="result-card">
          <!-- 左侧头像 -->
          <view class="card-avatar-section">
            <view class="card-avatar" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
              {{item.avatarText}}
            </view>
          </view>

          <!-- 中间内容 -->
          <view class="card-content-section">
            <view class="card-header-row">
              <text class="card-title">{{item.companyName}}</text>
              <text class="card-time">{{item.time}}</text>
            </view>
            <text class="card-content">{{item.content}}</text>
          </view>

          <!-- 右侧箭头 -->
          <view class="card-arrow">
            <text class="iconfont icon-youjiantou"></text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 筛选条件（搜索结果为空时显示） -->
  <view wx:if="{{searchResults.length === 0}}">
    <!-- 品类 -->
    <view class="filter-section">
      <text class="filter-title">品类</text>
      <view class="filter-tags">
        <view class="filter-tag {{categoryIndex === index ? 'filter-tag-active' : ''}}"
              wx:for="{{categories}}" wx:key="index"
              data-index="{{index}}" bindtap="onCategoryTap">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 地区 -->
    <view class="filter-section">
      <text class="filter-title">地区</text>
      <view class="filter-tags">
        <view class="filter-tag {{cityIndex === index ? 'filter-tag-active' : ''}}"
              wx:for="{{cities}}" wx:key="index"
              data-index="{{index}}" bindtap="onCityTap">
          <text>{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 排序 -->
    <view class="filter-section">
      <text class="filter-title">排序</text>
      <view class="filter-tags">
        <view class="filter-tag {{sortIndex === index ? 'filter-tag-active' : ''}}"
              wx:for="{{sorts}}" wx:key="index"
              data-index="{{index}}" bindtap="onSortTap">
          <text>{{item}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-btns">
    <button class="btn btn-outline" style="flex:1;" bindtap="onReset">重置</button>
    <button class="btn btn-primary" style="flex:1;" bindtap="{{searchResults.length > 0 ? 'onConfirm' : 'onSearch'}}">{{searchResults.length > 0 ? '确认' : '搜索'}}</button>
  </view>
</view>

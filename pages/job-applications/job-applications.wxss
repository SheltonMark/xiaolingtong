/* pages/job-applications/job-applications.wxss */

.job-applications-page {
  background-color: #f5f5f5;
  min-height: 100vh;
  padding-bottom: 20rpx;
}

/* 招工基本信息 */
.job-header {
  background-color: #fff;
  padding: 20rpx;
  margin: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.job-header-top {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  margin-bottom: 16rpx;
}

.job-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  flex: 1;
}

.status-tag {
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
  margin-left: 12rpx;
}

.status-bg-green {
  background-color: #d1fae5;
  color: #065f46;
}

.status-bg-amber {
  background-color: #fef3c7;
  color: #92400e;
}

.status-bg-gray {
  background-color: #f3f4f6;
  color: #6b7280;
}

.job-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 26rpx;
  color: #6b7280;
}

.job-info-label {
  color: #9ca3af;
  margin-right: 8rpx;
  min-width: 80rpx;
}

.job-info-value {
  color: #1f2937;
}

.text-cta {
  color: #10b981;
}

.font-semibold {
  font-weight: 600;
}

/* 应用状态分类 */
.applications-section {
  padding: 0 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 20rpx 0 16rpx 0;
  padding: 0 0 12rpx 0;
  border-bottom: 2rpx solid #e5e7eb;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-count {
  font-size: 24rpx;
  color: #9ca3af;
}

/* 状态分组 */
.status-group {
  margin-bottom: 24rpx;
}

.status-group-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
  padding: 12rpx 16rpx;
  background-color: #f9fafb;
  border-radius: 8rpx;
}

.status-group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  flex: 1;
}

.status-group-count {
  font-size: 24rpx;
  color: #9ca3af;
  background-color: #e5e7eb;
  padding: 4rpx 8rpx;
  border-radius: 4rpx;
}

/* 应用项 */
.application-item {
  display: flex;
  flex-direction: column;
  background-color: #fff;
  padding: 16rpx;
  margin-bottom: 12rpx;
  border-radius: 8rpx;
  border: 1rpx solid #e5e7eb;
}

.app-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.worker-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.worker-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.supervisor-badge {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: white;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  white-space: nowrap;
}

.worker-rating {
  font-size: 24rpx;
  color: #f59e0b;
  margin-left: 12rpx;
}

.rating-stars {
  display: inline-block;
}

.worker-detail {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 12rpx;
}

.detail-item {
  display: inline-block;
}

.detail-time {
  color: #999;
  font-size: 22rpx;
  width: 100%;
}

/* 操作按钮 */
.app-actions {
  display: flex;
  gap: 8rpx;
  justify-content: flex-end;
}

.action-btn {
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all 0.2s ease;
}

.btn-accept {
  background-color: #10b981;
  color: #fff;
}

.btn-accept:active {
  background-color: #059669;
  opacity: 0.9;
}

.btn-detail {
  background-color: #3b82f6;
  color: #fff;
}

.btn-detail:active {
  background-color: #2563eb;
  opacity: 0.9;
}

.btn-reject {
  background-color: #ef4444;
  color: #fff;
}

.btn-reject:active {
  background-color: #dc2626;
  opacity: 0.9;
}

/* 状态徽章 */
.app-status {
  display: flex;
  justify-content: flex-end;
}

.status-badge {
  display: inline-block;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-accepted {
  background-color: #dbeafe;
  color: #1e40af;
}

.status-confirmed {
  background-color: #d1fae5;
  color: #065f46;
}

.status-rejected {
  background-color: #fee2e2;
  color: #991b1b;
}

/* 搜索栏 */
.search-bar {
  padding: 12rpx 0;
  margin-bottom: 12rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f3f4f6;
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  gap: 8rpx;
}

.search-icon {
  font-size: 20rpx;
  color: #9ca3af;
}

.search-input {
  flex: 1;
  background: transparent;
  border: none;
  font-size: 24rpx;
  color: #1f2937;
  outline: none;
}

.search-input::placeholder {
  color: #d1d5db;
}

.clear-btn {
  font-size: 20rpx;
  color: #9ca3af;
  padding: 4rpx 8rpx;
}

/* 筛选和排序栏 */
.filter-sort-bar {
  display: flex;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.filter-btn,
.sort-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 10rpx 12rpx;
  background-color: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #374151;
  font-weight: 500;
}

.filter-btn:active,
.sort-btn:active {
  background-color: #f9fafb;
}

.dropdown-icon {
  font-size: 16rpx;
  color: #9ca3af;
}

/* 筛选菜单 */
.filter-menu {
  background-color: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.filter-option {
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: #374151;
  border-bottom: 1rpx solid #e5e7eb;
  transition: all 0.2s ease;
}

.filter-option:last-child {
  border-bottom: none;
}

.filter-option:active {
  background-color: #f9fafb;
}

.filter-option.active {
  background-color: #dbeafe;
  color: #1e40af;
  font-weight: 600;
}

/* 排序菜单 */
.sort-menu {
  background-color: #fff;
  border: 1rpx solid #e5e7eb;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.sort-option {
  padding: 12rpx 16rpx;
  font-size: 24rpx;
  color: #374151;
  border-bottom: 1rpx solid #e5e7eb;
  transition: all 0.2s ease;
}

.sort-option:last-child {
  border-bottom: none;
}

.sort-option:active {
  background-color: #f9fafb;
}

.sort-option.active {
  background-color: #dbeafe;
  color: #1e40af;
  font-weight: 600;
}


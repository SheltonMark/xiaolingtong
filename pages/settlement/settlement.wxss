.settlement-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.12), transparent 30%),
    linear-gradient(180deg, #F7F9FC 0%, #F4F7FB 100%);
  padding-bottom: 40rpx;
}

.shell-loading {
  margin: 120rpx 24rpx 0;
  padding: 40rpx 32rpx;
  border-radius: 32rpx;
  background-color: rgba(255, 255, 255, 0.94);
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.06);
  text-align: center;
}

.shell-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #0F172A;
}

.shell-sub {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.7;
}

.shell-actions {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.settlement-shell {
  min-height: 100vh;
  background:
    radial-gradient(circle at top right, rgba(37, 99, 235, 0.12), transparent 32%),
    linear-gradient(180deg, #F7F9FC 0%, #F3F6FB 100%);
  padding-bottom: 40rpx;
}

.hub-page {
  padding: 28rpx 24rpx 40rpx;
}

.hub-hero,
.shell-loading,
.hub-panel {
  background-color: rgba(255, 255, 255, 0.94);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 44rpx rgba(15, 23, 42, 0.06);
}

.hub-hero {
  padding: 36rpx 32rpx;
  margin-bottom: 24rpx;
}

.hub-kicker {
  display: block;
  font-size: 22rpx;
  color: #2563EB;
  letter-spacing: 2rpx;
}

.hub-title,
.shell-title {
  display: block;
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #0F172A;
}

.hub-sub,
.shell-sub {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.7;
}

.shell-loading {
  margin: 120rpx 24rpx 0;
  padding: 40rpx 32rpx;
  text-align: center;
}

.hub-panel {
  padding: 28rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0F172A;
}

.section-meta {
  font-size: 22rpx;
  color: #94A3B8;
}

.record-card,
.loading-card {
  border-radius: 24rpx;
  background: #F8FAFC;
  border: 1rpx solid rgba(148, 163, 184, 0.16);
}

.record-card {
  padding: 24rpx;
}

.record-card + .record-card,
.loading-card + .loading-card {
  margin-top: 20rpx;
}

.record-card-hover {
  transform: scale(0.995);
  opacity: 0.96;
}

.record-top,
.record-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.record-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #0F172A;
}

.record-badge {
  flex-shrink: 0;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.badge-amber {
  color: #B45309;
  background: rgba(245, 158, 11, 0.14);
}

.badge-blue {
  color: #1D4ED8;
  background: rgba(59, 130, 246, 0.14);
}

.badge-green {
  color: #047857;
  background: rgba(16, 185, 129, 0.14);
}

.badge-slate {
  color: #475569;
  background: rgba(148, 163, 184, 0.16);
}

.badge-sky {
  color: #0369A1;
  background: rgba(14, 165, 233, 0.14);
}

.record-subtitle {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #475569;
  line-height: 1.6;
}

.record-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #64748B;
  line-height: 1.7;
}

.record-footer {
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.14);
}

.record-action {
  font-size: 24rpx;
  color: #2563EB;
  font-weight: 600;
}

.record-arrow {
  font-size: 26rpx;
  color: #94A3B8;
}

.loading-card {
  padding: 24rpx;
}

.loading-line {
  height: 20rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(226, 232, 240, 0.9), rgba(241, 245, 249, 1));
}

.loading-line-lg {
  width: 60%;
  margin-top: 0;
  height: 28rpx;
}

.loading-line-sm {
  width: 36%;
}

.shell-actions {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

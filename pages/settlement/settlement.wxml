<view class="settlement-shell">
  <nav-bar title="{{pageTitle}}" />

  <view class="shell-loading" wx:if="{{redirecting}}">
    <text class="shell-title">正在跳转到统一工作流页…</text>
    <text class="shell-sub">结算页已并入用工流程页，系统正在为你打开对应工单。</text>
  </view>

  <empty-state
    wx:else
    text="请从具体工单进入结算"
    subText="当前入口缺少 jobId，无法直接定位到结算单。你可以回到“我的发布 / 用工记录 / 通知”重新进入。"
  >
    <view class="shell-actions">
      <button class="btn btn-primary" wx:if="{{targetUrl}}" bindtap="onOpenWorkflow">重新打开工作流</button>
      <button class="btn btn-outline" bindtap="onBackMine">返回我的</button>
    </view>
  </empty-state>
</view>

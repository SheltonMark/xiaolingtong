<!--pages/settlement/settlement.wxml-->
<view class="st-page">
  <nav-bar title="结算" />

  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 0 ? 'active' : ''}}" data-index="0" bindtap="onTabChange">
      <text>招工管理</text>
    </view>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" data-index="1" bindtap="onTabChange">
      <text>工资结算</text>
    </view>
  </view>

  <!-- Tab 1: 招工管理 -->
  <view class="tab-content" wx:if="{{activeTab === 0}}">
    <!-- 工作信息 -->
    <view class="st-card" wx:if="{{job.id}}">
      <view class="job-header">
        <text class="job-title">{{job.title}}</text>
        <text class="job-status">{{job.status}}</text>
      </view>
      <view class="job-info">
        <view class="info-row">
          <text class="label">招工人数:</text>
          <text class="value">{{job.needCount}}</text>
        </view>
        <view class="info-row">
          <text class="label">工作日期:</text>
          <text class="value">{{job.dateStart}} ~ {{job.dateEnd}}</text>
        </view>
        <view class="info-row">
          <text class="label">工作时间:</text>
          <text class="value">{{job.workHours}}</text>
        </view>
        <view class="info-row">
          <text class="label">工资:</text>
          <text class="value">¥{{job.salary}}/{{job.salaryUnit}}</text>
        </view>
      </view>
    </view>

    <!-- 应用列表 -->
    <view class="st-card" wx:if="{{applications}}">
      <text class="card-title">应用管理</text>

      <!-- 待审核 -->
      <view class="app-section" wx:if="{{applications.pending && applications.pending.length > 0}}">
        <text class="section-title">待审核 ({{applications.pending.length}})</text>
        <view class="app-item" wx:for="{{applications.pending}}" wx:key="id">
          <view class="app-info">
            <text class="worker-name">{{item.workerName}}</text>
            <text class="worker-phone">{{item.workerPhone}}</text>
          </view>
          <view class="app-meta">
            <text class="credit">信用分: {{item.workerCredit}}</text>
            <text class="orders">订单数: {{item.workerOrders}}</text>
          </view>
        </view>
      </view>

      <!-- 已接受 -->
      <view class="app-section" wx:if="{{applications.accepted && applications.accepted.length > 0}}">
        <text class="section-title">已接受 ({{applications.accepted.length}})</text>
        <view class="app-item" wx:for="{{applications.accepted}}" wx:key="id">
          <view class="app-info">
            <text class="worker-name">{{item.workerName}}</text>
            <text class="worker-phone">{{item.workerPhone}}</text>
          </view>
          <view class="app-meta">
            <text class="credit">信用分: {{item.workerCredit}}</text>
            <text class="orders">订单数: {{item.workerOrders}}</text>
          </view>
        </view>
      </view>

      <!-- 已确认 -->
      <view class="app-section" wx:if="{{applications.confirmed && applications.confirmed.length > 0}}">
        <text class="section-title">已确认 ({{applications.confirmed.length}})</text>
        <view class="app-item" wx:for="{{applications.confirmed}}" wx:key="id">
          <view class="app-info">
            <text class="worker-name">{{item.workerName}}</text>
            <text class="worker-phone">{{item.workerPhone}}</text>
          </view>
          <view class="app-meta">
            <text class="credit">信用分: {{item.workerCredit}}</text>
            <text class="orders">订单数: {{item.workerOrders}}</text>
          </view>
        </view>
      </view>

      <!-- 工作中 -->
      <view class="app-section" wx:if="{{applications.working && applications.working.length > 0}}">
        <text class="section-title">工作中 ({{applications.working.length}})</text>
        <view class="app-item" wx:for="{{applications.working}}" wx:key="id">
          <view class="app-info">
            <text class="worker-name">{{item.workerName}}</text>
            <text class="worker-phone">{{item.workerPhone}}</text>
          </view>
          <view class="app-meta">
            <text class="credit">信用分: {{item.workerCredit}}</text>
            <text class="orders">订单数: {{item.workerOrders}}</text>
          </view>
        </view>
      </view>

      <!-- 已完成 -->
      <view class="app-section" wx:if="{{applications.done && applications.done.length > 0}}">
        <text class="section-title">已完成 ({{applications.done.length}})</text>
        <view class="app-item" wx:for="{{applications.done}}" wx:key="id">
          <view class="app-info">
            <text class="worker-name">{{item.workerName}}</text>
            <text class="worker-phone">{{item.workerPhone}}</text>
          </view>
          <view class="app-meta">
            <text class="credit">信用分: {{item.workerCredit}}</text>
            <text class="orders">订单数: {{item.workerOrders}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Tab 2: 工资结算 -->
  <view class="tab-content" wx:if="{{activeTab === 1}}">
    <!-- 工作概要 -->
    <view class="st-card">
      <view class="st-job-header">
        <view class="text-avatar" style="width:60rpx;height:60rpx;font-size:24rpx;background-color:#10B981;">{{job.avatarText}}</view>
        <view class="st-job-info">
          <text class="st-company">{{job.company}} · {{job.jobType}}</text>
          <text class="st-date">{{job.dateRange}}</text>
        </view>
      </view>
      <view class="st-summary">
        <view class="st-sum-item">
          <text class="st-sum-val text-primary">{{job.totalWorkers}}</text>
          <text class="st-sum-label">实到人数</text>
        </view>
        <view class="st-sum-item">
          <text class="st-sum-val text-cta">{{job.totalHours}}</text>
          <text class="st-sum-label">总工时(h)</text>
        </view>
        <view class="st-sum-item">
          <text class="st-sum-val text-warm">¥{{job.factoryTotal}}</text>
          <text class="st-sum-label">工厂总支付</text>
        </view>
      </view>
    </view>

    <!-- 确认状态 -->
    <view class="st-card">
      <text class="card-title">确认状态</text>
      <view class="step-list">
        <view class="step-item" wx:for="{{steps}}" wx:key="label">
          <view class="step-dot {{item.done ? 'dot-done' : 'dot-pending'}}">
            <text wx:if="{{item.done}}">✓</text>
            <text wx:else>⏱</text>
          </view>
          <view class="step-content">
            <text class="step-label">{{item.label}}</text>
            <text class="step-time">{{item.time}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 结算明细 -->
    <view class="st-card">
      <text class="card-title">结算明细</text>
      <!-- 表头 -->
      <view class="table-header">
        <text class="th" style="flex:1.2;">姓名</text>
        <text class="th" style="flex:1;">工时</text>
        <text class="th" style="flex:1.2;">工厂付</text>
        <text class="th" style="flex:1.2;">临工得</text>
        <text class="th" style="flex:1;">状态</text>
      </view>
      <!-- 表行 -->
      <view class="table-row" wx:for="{{workers}}" wx:key="name">
        <text class="td" style="flex:1.2;">{{item.name}}</text>
        <text class="td" style="flex:1;">{{item.hours}}h</text>
        <text class="td" style="flex:1.2;">¥{{item.factoryPay}}</text>
        <text class="td" style="flex:1.2;">¥{{item.workerPay}}</text>
        <text class="td {{item.confirmed ? 'text-fresh' : 'text-warm'}}" style="flex:1;">{{item.confirmed ? '已确认' : '待确认'}}</text>
      </view>
      <text class="view-all" bindtap="onViewAll">查看全部{{job.totalWorkers}}人明细</text>
    </view>

    <!-- 费用汇总 -->
    <view class="st-card">
      <text class="card-title">费用汇总</text>
      <view class="fee-list">
        <view class="fee-row">
          <text class="fee-label">工厂总支付</text>
          <text class="fee-value">¥{{fees.factoryTotal}}</text>
        </view>
        <view class="fee-row">
          <text class="fee-label">平台服务费（20%）</text>
          <text class="fee-value fee-minus">-¥{{fees.platformFee}}</text>
        </view>
        <view class="fee-row">
          <text class="fee-label">管理员服务费</text>
          <text class="fee-value fee-minus">-¥{{fees.managerFee}}</text>
        </view>
        <view class="fee-divider"></view>
        <view class="fee-row fee-total">
          <text class="fee-label">临工实发总额</text>
          <text class="fee-value text-cta">¥{{fees.workerTotal}}</text>
        </view>
      </view>
    </view>

    <!-- 底部操作 -->
    <view class="st-bottom" wx:if="{{!viewOnly}}">
      <button class="btn btn-primary" wx:if="{{role === 'enterprise'}}" bindtap="onPay">确认支付 ¥{{job.factoryTotal}}</button>
      <button class="btn btn-cta" wx:if="{{role === 'manager'}}" bindtap="onSubmitSettlement">提交结算单</button>
      <text class="st-hint" wx:if="{{role === 'enterprise'}}">支付后工资将自动发放至临工钱包</text>
      <text class="st-hint" wx:if="{{role === 'manager'}}">提交后将通知临工确认工时</text>
    </view>
  </view>
</view>

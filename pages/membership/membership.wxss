.mb-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

.mb-card {
  margin: 24rpx 32rpx 0;
  border-radius: 32rpx;
  padding: 40rpx;
  background: linear-gradient(135deg, #FBBF24, #F97316);
  color: #fff;
  position: relative;
  overflow: hidden;
}

.mb-card-bg1 {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.mb-card-bg2 {
  position: absolute;
  bottom: -48rpx;
  left: -48rpx;
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.mb-user {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 32rpx;
  position: relative;
}

.mb-user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  flex-shrink: 0;
}

.mb-user-info {
  display: flex;
  flex-direction: column;
}

.mb-user-name {
  font-size: 28rpx;
  font-weight: 600;
}

.mb-user-status {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.mb-vip-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  position: relative;
}

.mb-star {
  font-size: 36rpx;
  opacity: 0.9;
}

.mb-vip-text {
  font-size: 32rpx;
  font-weight: 700;
}

.mb-section {
  margin: 24rpx 32rpx 0;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 24rpx;
}

.benefit-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx 0;
  text-align: center;
}

.benefit-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  box-sizing: border-box;
}

.benefit-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.benefit-icon .iconfont {
  font-size: 32rpx;
}

.benefit-icon-amber {
  background-color: #FFFBEB;
  color: #F59E0B;
}

.benefit-icon-amber .iconfont {
  color: #F59E0B;
}

.benefit-icon-rose {
  background-color: #FFF1F2;
  color: #F43F5E;
}

.benefit-icon-rose .iconfont {
  color: #F43F5E;
}

.benefit-icon-blue {
  background-color: #EFF6FF;
  color: #3B82F6;
}

.benefit-icon-blue .iconfont {
  color: #3B82F6;
}

.benefit-icon-green {
  background-color: #ECFDF5;
  color: #10B981;
}

.benefit-icon-green .iconfont {
  color: #10B981;
}

.benefit-icon-sky {
  background-color: #F0F9FF;
  color: #0EA5E9;
}

.benefit-icon-sky .iconfont {
  color: #0EA5E9;
}

.benefit-name {
  font-size: 22rpx;
  font-weight: 500;
  color: #1E293B;
}

.benefit-desc {
  font-size: 18rpx;
  color: #94A3B8;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border: 4rpx solid #E2E8F0;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.plan-selected {
  border-color: #3B82F6;
  background-color: rgba(239, 246, 255, 0.5);
}

.plan-tag {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 18rpx;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 0 0 0 16rpx;
}

.plan-left {
  display: flex;
  flex-direction: column;
}

.plan-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.plan-desc {
  font-size: 20rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.plan-right {
  text-align: right;
}

.plan-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
}

.plan-selected .plan-price {
  color: #3B82F6;
}

.plan-original {
  font-size: 20rpx;
  color: #94A3B8;
  text-decoration: line-through;
}

.mb-bottom-area {
  margin: 32rpx 32rpx 0;
}

.mb-agreement-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.mb-checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #CBD5E1;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.mb-checkbox-checked {
  border-color: #F97316;
  background-color: #F97316;
}

.mb-checkbox-mark {
  color: #fff;
  font-size: 20rpx;
  line-height: 1;
}

.mb-pay-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to right, #FBBF24, #F97316);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.35);
}

.mb-pay-btn::after {
  border: none;
}

.mb-pay-btn-disabled {
  background: #CBD5E1;
  color: #fff;
  box-shadow: none;
}

.mb-hint {
  font-size: 20rpx;
  color: #94A3B8;
}

.mb-hint-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}

.mb-hint-link {
  font-size: 20rpx;
  color: #3B82F6;
}

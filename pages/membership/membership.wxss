.mb-page {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 40rpx;
}

.mb-card {
  margin: 24rpx 32rpx 0;
  border-radius: 32rpx;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, #FBBF24, #F97316);
  color: #fff;
  position: relative;
  overflow: hidden;
}

.mb-card-bg1 {
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 256rpx;
  height: 256rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.mb-card-bg2 {
  position: absolute;
  bottom: -48rpx;
  left: -48rpx;
  width: 160rpx;
  height: 160rpx;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.mb-user-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  position: relative;
}

.mb-user-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  min-width: 0;
  flex: 1;
}

.mb-user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255, 255, 255, 0.35);
  flex-shrink: 0;
}

.mb-user-avatar-ph {
  width: 72rpx;
  height: 72rpx;
  font-size: 26rpx;
  background-color: #3B82F6;
  flex-shrink: 0;
}

.mb-user-name {
  font-size: 28rpx;
  font-weight: 600;
  min-width: 0;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mb-user-status-right {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
  max-width: 52%;
}

.mb-star {
  font-size: 26rpx;
  opacity: 0.9;
  flex-shrink: 0;
}

.mb-vip-text {
  font-size: 24rpx;
  font-weight: 700;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mb-poster-wrap {
  margin: 16rpx 32rpx 0;
  border-radius: 20rpx;
  overflow: hidden;
  background-color: #fff;
  line-height: 0;
}

.mb-poster-img {
  width: 100%;
  display: block;
  vertical-align: top;
}

.mb-section {
  margin: 24rpx 32rpx 0;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
  display: block;
  margin-bottom: 24rpx;
}

.plan-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.plan-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  border: 4rpx solid #E2E8F0;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.plan-selected {
  border-color: #3B82F6;
  background-color: rgba(239, 246, 255, 0.5);
}

.plan-tag {
  position: absolute;
  top: 0;
  right: 0;
  font-size: 18rpx;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 0 0 0 16rpx;
}

.plan-left {
  display: flex;
  flex-direction: column;
}

.plan-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1E293B;
}

.plan-desc {
  font-size: 20rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.plan-right {
  text-align: right;
}

.plan-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #1E293B;
  display: block;
}

.plan-selected .plan-price {
  color: #3B82F6;
}

.plan-original {
  font-size: 20rpx;
  color: #94A3B8;
  text-decoration: line-through;
}

.mb-bottom-area {
  margin: 32rpx 32rpx 0;
}

.mb-agreement-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.mb-checkbox {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  border: 2rpx solid #CBD5E1;
  background-color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.mb-checkbox-checked {
  border-color: #F97316;
  background-color: #F97316;
}

.mb-checkbox-mark {
  color: #fff;
  font-size: 20rpx;
  line-height: 1;
}

.mb-pay-btn {
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(to right, #FBBF24, #F97316);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 24rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(245, 158, 11, 0.35);
}

.mb-pay-btn::after {
  border: none;
}

.mb-pay-btn-disabled {
  background: #CBD5E1;
  color: #fff;
  box-shadow: none;
}

.mb-hint {
  font-size: 20rpx;
  color: #94A3B8;
}

.mb-hint-row {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
}

.mb-hint-link {
  font-size: 20rpx;
  color: #3B82F6;
}

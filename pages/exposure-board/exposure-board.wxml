<view class="eb-page">
  <nav-bar title="诚信通" showBack="{{false}}" />

  <view class="eb-tab-wrap">
    <view class="eb-tabs">
      <view
        class="eb-tab {{currentTab === index ? 'eb-tab-active' : ''}}"
        wx:for="{{tabs}}"
        wx:key="key"
        data-index="{{index}}"
        bindtap="onTabChange"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </view>

  <scroll-view
    class="eb-scroll"
    scroll-y
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="eb-list-wrap">
      <empty-state
        wx:if="{{!loading && list.length === 0}}"
        text="暂无维权分享"
        subText="通过真实经历帮助更多人了解协商流程与结果反馈"
      />

      <view class="eb-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}" bindtap="onTapCard">
        <view class="eb-card-header">
          <view class="text-avatar text-avatar-sm" style="background-color: {{item.avatarColor}};">{{item.avatarText}}</view>
          <view class="eb-header-info">
            <text class="eb-target">{{item.publisherName}}</text>
          </view>
        </view>

        <view class="eb-detail-row" wx:if="{{item.company}}">
          <text class="eb-dl">对方</text>
          <text class="eb-dv eb-dv-highlight">{{item.company}}</text>
        </view>
        <view class="eb-detail-row" wx:if="{{item.amount}}">
          <text class="eb-dl">涉及金额</text>
          <text class="eb-dv">{{item.amount}}</text>
        </view>

        <text class="eb-desc">{{item.reason}}</text>

        <view class="img-grid img-count-{{item.images.length}}" wx:if="{{item.images && item.images.length > 0}}">
          <view class="img-grid-item" wx:for="{{item.images}}" wx:for-item="img" wx:key="*this">
            <image
              class="img-grid-img"
              src="{{img}}"
              mode="aspectFill"
              data-urls="{{item.images}}"
              data-current="{{img}}"
              catchtap="onPreviewImage"
            />
          </view>
        </view>

        <view class="eb-card-bottom">
          <text class="eb-bottom-date">{{item.date}}</text>
          <view class="eb-actions">
            <view class="eb-action eb-action-share">
              <text class="eb-action-icon iconfont icon-fenxiang1"></text>
              <text class="eb-action-text">分享</text>
              <button class="share-overlay" open-type="share" data-id="{{item.id}}" data-type="{{item.type}}"></button>
            </view>
          </view>
        </view>
        <view class="eb-card-disclaimer">
          <text class="eb-card-disclaimer-text">聚采通声明：该曝光所涉及内容、信息和数据来自于用户自发，不代表平台的观点和立场。如有任何不实或疑问，请联系聚采通工作人员。</text>
        </view>
      </view>

      
    </view>
  </scroll-view>

  <view class="eb-fab" bindtap="onPublishExposure">
    <text class="eb-fab-icon">+</text>
  </view>
</view>

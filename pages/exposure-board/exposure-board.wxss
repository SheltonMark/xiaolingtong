.eb-page {
  height: 100vh;
  background: linear-gradient(180deg, #eef6ff 0%, #f8fbff 180rpx, #f6f8fc 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.eb-tab-wrap {
  margin: 24rpx 32rpx 0;
  padding: 8rpx;
  border-radius: 24rpx;
  background-color: rgba(255, 255, 255, 0.92);
}

.eb-tabs {
  display: flex;
  gap: 8rpx;
}

.eb-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 24rpx;
  color: #64748b;
  border-radius: 18rpx;
  transition: all 0.2s ease;
}

.eb-tab-active {
  background: linear-gradient(135deg, #dbeafe 0%, #e0f2fe 100%);
  color: #1d4ed8;
  font-weight: 600;
}

.eb-scroll {
  flex: 1;
  overflow-x: hidden;
}

.eb-list-wrap {
  margin: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-top: 24rpx;
  padding-bottom: calc(196rpx + env(safe-area-inset-bottom));
}

.eb-card {
  background-color: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.04);
}

.eb-card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.eb-header-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eb-target {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.eb-detail-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.eb-dl {
  font-size: 22rpx;
  color: #64748b;
  flex-shrink: 0;
}

.eb-dv {
  font-size: 22rpx;
  color: #0f172a;
  font-weight: 600;
}

.eb-desc {
  font-size: 24rpx;
  color: #334155;
  line-height: 1.8;
  display: block;
  margin-bottom: 16rpx;
}

.eb-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.eb-bottom-date {
  font-size: 20rpx;
  color: #94a3b8;
}

.eb-actions {
  display: flex;
  align-items: center;
}

.eb-action {
  display: flex;
  align-items: center;
  gap: 6rpx;
  position: relative;
}

.eb-action-icon {
  font-size: 28rpx;
  color: #64748b;
}

.eb-action-text {
  font-size: 22rpx;
  color: #64748b;
}

.share-overlay {
  position: absolute;
  inset: 0;
  opacity: 0;
  margin: 0;
  padding: 0;
  border: none;
  min-height: 0;
  background: transparent;
}

.share-overlay::after {
  border: none;
}

.eb-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  height: 88rpx;
  padding: 0 28rpx;
  border-radius: 9999rpx;
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  box-shadow: 0 12rpx 32rpx rgba(37, 99, 235, 0.28);
  display: flex;
  align-items: center;
  gap: 10rpx;
  z-index: 50;
}

.eb-fab-icon {
  font-size: 34rpx;
  color: #fff;
  line-height: 1;
}

.eb-fab-text {
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
}

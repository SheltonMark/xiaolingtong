.jd-page {
  background-color: #F5F5F5;
}
page {
  background-color: #fff;
}
.jd-swiper { width: 100%; height: 750rpx; position: relative; }
.jd-swiper-img { width: 100%; height: 100%; }
.swiper-counter {
  position: absolute; bottom: 16rpx; right: 24rpx;
  background-color: rgba(0,0,0,0.5); color: #fff;
  font-size: 20rpx; padding: 4rpx 16rpx; border-radius: 9999rpx;
  z-index: 10;
}
.salary-section {
  background-color: #fff; padding: 24rpx 32rpx;
}
.salary-row {
  display: flex; align-items: baseline; gap: 4rpx; margin-bottom: 12rpx;
}
.salary-big { font-size: 48rpx; font-weight: 700; }
.salary-unit { font-size: 24rpx; font-weight: 500; }
.urgent-badge {
  font-size: 24rpx; color: #F43F5E; background-color: #FFF1F2;
  padding: 6rpx 16rpx; border-radius: 8rpx; margin-left: 16rpx;
  font-weight: 600;
}
.jd-title {
  font-size: 30rpx; font-weight: 600; color: #1E293B;
  display: block; margin-bottom: 12rpx; line-height: 1.5;
}
.location-row { display: flex; align-items: center; gap: 8rpx; }
.loc-icon { font-size: 24rpx; color: #3B82F6; }
.loc-text { font-size: 24rpx; color: #64748B; flex: 1; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.nav-icon {
  font-size: 36rpx; color: #3B82F6;
  flex-shrink: 0; padding: 8rpx;
}
.distance-pill {
  display: inline-flex; align-items: center;
  background: #EFF6FF; border-radius: 20rpx;
  padding: 6rpx 16rpx; margin-top: 12rpx;
}
.distance-val { font-size: 22rpx; color: #3B82F6; font-weight: 500; }

.detail-card {
  background-color: #fff; margin-top: 8rpx; padding: 24rpx 32rpx;
}
.card-header-row {
  display: flex; align-items: center; gap: 12rpx; margin-bottom: 24rpx;
}
.card-icon { font-size: 28rpx; }
.card-label {
  font-size: 28rpx; font-weight: 600; color: #1E293B;
  display: block; margin-bottom: 0;
}
.detail-card > .card-label { margin-bottom: 20rpx; }
.detail-list { display: flex; flex-direction: column; gap: 20rpx; }
.detail-row { display: flex; }
.dl {
  width: 128rpx; font-size: 24rpx; color: #64748B;
  flex-shrink: 0; font-weight: 600;
}
.dv { font-size: 24rpx; color: #1E293B; flex: 1; line-height: 1.6; }

/* 福利标签 */
.tags-wrap { display: flex; flex-wrap: wrap; gap: 12rpx; align-items: center; }
.benefit-tag {
  font-size: 22rpx; padding: 6rpx 18rpx; border-radius: 8rpx;
}
.benefit-green { background-color: #ECFDF5; color: #10B981; }
.benefit-blue { background-color: #EFF6FF; color: #3B82F6; }
.benefit-amber { background-color: #FFFBEB; color: #F59E0B; }
.benefit-time { background-color: #FFF7ED; color: #F97316; font-weight: 500; }

/* 报名剩余 */
.remain-text { color: #F97316; font-size: 22rpx; }

/* 企业信息 */
.company-row { display: flex; align-items: center; gap: 24rpx; }
.company-avatar-img {
  width: 80rpx; height: 80rpx; border-radius: 50%; flex-shrink: 0;
}
.comp-info { display: flex; flex-direction: column; flex: 1; }
.comp-name-row { display: flex; align-items: center; gap: 12rpx; }
.comp-name { font-size: 26rpx; font-weight: 600; color: #1E293B; }
.cert-badge {
  font-size: 18rpx; color: #fff;
  padding: 2rpx 12rpx; border-radius: 6rpx;
}
.cert-badge-verified {
  background-color: #10B981;
}
.cert-badge-unverified {
  background-color: #94A3B8;
}
.comp-credit { font-size: 22rpx; color: #94A3B8; margin-top: 4rpx; }

/* 联系方式 */
.contact-list {
  margin-top: 24rpx; padding-top: 24rpx;
  border-top: 1rpx solid #F1F5F9;
  display: flex; flex-direction: column; gap: 12rpx;
}
.contact-row {
  display: flex; align-items: center; justify-content: space-between;
}
.contact-label { font-size: 24rpx; color: #64748B; }
.contact-value { font-size: 24rpx; color: #1E293B; }
.contact-action {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
}
.contact-action-text {
  font-size: 24rpx;
  color: #2563EB;
  font-weight: 600;
}
.contact-action-hint {
  font-size: 20rpx;
  color: #94A3B8;
}

/* 收藏 */
.fav-active { color: #F59E0B; }
.fav-inactive { color: #CBD5E1; }

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -2rpx 8rpx rgba(0,0,0,0.05);
  z-index: 100;
}
.bar-left {
  display: flex; align-items: center; gap: 24rpx;
}
.bar-icon-btn {
  display: flex; flex-direction: column; align-items: center; gap: 2rpx;
}
.bar-icon-btn-share {
  display: flex; flex-direction: column; align-items: center; gap: 2rpx;
  background: transparent; border: none; padding: 0; margin: 0;
  line-height: 1;
}
.bar-icon-btn-share::after { border: none; }
.bar-icon-btn .iconfont { font-size: 36rpx; }
.bar-icon-btn-share .iconfont { font-size: 36rpx; }
.bar-icon-btn-share-wrap { position: relative; }
.bar-icon-btn-share-wrap .share-overlay {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  opacity: 0; margin: 0; padding: 0; border: none;
  min-height: 0; background: transparent; z-index: 1;
}
.bar-icon-btn-share-wrap .share-overlay::after { border: none; }
.bar-icon-gray { color: #94A3B8; }
.bar-icon-label { font-size: 18rpx; color: #94A3B8; }
.bar-right {
  display: flex; align-items: center; gap: 12rpx;
}
.bar-btn-phone {
  display: flex; align-items: center; justify-content: center;
  height: 72rpx; padding: 0 40rpx; border-radius: 16rpx;
  background: #3B82F6; color: #fff;
  font-size: 26rpx; font-weight: 600;
}
.bar-btn-apply {
  height: 72rpx; padding: 0 40rpx; border-radius: 16rpx;
  background: #F97316; color: #fff;
  font-size: 26rpx; font-weight: 600;
  display: flex; align-items: center; justify-content: center;
}

<view class="cert-page">
  <nav-bar title="实名认证" />

  <view class="steps">
    <view class="step">
      <view class="step-circle step-active">1</view>
      <text class="step-label step-label-active">填写信息</text>
    </view>
    <view class="step-line"></view>
    <view class="step">
      <view class="step-circle">2</view>
      <text class="step-label">审核中</text>
    </view>
    <view class="step-line"></view>
    <view class="step">
      <view class="step-circle">3</view>
      <text class="step-label">认证完成</text>
    </view>
  </view>

  <view class="form-area">
    <view class="form-group">
      <text class="form-label">身份证照片 <text class="required">*</text></text>
      <view class="upload-grid">
        <view class="upload-area upload-half" bindtap="onUploadFront">
          <image wx:if="{{frontImage}}" src="{{frontImage}}" mode="aspectFill" class="upload-preview" />
          <view wx:else class="upload-placeholder">
            <text class="upload-icon iconfont icon-shenfenzheng"></text>
            <text class="upload-hint-sm">人像面</text>
          </view>
        </view>
        <view class="upload-area upload-half" bindtap="onUploadBack">
          <image wx:if="{{backImage}}" src="{{backImage}}" mode="aspectFill" class="upload-preview" />
          <view wx:else class="upload-placeholder">
            <text class="upload-icon iconfont icon-shenfenzhengfanmian"></text>
            <text class="upload-hint-sm">国徽面</text>
          </view>
        </view>
      </view>
      <text class="verify-hint">上传后会自动识别身份证信息，识别结果可手动修改。</text>
    </view>

    <view class="form-group">
      <text class="form-label">真实姓名 <text class="required">*</text></text>
      <input class="form-input" placeholder="请输入身份证上的姓名" data-field="name" value="{{form.name}}" bindinput="onInput" />
    </view>

    <view class="form-group">
      <text class="form-label">身份证号 <text class="required">*</text></text>
      <input class="form-input" placeholder="请输入18位身份证号" data-field="idCard" value="{{form.idCard}}" bindinput="onInput" />
    </view>

    <view class="form-group">
      <text class="form-label">手机号 <text class="required">*</text></text>
      <input class="form-input" type="number" placeholder="请输入手机号" data-field="phone" value="{{form.phone}}" bindinput="onInput" />
    </view>

    <view wx:if="{{certSmsEnabled}}" class="form-group">
      <text class="form-label">短信验证码 <text class="required">*</text></text>
      <view class="verify-row">
        <input class="form-input verify-input" type="number" maxlength="6" placeholder="请输入6位验证码" value="{{smsCode}}" bindinput="onSmsCodeInput" />
        <view class="sms-btn {{smsCountdown ? 'sms-btn-disabled' : ''}}" bindtap="onSendSms">
          {{smsCountdown ? smsCountdown + 's后重发' : '发送验证码'}}
        </view>
      </view>
      <view wx:if="{{verifyingSms || verificationToken}}" class="verify-status {{verificationToken ? 'verify-status-done' : ''}}">
        {{verificationToken ? '验证码已通过' : '验证码校验中...'}}
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">擅长工种 <text class="optional">(选填)</text></text>
      <view class="tag-list">
        <view class="skill-tag {{selectedSkillsMap[item] ? 'skill-tag-active' : ''}}"
              wx:for="{{skills}}" wx:key="*this" data-tag="{{item}}" bindtap="onSkillTap">{{item}}</view>
      </view>
    </view>

    <button class="submit-btn submit-orange" bindtap="onSubmit">提交认证</button>
    <text class="submit-hint">审核结果将在 1-3 个工作日内通知您</text>
  </view>
</view>

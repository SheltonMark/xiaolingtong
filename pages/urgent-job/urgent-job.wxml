<!--pages/urgent-job/urgent-job.wxml-->
<view class="pm-page">
  <nav-bar title="设置急招" />
  <!-- 招工信息预览 -->
  <view class="pm-section">
    <text class="pm-hint">招工信息</text>
    <view class="pm-preview" wx:if="{{jobInfo}}">
      <image class="pm-preview-img" wx:if="{{jobInfo.image}}" src="{{jobInfo.image}}" mode="aspectFill" />
      <view class="pm-preview-img pm-preview-placeholder" wx:else>
        <text class="iconfont icon-tupian" style="font-size:40rpx;color:#94A3B8;"></text>
      </view>
      <view class="pm-preview-info">
        <text class="pm-preview-title">{{jobInfo.title}}</text>
        <view class="pm-preview-tags">
          <text class="pm-tag-orange">招工</text>
          <text class="pm-tag-rose">{{jobInfo.salary}}{{jobInfo.salaryUnit}}</text>
        </view>
      </view>
    </view>
    <view class="pm-preview" wx:else>
      <text style="color:#94A3B8;font-size:24rpx;">加载中...</text>
    </view>
  </view>

  <!-- 急招效果预览 -->
  <view class="pm-section">
    <text class="section-title">急招效果</text>
    <text class="pm-effect-desc">设置急招后，您的招工信息标题后将显示醒目的"急招"红色标签</text>
    <view class="pm-effect-box">
      <view class="pm-effect-row">
        <text class="pm-effect-text">{{jobInfo.title || '您的招工标题'}}</text>
        <text class="pm-urgent-badge">急招</text>
      </view>
      <text class="pm-effect-hint">红色"急招"标签更吸引求职者注意</text>
    </view>
  </view>

  <!-- 急招时长选择 -->
  <view class="pm-section">
    <text class="section-title">选择急招时长</text>
    <view class="pm-options">
      <view class="pm-preview" wx:if="{{options.length === 0}}">
        <text style="color:#94A3B8;font-size:24rpx;">暂无可用套餐</text>
      </view>
      <view class="pm-option {{selectedIndex === index ? 'pm-option-active' : ''}}"
            wx:for="{{options}}" wx:key="id"
            data-index="{{index}}" bindtap="onSelect">
        <text class="pm-option-tag" wx:if="{{item.tag}}" style="background-color:{{item.tagColor}};">{{item.tag}}</text>
        <view class="pm-option-left">
          <view class="pm-radio {{selectedIndex === index ? 'pm-radio-active' : ''}}">
            <view class="pm-radio-dot" wx:if="{{selectedIndex === index}}"></view>
          </view>
          <view class="pm-option-info">
            <text class="pm-option-name">{{item.name}}</text>
            <text class="pm-option-desc">{{item.desc}}</text>
          </view>
        </view>
        <text class="pm-option-price {{selectedIndex === index ? 'text-primary' : ''}}">{{item.beans}}灵豆</text>
      </view>
    </view>
  </view>

  <!-- 急招规则 -->
  <view class="pm-section">
    <text class="section-title">急招规则</text>
    <view class="pm-rules">
      <text class="pm-rule">1. 急招标签将在招工信息标题后显示</text>
      <text class="pm-rule">2. 急招到期后自动取消标签</text>
      <text class="pm-rule">3. 急招期间信息被下架，不退款</text>
    </view>
  </view>

  <!-- 支付按钮 -->
  <view class="pm-bottom-area">
    <button class="btn btn-primary" bindtap="onPay">立即支付 · {{options.length ? options[selectedIndex].beans : 0}}灵豆</button>
  </view>
</view>
